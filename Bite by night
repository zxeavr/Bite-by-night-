            TweenService:Create(barFill,TweenInfo.new(dur,Enum.EasingStyle.Quad),
                {Size=UDim2.new(to/100,0,1,0)}):Play()
            local st2 = tick()
            while (tick()-st2) < dur do
                pcall(function() pctL.Text = math.floor(from+(to-from)*((tick()-st2)/dur)).."%" end)
                task.wait(0.02)
            end
            pctL.Text = to.."%"
        end
        subL.Text = "Ready!"; barFill.BackgroundColor3 = Color3.fromRGB(50,200,100)
        task.wait(2)
        TweenService:Create(card,TweenInfo.new(0.5,Enum.EasingStyle.Quad),{BackgroundTransparency=1}):Play()
        TweenService:Create(bg,TweenInfo.new(0.5,Enum.EasingStyle.Quad),{BackgroundTransparency=1}):Play()
        task.wait(0.5); sg:Destroy(); callback()
    end)
end

