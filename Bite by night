-- MASTER LOOP (anti stun/ragdoll)
local masterConn=nil
local function MasterHeartbeat()
    local char = LP.Character
    if S.AntiStun and char then
        for _,a in ipairs({"Stun","Stunned","IsStunned","Blinded","IsBlinded","Slowed","Slowness"}) do
            local v=char:GetAttribute(a)
            if type(v)=="boolean" and v then char:SetAttribute(a,false)
            elseif type(v)=="number" and v>0 then char:SetAttribute(a,0) end
        end
        for _,t in ipairs({"Stun","Stunned","Blinded"}) do
            if CollectionService:HasTag(char,t) then CollectionService:RemoveTag(char,t) end
        end
    end
    if S.AntiRagdoll and char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum:GetState()==Enum.HumanoidStateType.Physics then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end
local function ToggleMasterLoop(on)
    if masterConn then masterConn:Disconnect(); masterConn=nil end
    if on then masterConn = RunService.Heartbeat:Connect(MasterHeartbeat) end
end

