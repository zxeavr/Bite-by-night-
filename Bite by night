    local function ApplyESP(obj, tcfg, label, maxDist, showHP, labelOverride)
        if not obj or not obj.Parent then return end
        local anyOn = tcfg.On or (showHP and S.ESPHealth)
        local d = espReg[obj]
        if d then
            if not d.valid then espReg[obj] = nil; d = nil
            elseif not d.HL or not d.HL.Parent then
                pcall(function() if d.SB then d.SB:Destroy() end; if d.BB then d.BB:Destroy() end; if d.DotBB then d.DotBB:Destroy() end end)
