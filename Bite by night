-- ============================================================
local espCache = {}
local function clearESP(obj)
    if espCache[obj] then pcall(function() espCache[obj]:Destroy() end); espCache[obj] = nil end
end

local function ESP(obj, color, name)
    if not obj or not obj.Parent then clearESP(obj); return end
    local mode = S.ESPMode
    local fillTrans = (mode == "Highlight" and 0.5) or (mode == "Chams" and 0.2) or 1
    local outlineTrans = 0.3

    if mode == "Name" then
        local bb = espCache[obj]
        if bb and bb:IsA("BillboardGui") and bb:FindFirstChild("NameTag") then
            bb.NameTag.Text = name or obj.Name
            bb.NameTag.TextColor3 = color
        else
            if bb then pcall(function() bb:Destroy() end) end
            bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,120,0,30)
            bb.StudsOffset = Vector3.new(0,0,0); bb.Parent = obj
            local txt = Instance.new("TextLabel", bb)
            txt.Name = "NameTag"; txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1; txt.Text = name or obj.Name
            txt.TextColor3 = color; txt.Font = Enum.Font.GothamBold
            txt.TextSize = 10; txt.TextStrokeTransparency = 0
            txt.TextStrokeColor3 = Color3.new(0,0,0)
            espCache[obj] = bb
        end
        return
    end

    -- Highlight / Chams / Outline
    local hl = espCache[obj]
    if hl and hl:IsA("Highlight") then
        hl.FillColor = color; hl.OutlineColor = color
        hl.FillTransparency = fillTrans
        hl.OutlineTransparency = outlineTrans
    else
        if hl then pcall(function() hl:Destroy() end) end
        hl = Instance.new("Highlight")
        hl.Adornee = obj
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.FillColor = color; hl.OutlineColor = color
        hl.FillTransparency = fillTrans
        hl.OutlineTransparency = outlineTrans
        hl.Parent = obj
        espCache[obj] = hl
    end
end

local function processAllESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP or not player.Character or not player.Team then continue end
        local on, color, name = false, nil, player.Name
        if IsKiller(player) then on = S.KillerESP; color = S.KillerColor
        elseif IsSurvivor(player) then on = S.SurvivorESP; color = S.SurvivorColor end
        if on then ESP(player.Character, color, name) else clearESP(player.Character) end
    end

    pcall(function()
        local map = workspace:FindFirstChild("Map"); if not map then return end
        for _, obj in ipairs(map:GetDescendants()) do
            if obj.Name == "Hook" then
                if obj:FindFirstChild("Model") then
                    for _, part in ipairs(obj.Model:GetDescendants()) do
                        if part:IsA("MeshPart") then
                            if S.HookESP then ESP(part, S.HookColor, "Hook") else clearESP(part) end
                        end
                    end
                end
                if obj:FindFirstChild("Cartoony Blood Puddle") then
                    local bp = obj["Cartoony Blood Puddle"]
                    if S.HookESP then ESP(bp, S.HookColor, "Hook") else clearESP(bp) end
                end
            elseif obj.Name == "Generator" then
                if S.GeneratorESP then ESP(obj, S.GeneratorColor, "Gen") else clearESP(obj) end
            elseif obj.Name == "Gate" then
                if S.GateESP then ESP(obj, S.GateColor, "Gate") else clearESP(obj) end
            elseif obj.Name == "Palletwrong" then
                if S.PalletESP then ESP(obj, S.PalletColor, "Pallet") else clearESP(obj) end
            elseif obj.Name == "Window" then
                if S.WindowESP then ESP(obj, S.WindowColor, "Window") else clearESP(obj) end
            end
        end
    end)
end

local function ClearESPCache()
    for obj, _ in pairs(espCache) do clearESP(obj) end
end

