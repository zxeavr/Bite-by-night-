-- ============================================================
-- CHARACTER UPDATES
-- ============================================================
LP.CharacterAdded:Connect(function()
    task.wait(1)
    RefreshChar()
    ConnectStamina()
    if S.NoClip then SetNoClip(true) end
    if S.AllowJump then SetAllowJump(true) end
    if S.AntiRagdoll then SetAntiRagdoll(true) end
    if CURRENT_GAME.Type == "BBN" and S.AntiStun then
        if _G.SetAntiStun then _G.SetAntiStun(true) end
    end
end)

RefreshChar()

-- ============================================================
-- INITIALIZATION
-- ============================================================
ConnectStamina()
SetAntiAFK(S.AntiAFK)
if S.AllowJump then SetAllowJump(true) end
if S.AntiRagdoll then SetAntiRagdoll(true) end
if S.NoClip then SetNoClip(true) end
if S.FullBright then SetFullBright(true) end
if S.FPSBooster then SetFPSBooster(true) end
if CURRENT_GAME.Type == "BBN" and S.AntiStun then
    if _G.SetAntiStun then _G.SetAntiStun(true) end
end

Rayfield:Notify({
    Title = "Phantom Hub v2.0",
    Content = "Loaded for " .. CURRENT_GAME.Name,
    Duration = 3,
    Image = 4483362458
})
