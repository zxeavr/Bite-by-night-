local parryConn=nil
local function SetAutoParry(on)
    if parryConn then parryConn:Disconnect(); parryConn=nil end
    if not on then return end
    parryConn=RunService.Heartbeat:Connect(function()
        if not S.AutoParry then return end
        local char=LP.Character; if not char then return end
        local myRoot=char:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr==LP then continue end
            local pchar=plr.Character; if not pchar then continue end
            local attackerRoot=pchar:FindFirstChild("HumanoidRootPart"); if not attackerRoot then continue end
            local diff=attackerRoot.Position-myRoot.Position
            local distSq=diff:Dot(diff)
            if distSq>(S.ParryRangePull*S.ParryRangePull) then continue end
            local hum=pchar:FindFirstChildOfClass("Humanoid"); if not hum then continue end
            local animator=hum:FindFirstChildOfClass("Animator"); if not animator then continue end
            for _,track in ipairs(animator:GetPlayingAnimationTracks()) do
                if not track.IsPlaying then continue end
                if not track.Animation then continue end
                local animId=track.Animation.AnimationId
                local attackType=ATTACK_ANIM_IDS[animId]
                if not attackType then continue end
                local rangeNeeded=(attackType=="pull") and S.ParryRangePull or S.ParryRangeBasic
                if distSq>(rangeNeeded*rangeNeeded) then continue end
                DoParryReliable(); break
            end
        end
    end)
end

