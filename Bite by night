-- ESP System (BBN)
local espReg = {}
local function GetAnchor(obj)
	if obj:IsA("BasePart") then return obj end
	return obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or (obj:IsA("Model") and obj.PrimaryPart) or obj:FindFirstChildOfClass("BasePart",true)
end
local function BuildESP(obj,color,label,maxDist)
	if not obj or not obj.Parent then return nil end
	local d = {valid=true}
	local hl = Instance.new("Highlight"); hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
	hl.FillTransparency=0.55; hl.OutlineTransparency=0; hl.FillColor=color; hl.OutlineColor=color; hl.Adornee=obj; hl.Enabled=false; hl.Parent=obj; d.HL=hl
	local anc = GetAnchor(obj)
	if anc then
		local bb = Instance.new("BillboardGui"); bb.Size=UDim2.fromOffset(200,55); bb.StudsOffset=Vector3.new(0,4,0)
		bb.AlwaysOnTop=true; bb.Enabled=false; bb.ResetOnSpawn=false; bb.LightInfluence=0
		bb.MaxDistance=maxDist or 9999; bb.Adornee=anc; bb.Parent=anc
		local hpL = Instance.new("TextLabel",bb); hpL.Size=UDim2.new(1,0,.45,0); hpL.BackgroundTransparency=1
		hpL.Font=Enum.Font.GothamBold; hpL.TextSize=13; hpL.TextColor3=Color3.fromRGB(100,255,100)
		hpL.TextStrokeTransparency=0.2; hpL.Visible=false
		local nmL = Instance.new("TextLabel",bb); nmL.Size=UDim2.new(1,0,.55,0); nmL.Position=UDim2.fromScale(0,.45)
		nmL.BackgroundTransparency=1; nmL.Text=label; nmL.TextColor3=color; nmL.Font=Enum.Font.GothamBold
		nmL.TextSize=15; nmL.TextStrokeTransparency=0.2; nmL.Visible=false
		d.BB=bb; d.HpL=hpL; d.Lbl=nmL
	end
	local conn; conn = obj.AncestryChanged:Connect(function()
		if obj.Parent then return end; conn:Disconnect(); d.valid=false
		pcall(function() if d.HL then d.HL:Destroy() end; if d.BB then d.BB:Destroy() end end); espReg[obj]=nil
	end); espReg[obj]=d; return d
end
local function ApplyESP(obj,tcfg,label,maxDist,showHP,labelOvr)
	if not obj or not obj.Parent then return end
	local anyOn = tcfg.On or (showHP and S.ESPHealth)
	local d = espReg[obj]
	if d then
		if not d.valid then espReg[obj]=nil; d=nil
		elseif not d.HL or not d.HL.Parent then pcall(function() if d.BB then d.BB:Destroy() end end); espReg[obj]=nil; d=nil end
	end
	if not anyOn then if d then if d.HL then d.HL.Enabled=false end; if d.BB then d.BB.Enabled=false end end; return end
	if not d then d = BuildESP(obj,tcfg.Color,label,maxDist) end; if not d then return end
	if d.HL then d.HL.FillColor=tcfg.Color; d.HL.OutlineColor=tcfg.Color; d.HL.Enabled=tcfg.On end
	if d.Lbl then d.Lbl.TextColor3=tcfg.Color; d.Lbl.Text=labelOvr or label; d.Lbl.Visible=tcfg.On end
	if d.BB then d.BB.Enabled=(tcfg.On and d.Lbl~=nil) or (showHP and S.ESPHealth) end
	if d.HpL then
		if showHP and S.ESPHealth then
			local hum = obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health>0 then
				local r = math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
				d.HpL.Text = math.floor(hum.Health+.5).."/"..math.floor(hum.MaxHealth+.5)
				d.HpL.TextColor3 = Color3.fromRGB(math.floor((1-r)*255),math.floor(r*200+55),30); d.HpL.Visible=true
			else d.HpL.Visible=false end
		else d.HpL.Visible=false end
	end
end
