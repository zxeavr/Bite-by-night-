	if parryConn then parryConn:Disconnect(); parryConn = nil end; if not on then return end
	parryConn = RunService.Heartbeat:Connect(function()
		if not S.AutoParry then return end
		local char = LP.Character; if not char then return end
		local myRoot = char:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr==LP then continue end
			local pc = plr.Character; if not pc then continue end
			local ar = pc:FindFirstChild("HumanoidRootPart"); if not ar then continue end
			local dSq = (ar.Position-myRoot.Position):Dot(ar.Position-myRoot.Position)
			if dSq>(S.ParryRangePull*S.ParryRangePull) then continue end
			local hum = pc:FindFirstChildOfClass("Humanoid"); if not hum then continue end
			local anim = hum:FindFirstChildOfClass("Animator"); if not anim then continue end
			for _, track in ipairs(anim:GetPlayingAnimationTracks()) do
				if not track.IsPlaying or not track.Animation then continue end
				local aType = PARRY_ANIMS[track.Animation.AnimationId]; if not aType then continue end
				local rng = (aType=="pull") and S.ParryRangePull or S.ParryRange
				if dSq>(rng*rng) then continue end
				DoParry(); break
			end
		end
	end)
end

-- Auto Farm
local farmThread
local function GetMap()
	local maps = workspace:FindFirstChild("MAPS"); if not maps then return nil end
	local gm = maps:FindFirstChild("GAME MAP"); if gm then return gm end
	for _, c in ipairs(maps:GetChildren()) do if c:IsA("Model") or c:IsA("Folder") then return c end end
end
local function RD(base) return base*(0.7+math.random()*0.6) end
local function FarmMove(targetCF)
	if not LPChar then return end
	local hrp = LPChar:FindFirstChild("HumanoidRootPart"); if not hrp then return end
	if S.FarmUnderground then hrp.CFrame = CFrame.new(hrp.CFrame.Position-Vector3.new(0,50,0)); task.wait(RD(0.1)) end
	if S.FarmMode=="TP" then hrp.CFrame = targetCF
	else
		local d = (hrp.Position-targetCF.Position).Magnitude; local t = d/math.max(S.FarmSpeed,5)
		local tw = TweenService:Create(hrp,TweenInfo.new(t,Enum.EasingStyle.Linear),{CFrame=targetCF}); tw:Play(); tw.Completed:Wait()
	end
end
local function CompleteAllGenerators()
	local mF = GetMap(); if not mF then return end
	local genF = mF:FindFirstChild("Generators"); if not genF then return end
	local wasIG = S.InstantGen; S.InstantGen = true; StartInstantGen()
	for _, gen in ipairs(genF:GetChildren()) do
		if not S.AutoFarm then break end
		if (gen:GetAttribute("Progress") or 0)>=100 then continue end
		if not gen:IsA("Model") or not gen.PrimaryPart then continue end
		Log("Farm gen: "..gen.Name); task.wait(RD(0.5))
		FarmMove(CFrame.new(gen.PrimaryPart.Position+Vector3.new(0,2,0))); task.wait(RD(0.3))
		local rp = gen:FindFirstChild("RootPart")
		if rp then local attempts=0
			repeat attempts=attempts+1
				local prompt = nil
				for i=1,3 do local pt = rp:FindFirstChild("Point"..i); if pt then local pp = pt:FindFirstChildOfClass("ProximityPrompt"); if pp and pp.Enabled then prompt=pp; break end end end
				if not prompt then for _, atch in ipairs(rp:GetChildren()) do if atch:IsA("Attachment") then local pp = atch:FindFirstChildOfClass("ProximityPrompt"); if pp and pp.Enabled then prompt=pp; break end end end end
				if prompt and fireproximityprompt then pcall(function() fireproximityprompt(prompt) end) end
				task.wait(RD(1))
			until (gen:GetAttribute("Progress") or 0)>=100 or attempts>15 or not S.AutoFarm
		end
		if S.FarmUnderground and LPChar and LPChar:FindFirstChild("HumanoidRootPart") then
			LPChar.HumanoidRootPart.CFrame = CFrame.new(gen.PrimaryPart.Position-Vector3.new(0,50,0))
		end; task.wait(RD(0.5))
	end
	if not wasIG then S.InstantGen = false; StopInstantGen() end
	if S.FarmUnderground then local t2=0; while t2<120 do task.wait(1); t2=t2+1
		local gF2 = workspace:FindFirstChild("GAME"); local cE = gF2 and gF2:FindFirstChild("CAN_ESCAPE")
		if cE and cE.Value then break end end
	end
	pcall(function()
		local gF2 = workspace:FindFirstChild("GAME"); local cE = gF2 and gF2:FindFirstChild("CAN_ESCAPE")
		if not cE or not cE.Value then return end
		local mF2 = GetMap(); if not mF2 then return end
		local ef = mF2:FindFirstChild("Escapes"); if not ef then return end
		for _, v in ipairs(ef:GetChildren()) do
			if v:GetAttribute("Enabled")==false then continue end
			local cf = v:IsA("BasePart") and v.CFrame or (v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.CFrame)
			if cf and LPChar then LPChar:PivotTo(cf+Vector3.new(0,3,0)); return end
		end
	end)
end
local function SetAutoFarm(on)
	if farmThread then pcall(task.cancel,farmThread); farmThread = nil end; if not on then return end
	farmThread = task.spawn(function()
		while S.AutoFarm do task.wait(RD(0.5)); pcall(CompleteAllGenerators); task.wait(RD(5)) end
	end)
end

