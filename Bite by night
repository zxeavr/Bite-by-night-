local function FindTarget()
    local vp=Camera.ViewportSize; local center=Vector2.new(vp.X*.5,vp.Y*.5)
    local best,bestD=nil,math.huge
    local pf=workspace:FindFirstChild("PLAYERS"); local af=pf and pf:FindFirstChild("ALIVE"); if not af then return nil end
    for _,m in ipairs(af:GetChildren()) do
