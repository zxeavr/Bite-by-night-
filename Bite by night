        R.CamDoppelStab=TbKiller:Toggle({Title=Tr("cam_doppel_stab"),Value=S.CamDoppelStab,Callback=function(v) S.CamDoppelStab=v end})
        TbKiller:Divider()
        TbKiller:Paragraph({Title="Mimic",Desc="Grab ID: 95722006705414\nJump IDs: 71098053103714, 81381542397159"})
        R.CamMimicGrab=TbKiller:Toggle({Title=Tr("cam_mimic_grab"),Value=S.CamMimicGrab,Callback=function(v) S.CamMimicGrab=v end})
        R.CamMimicJump=TbKiller:Toggle({Title=Tr("cam_mimic_jump"),Value=S.CamMimicJump,Callback=function(v) S.CamMimicJump=v end})
        TbKiller:Divider()
        TbKiller:Paragraph({Title="All Killers (M1)",Desc="IDs: 112503015929213, 106673226682917\n70869035406359, 102810363618918, 120428956410756"})
        R.CamM1=TbKiller:Toggle({Title=Tr("cam_m1"),Value=S.CamM1,Callback=function(v) S.CamM1=v end})
        TbKiller:Divider()
        -- FOV circle
        R.ShowFOV=TbKiller:Toggle({Title=Tr("show_fov"),Value=S.ShowFOV,Callback=function(v) S.ShowFOV=v end})
        TbKiller:Colorpicker({Title=Tr("fov_color"),Default=S.FovColor,Callback=function(c)
            S.FovColor=c; local s=fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if s then s.Color=c end
        end})
        TbKiller:Slider({Title=Tr("fov_radius"),Step=5,Value={Min=30,Max=300,Default=120},Callback=function(v) S.CamFOV=v end})
        TbKiller:Button({Title=Tr("lock_near"),Callback=function()
            S.CamTarget=FindNearestSurvivor(); camActive=S.CamTarget~=nil
        end})
        TbKiller:Button({Title=Tr("clear_lock"),Callback=function() camActive=false; S.CamTarget=nil end})
    end

    do -- FARM
        local R=uiRefs
        TbFarm:Button({Title=Tr("complete_all"),Callback=function() N("Auto Farm","Starting...",3,"wheat"); task.spawn(CompleteAllGenerators) end})
        TbFarm:Divider()
        R.AutoFarm=TbFarm:Toggle({Title=Tr("auto_farm"),Value=S.AutoFarm,Callback=function(v) S.AutoFarm=v; SetAutoFarm(v) end})
    end

    do -- CONFIG
        local cfgInput=""; local selCfg=nil; local cfgDD=nil
        TbConfig:Input({Title=Tr("cfg_name"),Placeholder="v1",Callback=function(t) if t and t~="" then cfgInput=t end end})
        TbConfig:Button({Title=Tr("cfg_create"),Callback=function()
            if cfgInput=="" then return end
            if SaveCfg(cfgInput) then local l=ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end end
        end})
        local iL=ListCfgs()
        cfgDD=TbConfig:Dropdown({Title=Tr("cfg_select"),Values=#iL>0 and iL or {"(none)"},Value=iL[1] or nil,Multi=false,AllowNone=true,Callback=function(v) selCfg=v end})
        if #iL>0 then selCfg=iL[1] end
        TbConfig:Button({Title=Tr("cfg_load"),Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            local n=LoadCfg(selCfg); if not n then return end
            SyncUI(); ConnectStamina(); SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap)
            SetAutoEscape(S.AutoEscape); SetBarricade(S.AutoBarricade)
            SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
            if S.AllowJump then SetAllowJump(true) end; if S.AutoRun then SetAutoRun(true) end
            if S.DeleteDoor then SetDeleteDoor(true) end; if S.SkipCutscene then SetSkipCutscene(true) end
            if S.AutoPhase then SetAutoPhase(true) end
            if S.InstantGen then StartInstantGen() end; if S.FullBright then SetFullBright(true) end
            if S.NoBlind then SetNoBlind(true) end; if S.HideGenGui then SetHideGenGui(true) end
            if S.InstantPrompt then SetInstantPrompt(true) end; if S.AutoFarm then SetAutoFarm(true) end
            if S.AutoSwing then SetAutoSwing(true) end; if S.AutoParry then SetAutoParry(true) end
            if S.AutoShakeWire then SetAutoShakeWire(true) end; if S.FPSBooster then SetFPSBooster(true) end
            if S.FovValue~=70 then SetFOV(S.FovValue) end; ConnectAntiDie()
        end})
        TbConfig:Divider()
        local cA=GetAutoLoad()
        TbConfig:Toggle({Title=Tr("cfg_auto"),Value=cA~=nil,Callback=function(v)
            if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
        end})
        TbConfig:Button({Title=Tr("cfg_delete"),Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            pcall(function() if delfile then delfile(CFG_FOLDER.."/"..selCfg..".json") end end)
            local l=ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end; selCfg=nil
        end})
    end

    do -- SETTINGS
        local R=uiRefs
        TbSettings:Slider({Title=Tr("ui_scale"),Step=0.05,Value={Min=0.7,Max=1.5,Default=1.0},Callback=function(v) ApplyScale(v) end})
        TbSettings:Slider({Title=Tr("ui_alpha"),Step=0.05,Value={Min=0,Max=0.9,Default=0},Callback=function(v) ApplyAlpha(v) end})
        TbSettings:Divider()
        R.AntiAFK=TbSettings:Toggle({Title=Tr("anti_afk"),Value=S.AntiAFK,Callback=function(v) S.AntiAFK=v; SetAntiAFK(v) end})
        R.FPSBooster=TbSettings:Toggle({Title=Tr("fps_boost"),Value=S.FPSBooster,Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end})
        TbSettings:Keybind({Title=Tr("toggle_ui"),Value="RightControl",Callback=function(k) pcall(function() Window:SetToggleKey(Enum.KeyCode[k]) end) end})
        TbSettings:Divider()
        TbSettings:Button({Title=Tr("lang_btn"),Callback=function()
            local nl=LANG=="en" and "ar" or "en"; LANG=nl; N("Language","Switched - re-execute",4,"globe")
        end})
    end

    -- INIT
    ConnectStamina(); SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap)
    SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
    if S.AllowJump then SetAllowJump(true) end; if S.AutoRun then SetAutoRun(true) end
    if S.DeleteDoor then SetDeleteDoor(true) end; if S.SkipCutscene then SetSkipCutscene(true) end
    if S.AutoPhase then SetAutoPhase(true) end
    if S.InstantGen then StartInstantGen() end; if S.FullBright then SetFullBright(true) end
    if S.NoBlind then SetNoBlind(true) end; if S.HideGenGui then SetHideGenGui(true) end
    if S.InstantPrompt then SetInstantPrompt(true) end; if S.AutoBarricade then SetBarricade(true) end
    if S.AutoEscape then SetAutoEscape(true) end; if S.AutoFarm then SetAutoFarm(true) end
    if S.AutoSwing then SetAutoSwing(true) end; if S.AutoParry then SetAutoParry(true) end
    if S.AutoShakeWire then SetAutoShakeWire(true) end; if S.FPSBooster then SetFPSBooster(true) end
    if S.FovValue~=70 then SetFOV(S.FovValue) end
    task.delay(0.9,function() ApplyScale(S.UIScale); ApplyAlpha(S.UIAlpha) end)

    LP.CharacterAdded:Connect(function()
        task.wait(1); RefreshChar(); ConnectStamina(); ConnectAntiDie()
        if S.NoClip then SetNoClip(true) end; if S.AllowJump then SetAllowJump(true) end
        if S.AutoRun then SetAutoRun(true) end; if S.AutoSwing then SetAutoSwing(true) end
        if S.AutoParry then SetAutoParry(true) end; if S.AntiTrap then SetAntiTrap(true) end
        SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
        if S.AutoPhase then SetAutoPhase(true) end
        task.wait(1)
        pcall(function()
            local pf=workspace:FindFirstChild("PLAYERS"); local kf=pf and pf:FindFirstChild("KILLER")
            if kf then for _,m in ipairs(kf:GetChildren()) do HookKillerAnim(m) end end
        end)
    end)
    ConnectAntiDie()
    task.wait(1.5); N("Phantom Hub  v7.6","By 7k.u  -  Ready",5,"moon")
end

