-- Config system (saves all current settings)
local function ListCfgs()
	if not listfiles then return {} end
	local r={}; local ok,fs=pcall(listfiles,CFG_FOLDER); if not ok then return r end
	for _,f in ipairs(fs) do local n=f:match("([^/\\]+)%.json$"); if n and n~="_autoload" then table.insert(r,n) end end
	return r
end
local function SaveCfg(name)
	local data = {LANG=LANG}
	for k,v in pairs(S) do
		if type(v) == "table" then
			-- skip complex tables
		elseif type(v) == "Color3" then
			data[k] = {v.R, v.G, v.B}
		else
			data[k] = v
		end
	end
	pcall(writefile, CFG_FOLDER.."/"..name..".json", HttpService:JSONEncode(data))
end
local function LoadCfg(name)
	local path = CFG_FOLDER.."/"..name..".json"
	if not isfile or not isfile(path) then return nil end
	local ok,content = pcall(readfile, path)
	if not ok then return nil end
	local data = HttpService:JSONDecode(content)
	if not data then return nil end
	for k,v in pairs(data) do
		if S[k] ~= nil then
			if type(v) == "table" and type(S[k]) == "Color3" then
				S[k] = Color3.new(v[1], v[2], v[3])
			elseif type(v) == "table" and type(S[k]) == "table" then
				-- skip
			else
				S[k] = v
			end
		end
	end
	LANG = data.LANG or LANG
	return name
end
local function GetAutoLoad()
	if not isfile or not isfile(AUTO_FILE) then return nil end
	local ok,v = pcall(readfile, AUTO_FILE)
	return (ok and v and v~="") and v or nil
end
local function SetAutoLoad(n) pcall(writefile, AUTO_FILE, n or "") end

