-- AUTO ESCAPE (FIX: proper check with alive verification + cooldown)
local escapeConn = nil; local lastEscapeAt = 0
local function SetAutoEscape(on)
    if escapeConn then escapeConn:Disconnect(); escapeConn = nil end; if not on then return end
    escapeConn = RunService.Heartbeat:Connect(function()
        if not S.AutoEscape then return end
        if (tick() - lastEscapeAt) < 2 then return end -- 2s cooldown to avoid spam
        pcall(function()
            if not LPChar then return end
            -- Check CAN_ESCAPE
            local gF = workspace:FindFirstChild("GAME")
            local cE = gF and gF:FindFirstChild("CAN_ESCAPE")
            if not cE or not cE.Value then return end
            -- Check player is in ALIVE folder
            local pf = workspace:FindFirstChild("PLAYERS"); local af = pf and pf:FindFirstChild("ALIVE")
            if not af or not af:FindFirstChild(LP.Name) then return end
            -- Check there's an open escape
            local mapF = workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP")
            if not mapF then return end
            local ef = mapF:FindFirstChild("Escapes"); if not ef then return end
            for _, v in ipairs(ef:GetChildren()) do
                local isEnabled = v:GetAttribute("Enabled")
                -- If attribute is nil, treat as enabled; if false, skip
                if isEnabled == false then continue end
                local cf = v:IsA("BasePart") and v.CFrame
                    or (v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.CFrame)
                if not cf then continue end
                local hrp = LPChar:FindFirstChild("HumanoidRootPart"); if not hrp then return end
                lastEscapeAt = tick()
                hrp.CFrame = cf + Vector3.new(0, 3, 0)
                return
            end
        end)
    end)
end

