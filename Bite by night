local function UpdateFly()
    local c = LP.Character
    if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    local h = c:FindFirstChildOfClass("Humanoid")
    if not r or not h then return end
    if CFG.FLY_Enabled then
        h.PlatformStand = true
        if not State.FlyBV then
            State.FlyBV = Instance.new("BodyVelocity")
            State.FlyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            State.FlyBV.Velocity = Vector3.zero
            State.FlyBV.Parent = r
        end
        if not State.FlyBG then
            State.FlyBG = Instance.new("BodyGyro")
            State.FlyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            State.FlyBG.P = 9e4
            State.FlyBG.Parent = r
        end
        local cam = Camera
        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
        if dir.Magnitude > 0 then dir = dir.Unit * CFG.FLY_Speed end
        State.FlyBV.Velocity = dir
        State.FlyBG.CFrame = cam.CFrame
    else
        if State.FlyBV then State.FlyBV:Destroy(); State.FlyBV = nil end
        if State.FlyBG then State.FlyBG:Destroy(); State.FlyBG = nil end
        if h then h.PlatformStand = false end
    end
end

