-- CAM LOCK (بقية الكود)
local camActive=false
function FindNearestSurvivor()
    local char = LP.Character; local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    local pf = workspace:FindFirstChild("PLAYERS"); local af = pf and pf:FindFirstChild("ALIVE")
    if not af then return nil end
    local best, bestDist = nil, 999
    for _, m in ipairs(af:GetChildren()) do if m.Name ~= LP.Name then
        local hrp = m:FindFirstChild("HumanoidRootPart")
        if hrp then local d = (hrp.Position - myRoot.Position).Magnitude
            if d < bestDist then bestDist = d; best = m end end
    end end
    return best
end

pcall(function()
    local warpReq=RS:WaitForChild("Modules",8):FindFirstChild("Warp"):FindFirstChild("Index"):FindFirstChild("Event"):FindFirstChild("Request")
    if not warpReq then return end
    local oldNC
    oldNC=hookmetamethod(game,"__namecall",function(self,...)
        local method=getnamecallmethod()
        if method~="FireServer" or self~=warpReq then return oldNC(self,...) end
        local args={...}; local a1=args[1]
        if type(a1)=="buffer" and buffer.len(a1)>=1 then
            local function findId(t,depth)
                if depth>5 or type(t)~="table" then return end
                for _,v in ipairs(t) do
                    if type(v)=="string" then
                        if v=="806604" and S.CamRotten then
                            S.CamTarget = FindNearestSurvivor()
                            if S.CamTarget then camActive=true end
                        elseif v=="892282" and S.CamRotten then camActive=false; S.CamTarget=nil
                        elseif (v=="376936" or v=="752856") and S.CamRotten and not camActive then
                            task.spawn(function() local t=FindNearestSurvivor() if t then S.CamTarget=t; camActive=true end end)
                        elseif (v=="602035" or v=="563043") and S.CamRotten then camActive=false; S.CamTarget=nil
                        end
                    elseif type(v)=="table" then findId(v,depth+1) end
                end
            end
            local a3=args[3]; local a2=args[2]
            if type(a3)=="table" then findId(a3,1) elseif type(a2)=="table" then findId(a2,1) end
        end
        return oldNC(self,...)
    end)
end)

local function IsFacingPlayer(km)
    local c=LP.Character; local r2=c and c:FindFirstChild("HumanoidRootPart"); if not r2 then return true end
    local r=km:FindFirstChild("HumanoidRootPart"); if not r then return true end
    return r.CFrame.LookVector:Dot((r2.Position-r.Position).Unit)>0.4
end
local function GetKillerModel()
    local pf=workspace:FindFirstChild("PLAYERS"); local kf=pf and pf:FindFirstChild("KILLER"); if not kf then return nil end
    return kf:FindFirstChildOfClass("Model")
end
local hookedKillers={}
function HookKillerAnim(km)
    if hookedKillers[km] then return end; hookedKillers[km]=true
    local hum=km:FindFirstChildOfClass("Humanoid"); if not hum then return end
    hum.AnimationPlayed:Connect(function(track)
        local n=(track.Name or ""):lower(); local aid=(track.Animation and track.Animation.AnimationId or ""):lower()
        if S.CamDoppel then
            local GKW={"grab","reach","lunge","snatch","extend","pull","doppel","mimic","copy","clone","teleport","leap","dash","rush"}
            for _,kw in ipairs(GKW) do if n:find(kw,1,true) or aid:find(kw,1,true) then
                if IsFacingPlayer(km) and not camActive then camActive=true; S.CamTarget=km:FindFirstChild("HumanoidRootPart") end; break end end
        end
    end)
    km.AncestryChanged:Connect(function() if not km.Parent then hookedKillers[km]=nil end end)
end
