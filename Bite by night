local SCConn = nil

local function PressSpace()
    SafeCall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
        task.wait(0.01)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
    end)
end

local function InZone(line, goal)
    local lr = line.Rotation % 360
    local gr = goal.Rotation % 360
    local gs = (gr + 104) % 360
    local ge = (gr + 114) % 360
    if gs > ge then return lr >= gs or lr <= ge end
    return lr >= gs and lr <= ge
end

local function StartSC()
    if SCConn then return end
    SafeCall(function()
        local gui = PG:WaitForChild("SkillCheckPromptGui", 2)
        local check = gui:WaitForChild("Check")
        local line = check:WaitForChild("Line")
        local goal = check:WaitForChild("Goal")
        SCConn = RunService.Heartbeat:Connect(function()
            if not CFG.AUTO_SkillCheck or GetRole() ~= "Survivor" then
                SCConn:Disconnect(); SCConn = nil; return
            end
            if check.Visible and InZone(line, goal) then
                PressSpace()
                SCConn:Disconnect(); SCConn = nil
            end
        end)
    end)
end

PG.ChildAdded:Connect(function(ch)
    if ch.Name == "SkillCheckPromptGui" and CFG.AUTO_SkillCheck then task.wait(0.1); StartSC() end
end)

