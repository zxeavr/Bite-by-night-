    local phaseStepped=nil
    local function SetAutoPhase(on)
        S.AutoPhase = on
        if phaseStepped then phaseStepped:Disconnect(); phaseStepped=nil end
        if not on then return end
        local canPhase = true
        phaseStepped = RunService.Heartbeat:Connect(function()
            if not S.AutoPhase then return end
            local char = LP.Character; if not char then return end
            local maskClient = char:FindFirstChild("MaskClient")
            if not maskClient then return end
            local lungeEvent = maskClient:FindFirstChild("ActiveLunge")
            if not lungeEvent then return end
            local checkPartsModule = maskClient:FindFirstChild("CheckParts")
            if not checkPartsModule then return end
            local ok, checkParts = pcall(require, checkPartsModule)
            if not ok or type(checkParts) ~= "table" then return end
            local map = workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP")
            local other = map and map:FindFirstChild("Other")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not other or not hrp then return end
            local nearest, nearestDist = nil, math.huge
            for _, part in ipairs(other:GetDescendants()) do
                if part:IsA("BasePart") then
                    local lower = part.Name:lower()
                    for _, v in ipairs(checkParts) do
                        if type(v) == "string" and lower:find(v:lower(), nil, true) then
                            local dist = (part.Position - hrp.Position).Magnitude
                            if dist < nearestDist then
                                nearestDist = dist; nearest = part
                            end
                            break
                        end
                    end
                end
            end
            if nearest and nearestDist <= 10 and canPhase then
                canPhase = false
                for _, conn in ipairs(getconnections(lungeEvent.OnClientEvent)) do
                    conn.Function()
                end
                task.delay(0.3, function() canPhase = true end)
            end
        end)
    end

