local function FindNearestAlive()
    local vp = Camera.ViewportSize
    local center = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
    local best, bestD = nil, S.CamFOV + 1
    local pf = workspace:FindFirstChild("PLAYERS")
    local af = pf and pf:FindFirstChild("ALIVE"); if not af then return nil end
    for _, m in ipairs(af:GetChildren()) do
        if m.Name == LP.Name then continue end
        local h = m:FindFirstChild("HumanoidRootPart"); if not h then continue end
        local sp, vis = Camera:WorldToViewportPoint(h.Position)
        if not vis then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < bestD then bestD = d; best = h end
    end
    return best
end

-- AIMBOT: smooth tracking via CameraType.Scriptable + Lerp
local camActive = false
local function StopAimbot()
    camActive = false; S.CamTarget = nil
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
end
local function StartAimbotOnTrack(track)
    local target = FindNearestAlive(); if not target then return end
    S.CamTarget = target; camActive = true
    Camera.CameraType = Enum.CameraType.Scriptable
    local conn; conn = track.Stopped:Connect(function()
        conn:Disconnect()
        if S.CamTarget == target then StopAimbot() end
    end)
end

RunService.RenderStepped:Connect(function()
    if not camActive then return end
    local anyOn = S.CamRotten or S.CamM1 or S.CamDoppelPull or S.CamDoppelStab or S.CamMimicGrab or S.CamMimicJump
    if not anyOn then StopAimbot(); return end
    if not S.CamTarget or not S.CamTarget.Parent then StopAimbot(); return end
    Camera.CameraType = Enum.CameraType.Scriptable
    local targetCF = CFrame.new(Camera.CFrame.Position, S.CamTarget.Position + Vector3.new(0, 2.5, 0))
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, 0.3)
end)

local hookedKillers = {}
local function HookKillerAnim(km)
    if not km or hookedKillers[km] then return end; hookedKillers[km] = true
    local hum = km:FindFirstChildOfClass("Humanoid"); if not hum then return end
    hum.AnimationPlayed:Connect(function(track)
        if not track or not track.Animation then return end
        local cfg = ANIM_CFG[track.Animation.AnimationId]; if not cfg then return end
        if not S[cfg.feature] then return end
        if cfg.isStop then StopAimbot() else StartAimbotOnTrack(track) end
    end)
    km.AncestryChanged:Connect(function() if not km.Parent then hookedKillers[km] = nil end end)
end
