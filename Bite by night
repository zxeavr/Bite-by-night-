local function FireInput(a1,a2)
    if cachedWarpInput then
        local ok=pcall(function() cachedWarpInput:Fire(a1,a2) end); if ok then return true end
    end
    -- Fallback: try to get again
    pcall(function()
        local warp=require(RS:WaitForChild("Modules",3):WaitForChild("Warp",3))
        if warp and warp.Client then
            local inp=warp.Client("Input")
            if inp then cachedWarpInput=inp; inp:Fire(a1,a2); return true end
        end
    end)
    return false
end

