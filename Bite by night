--[[
  Script Updating GUI
  يعرض رسالة "Script is updating..." ويختفي بعد فترة
--]]

local player = game:GetService("Players").LocalPlayer
local TweenService = game:GetService("TweenService")

-- إنشاء الشاشة الرئيسية
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "UpdateNotification"
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- محاولة وضعها في CoreGui (أو PlayerGui كبديل)
local success = pcall(function()
    screenGui.Parent = game:GetService("CoreGui")
end)
if not success then
    screenGui.Parent = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui")
end

-- إطار رئيسي شبه شفاف
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(1, 0, 1, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
mainFrame.BackgroundTransparency = 0.5
mainFrame.BorderSizePixel = 0
mainFrame.ZIndex = 1
mainFrame.Parent = screenGui

-- بطاقة مركزية
local card = Instance.new("Frame")
card.Size = UDim2.new(0, 300, 0, 150)
card.Position = UDim2.new(0.5, -150, 0.5, -75)
card.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
card.BorderSizePixel = 0
card.ZIndex = 2
card.Parent = screenGui

local cardCorner = Instance.new("UICorner")
cardCorner.CornerRadius = UDim.new(0, 12)
cardCorner.Parent = card

local cardStroke = Instance.new("UIStroke")
cardStroke.Color = Color3.fromRGB(80, 120, 255)
cardStroke.Thickness = 1.5
cardStroke.Transparency = 0.3
cardStroke.Parent = card

-- نص التحديث
local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 30)
titleLabel.Position = UDim2.new(0, 0, 0.2, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "⏳ Script is updating..."
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.Font = Enum.Font.GothamBold
titleLabel.TextSize = 20
titleLabel.ZIndex = 3
titleLabel.Parent = card

local descLabel = Instance.new("TextLabel")
descLabel.Size = UDim2.new(1, 0, 0, 20)
descLabel.Position = UDim2.new(0, 0, 0.45, 0)
descLabel.BackgroundTransparency = 1
descLabel.Text = "Please wait..."
descLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
descLabel.Font = Enum.Font.Gotham
descLabel.TextSize = 14
descLabel.ZIndex = 3
descLabel.Parent = card

-- شريط تقدم غير محدد (Spinner)
local spinner = Instance.new("Frame")
spinner.Size = UDim2.new(0, 200, 0, 4)
spinner.Position = UDim2.new(0.5, -100, 0.7, 0)
spinner.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
spinner.BorderSizePixel = 0
spinner.ZIndex = 3
spinner.Parent = card

local spinnerCorner = Instance.new("UICorner")
spinnerCorner.CornerRadius = UDim.new(1, 0)
spinnerCorner.Parent = spinner

local bar = Instance.new("Frame")
bar.Size = UDim2.new(0, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(80, 120, 255)
bar.BorderSizePixel = 0
bar.ZIndex = 4
bar.Parent = spinner

local barCorner = Instance.new("UICorner")
barCorner.CornerRadius = UDim.new(1, 0)
barCorner.Parent = bar

-- حركة وهمية للشريط
local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1)
local tween = TweenService:Create(bar, tweenInfo, { Size = UDim2.new(1, 0, 1, 0) })
tween:Play()

-- اختفاء تلقائي بعد 5 ثواني
task.delay(5, function()
    -- تأثير تلاشي
    local fadeOut = TweenService:Create(mainFrame, TweenInfo.new(0.5), { BackgroundTransparency = 1 })
    local cardOut = TweenService:Create(card, TweenInfo.new(0.5), { Position = UDim2.new(0.5, -150, 1.2, 0) })
    fadeOut:Play()
    cardOut:Play()
    task.wait(0.5)
    screenGui:Destroy()
end)
