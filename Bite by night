function PlayerMods:SetSpeed(state)
    Config.Player.SpeedEnabled = state
    if self.speedConn then pcall(function() self.speedConn:Disconnect() end); self.speedConn = nil end
    if not state then
        pcall(function() if LPChar then LPChar:SetAttribute("RunSpeed", 16) end end)
        return
    end
    self.speedConn = RunService.Heartbeat:Connect(function()
        pcall(function() if LPChar then LPChar:SetAttribute("RunSpeed", Config.Player.SpeedValue) end end)
    end)
end

function PlayerMods:SetWalk(state)
    Config.Player.WalkEnabled = state
    if not state then
        pcall(function() if LPChar then LPChar:SetAttribute("WalkSpeed", 16) end end)
        return
    end
    -- WalkSpeed is handled via attribute in many games
    self.walkConn = RunService.Heartbeat:Connect(function()
        pcall(function() if LPChar then LPChar:SetAttribute("WalkSpeed", Config.Player.WalkValue) end end)
    end)
end

function PlayerMods:SetNoclip(state)
    Config.Player.Noclip = state
    if self.noclipConn then pcall(function() self.noclipConn:Disconnect() end); self.noclipConn = nil end
    if not state then
        pcall(function()
            if not LPChar then return end
            for _, p in ipairs(LPChar:GetDescendants()) do
                if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                    p.CanCollide = true
                end
            end
        end)
        return
    end
    self.noclipConn = RunService.Stepped:Connect(function()
        pcall(function()
            if not LPChar then return end
            for _, p in ipairs(LPChar:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end)
    end)
end

function PlayerMods:SetJump(state)
    Config.Player.JumpEnabled = state
    if self.jumpConn then pcall(function() self.jumpConn:Disconnect() end); self.jumpConn = nil end
    if not state then
        pcall(function() if LPHum then LPHum.JumpHeight = 0 end end)
        return
    end
    self.jumpConn = RunService.Heartbeat:Connect(function()
        pcall(function() if LPHum then LPHum.JumpHeight = Config.Player.JumpValue / 10 end end)
    end)
end

function PlayerMods:SetStamina(state)
    Config.Player.InfStamina = state
    if self.staminaConn then pcall(function() self.staminaConn:Disconnect() end); self.staminaConn = nil end
    if not state then return end
    self.staminaConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if not LPChar then return end
            local max = LPChar:GetAttribute("MaxStamina") or 100
            if (LPChar:GetAttribute("Stamina") or max) < max then
                LPChar:SetAttribute("Stamina", max)
            end
        end)
    end)
end

