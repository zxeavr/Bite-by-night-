        local tIP=TbMain:Toggle({Title=Tr("instant_prompt"),Value=S.InstantPrompt,Callback=function(v) S.InstantPrompt=v; SetInstantPrompt(v) end}); R.InstantPrompt=tIP
        TbMain:Divider()
        local tIG=TbMain:Toggle({Title=Tr("instant_gen"),Value=S.InstantGen,Callback=function(v) S.InstantGen=v; if v then StartInstantGen() else StopInstantGen() end end}); R.InstantGen=tIG
        TbMain:Slider({Title=Tr("gen_speed"),Step=0.1,Value={Min=0.1,Max=3,Default=1.0},Callback=function(v) S.GenDelay=v end})
        TbMain:Button({Title=Tr("gen_now"),Callback=function() InstantGenNow() end})
        TbMain:Divider()
        local tAP=TbMain:Toggle({Title=Tr("auto_parry"),Value=S.AutoParry,Callback=function(v) S.AutoParry=v; SetAutoParry(v) end}); R.AutoParry=tAP
        TbMain:Slider({Title=Tr("parry_range_basic"),Step=1,Value={Min=10,Max=50,Default=30},Callback=function(v) S.ParryRangeBasic=v end})
        TbMain:Slider({Title=Tr("parry_range_pull"),Step=1,Value={Min=10,Max=60,Default=50},Callback=function(v) S.ParryRangePull=v end})
        local tSPR=TbMain:Toggle({Title=Tr("show_parry"),Value=S.ShowParry,Callback=function(v) S.ShowParry=v end}); R.ShowParry=tSPR
        TbMain:Divider()
        local tASW=TbMain:Toggle({Title=Tr("auto_swing"),Value=S.AutoSwing,Callback=function(v) S.AutoSwing=v; SetAutoSwing(v) end}); R.AutoSwing=tASW
        TbMain:Slider({Title=Tr("swing_range"),Step=1,Value={Min=5,Max=25,Default=12},Callback=function(v) S.SwingRange=v end})
        TbMain:Divider()
        local tWSH=TbMain:Toggle({Title=Tr("wire_shake"),Value=S.AutoShakeWire,Callback=function(v) S.AutoShakeWire=v; SetAutoShakeWire(v) end}); R.AutoShakeWire=tWSH
        TbMain:Slider({Title=Tr("shake_speed"),Step=0.1,Value={Min=0.1,Max=5,Default=0.1},Callback=function(v) S.ShakeSpeed=v end})
    end

    do  -- VISUAL
        local R=uiRefs
        TbVisual:Dropdown({Title=Tr("esp_type"),Values={"Highlight","Chams","Name"},Value=S.ESPMode,Multi=false,Callback=function(v) S.ESPMode=v end})
        local tEH=TbVisual:Toggle({Title=Tr("health_esp"),Value=S.ESPHealth,Callback=function(v) S.ESPHealth=v end}); R.ESPHealth=tEH
        TbVisual:Divider()
        local ROWS={{"Killer","Killer"},{"Survivor","Survivor"},{"Generator","Generator"},{"Battery","Battery"},{"Fuse","Fuse"},{"Trap","Trap"},{"WireEye","Wire Eye"}}
        for _,row in ipairs(ROWS) do
            local key,label=row[1],row[2]; local cfg=S.T[key]
            if cfg then
                local tOn=TbVisual:Toggle({Title=Tr("esp_on").." "..label,Value=cfg.On,Callback=function(v) cfg.On=v end}); R["T."..key..".On"]=tOn
                TbVisual:Colorpicker({Title=label.." "..Tr("esp_color"),Default=cfg.Color,Callback=function(c) cfg.Color=c end})
            end
        end
        TbVisual:Divider()
        local tFB=TbVisual:Toggle({Title=Tr("full_bright"),Value=S.FullBright,Callback=function(v) S.FullBright=v; SetFullBright(v) end}); R.FullBright=tFB
        local tNF=TbVisual:Toggle({Title=Tr("no_fog"),Value=S.NoFog,Callback=function(v) S.NoFog=v end}); R.NoFog=tNF
        local tNS=TbVisual:Toggle({Title=Tr("no_shadow"),Value=S.NoShadow,Callback=function(v) S.NoShadow=v end}); R.NoShadow=tNS
        TbVisual:Slider({Title=Tr("fov_ctrl"),Step=1,Value={Min=10,Max=100,Default=70},Callback=function(v) SetFOV(v) end})
        TbVisual:Divider()
        local tHG=TbVisual:Toggle({Title=Tr("hide_gen_gui"),Value=S.HideGenGui,Callback=function(v) S.HideGenGui=v; SetHideGenGui(v) end}); R.HideGenGui=tHG
    end

    do  -- COMBAT
        local R=uiRefs
        local tCR=TbCombat:Toggle({Title=Tr("cam_rotten"),Value=S.CamRotten,Callback=function(v) S.CamRotten=v; if not v then StopCamLock() end end}); R.CamRotten=tCR
        local tCD=TbCombat:Toggle({Title=Tr("cam_doppel"),Value=S.CamDoppel,Callback=function(v) S.CamDoppel=v end}); R.CamDoppel=tCD
        local tSF=TbCombat:Toggle({Title=Tr("show_fov"),Value=S.ShowFOV,Callback=function(v) S.ShowFOV=v end}); R.ShowFOV=tSF
        TbCombat:Colorpicker({Title=Tr("fov_color"),Default=S.FovColor,Callback=function(c)
            S.FovColor=c; local stroke=fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if stroke then stroke.Color=c end
        end})
        TbCombat:Slider({Title=Tr("fov_radius"),Step=5,Value={Min=30,Max=300,Default=120},Callback=function(v) S.CamFOV=v end})
        TbCombat:Button({Title=Tr("lock_near"),Callback=function() camTarget=FindTarget(); camActive=camTarget~=nil; camEndTime=tick()+5 end})
        TbCombat:Button({Title=Tr("clear_lock"),Callback=function() StopCamLock() end})
    end

    do  -- FARM
        local R=uiRefs
        local tAF=TbFarm:Toggle({Title=Tr("auto_farm"),Value=S.AutoFarm,Callback=function(v) S.AutoFarm=v; SetAutoFarm(v) end}); R.AutoFarm=tAF
    end

    do  -- CONFIG
        local cfgInput=""; local selCfg=nil; local cfgDD=nil
        TbConfig:Input({Title=Tr("cfg_name"),Placeholder="v1",Callback=function(t) if t and t~="" then cfgInput=t end end})
        TbConfig:Button({Title=Tr("cfg_create"),Callback=function()
            if cfgInput=="" then return end
            if SaveCfg(cfgInput) then local list=ListCfgs(); if cfgDD then cfgDD:Refresh(#list>0 and list or {"(none)"}) end end
        end})
        local initList=ListCfgs()
        cfgDD=TbConfig:Dropdown({Title=Tr("cfg_select"),Values=#initList>0 and initList or {"(none)"},Value=initList[1] or nil,Multi=false,AllowNone=true,Callback=function(v) selCfg=v end})
        if #initList>0 then selCfg=initList[1] end
        TbConfig:Button({Title=Tr("cfg_load"),Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            local n=LoadCfg(selCfg)
            if n then
                SyncUI(); ConnectStamina(); SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap)
                SetAutoEscape(S.AutoEscape); SetBarricade(S.AutoBarricade)
                if S.AllowJump    then SetAllowJump(true)    end; if S.AutoRun      then SetAutoRun(true)       end
                if S.BypassSlow   then SetBypassSlow(true)   end; if S.InstantGen   then StartInstantGen()      end
                if S.FullBright   then SetFullBright(true)   end; if S.HideGenGui   then SetHideGenGui(true)    end
                if S.InstantPrompt then SetInstantPrompt(true) end; if S.AutoFarm     then SetAutoFarm(true)      end
                if S.AutoSwing    then SetAutoSwing(true)    end; if S.AutoParry     then SetAutoParry(true)     end
                if S.AutoShakeWire then SetAutoShakeWire(true) end; if S.FPSBooster   then SetFPSBooster(true)   end
                if S.FovValue~=70 then SetFOV(S.FovValue)   end; ConnectAntiDie()
            end
        end})
        TbConfig:Divider()
        local curAuto=GetAutoLoad()
        TbConfig:Toggle({Title=Tr("cfg_auto"),Value=curAuto~=nil,Callback=function(v)
            if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
        end})
        TbConfig:Button({Title=Tr("cfg_delete"),Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            pcall(function() if delfile then delfile(CFG_FOLDER.."/"..selCfg..".json") end end)
            local list=ListCfgs(); if cfgDD then cfgDD:Refresh(#list>0 and list or {"(none)"}) end; selCfg=nil
        end})
    end

    do  -- SETTINGS
        local R=uiRefs
        TbSettings:Slider({Title=Tr("ui_scale"),Step=0.05,Value={Min=0.7,Max=1.5,Default=1.1},Callback=function(v) ApplyScale(v) end})
        TbSettings:Slider({Title=Tr("ui_alpha"),Step=0.05,Value={Min=0,Max=0.9,Default=0},Callback=function(v) ApplyAlpha(v) end})
        TbSettings:Divider()
        local tAFK=TbSettings:Toggle({Title=Tr("anti_afk"),Value=S.AntiAFK,Callback=function(v) S.AntiAFK=v; SetAntiAFK(v) end}); R.AntiAFK=tAFK
        local tFPS=TbSettings:Toggle({Title=Tr("fps_boost"),Value=S.FPSBooster,Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end}); R.FPSBooster=tFPS
        TbSettings:Keybind({Title=Tr("toggle_ui"),Value="RightControl",Callback=function(k) pcall(function() Window:SetToggleKey(Enum.KeyCode[k]) end) end})
        TbSettings:Divider()
        TbSettings:Button({Title=Tr("lang_btn"),Callback=function()
            local nl=LANG=="en" and "ar" or "en"; LANG=nl; N("Language","Switched - re-execute",4,"globe")
        end})
    end

    -- Init
    ConnectStamina(); SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap)
    if S.AllowJump     then SetAllowJump(true)    end; if S.AutoRun       then SetAutoRun(true)       end
    if S.BypassSlow    then SetBypassSlow(true)   end; if S.InstantGen    then StartInstantGen()      end
    if S.FullBright    then SetFullBright(true)   end; if S.HideGenGui    then SetHideGenGui(true)    end
    if S.InstantPrompt then SetInstantPrompt(true) end; if S.AutoBarricade then SetBarricade(true)     end
    if S.AutoEscape    then SetAutoEscape(true)   end; if S.AutoFarm      then SetAutoFarm(true)      end
    if S.AutoSwing     then SetAutoSwing(true)    end; if S.AutoParry     then SetAutoParry(true)     end
    if S.AutoShakeWire then SetAutoShakeWire(true) end; if S.FPSBooster   then SetFPSBooster(true)    end
    if S.FovValue~=70  then SetFOV(S.FovValue)   end
    task.delay(0.9,function() ApplyScale(S.UIScale); ApplyAlpha(S.UIAlpha) end)

    LP.CharacterAdded:Connect(function()
        task.wait(1); RefreshChar(); ConnectStamina(); ConnectAntiDie()
        if S.NoClip        then SetNoClip(true)     end; if S.AllowJump     then SetAllowJump(true)  end
        if S.AutoRun       then SetAutoRun(true)    end; if S.BypassSlow    then SetBypassSlow(true) end
        if S.AutoSwing     then SetAutoSwing(true)  end; if S.AutoParry     then SetAutoParry(true)  end
        if S.AntiTrap      then SetAntiTrap(true)   end
    end)
    ConnectAntiDie()
    task.wait(1.5); N("Phantom Hub  v7.5","By 7k.u  -  Ready",5,"moon")
end

ShowLoadingScreen(function()
    ShowLangGUI(function()
        BuildWindow()
    end)
end)
