--  MAP SCANNING
-- ═══════════════════════════════════════════════════════════════════════
local function ScanMap()
    local map = workspace:FindFirstChild("Map")
    if not map then
        Cache.Generators = {}; Cache.Gates = {}; Cache.Hooks = {}; Cache.Pallets = {}; Cache.Windows = {}
        return
    end
    local gens, gates, hooks, pallets, windows = {}, {}, {}, {}, {}
    for _, obj in ipairs(map:GetDescendants()) do
        if obj:IsA("Model") then
            local part = obj:FindFirstChildWhichIsA("BasePart")
            if part then
                if obj.Name == "Generator" then table.insert(gens, {model = obj, part = part})
                elseif obj.Name == "Gate" then table.insert(gates, {model = obj, part = part})
                elseif obj.Name == "Hook" then table.insert(hooks, {model = obj, part = part})
                elseif obj.Name:lower():find("pallet") then table.insert(pallets, {model = obj, part = part})
                elseif obj.Name == "Window" then table.insert(windows, {model = obj, part = part})
                end
            end
        end
    end
    Cache.Generators = gens; Cache.Gates = gates; Cache.Hooks = hooks; Cache.Pallets = pallets; Cache.Windows = windows
    local root = GetRoot()
    if root and #hooks > 0 then
        local closest, best = nil, math.huge
        for _, h in ipairs(hooks) do
            if h.part then
                local d = (h.part.Position - root.Position).Magnitude
                if d < best then best = d; closest = h end
            end
        end
        Cache.ClosestHook = closest
    end
end

