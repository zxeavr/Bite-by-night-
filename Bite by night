-- ═══════════════════════════════════════════════════════════════════════
local ESP = {}

function ESP.Create(obj, color, label)
    if not obj or not obj.Parent then return nil end
    if obj:FindFirstChild("_VD_ESP") then return obj:FindFirstChild("_VD_ESP") end

    local folder = Instance.new("Folder")
    folder.Name = "_VD_ESP"
    folder.Parent = obj

    local hl = Instance.new("Highlight")
    hl.Name = "HL"
    hl.Adornee = obj
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.75
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = folder

    local rp = obj:IsA("Model") and (obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")) or obj
    if rp then
        local bb = Instance.new("BillboardGui")
        bb.Name = "BB"
        bb.AlwaysOnTop = true
        bb.Size = UDim2.fromOffset(130, 45)
        bb.StudsOffset = Vector3.new(0, 3.2, 0)
        bb.Adornee = rp
        bb.Parent = folder
        bb.LightInfluence = 0
        bb.MaxDistance = CFG.ESP_MaxDist

        local txt = Instance.new("TextLabel")
        txt.Size = UDim2.fromScale(1, 1)
        txt.BackgroundTransparency = 1
        txt.Text = label
        txt.TextColor3 = color
        txt.TextStrokeTransparency = 0
        txt.TextStrokeColor3 = Color3.new(0, 0, 0)
        txt.Font = Enum.Font.GothamBold
        txt.TextSize = 11
        txt.TextWrapped = true
        txt.Parent = bb
    end
    return folder
end

function ESP.Remove(obj)
    if not obj then return end
    local f = obj:FindFirstChild("_VD_ESP")
    if f then pcall(function() f:Destroy() end) end
end

function ESP.Clear()
    for _, obj in pairs(workspace:GetDescendants()) do
        local f = obj:FindFirstChild("_VD_ESP")
        if f then pcall(function() f:Destroy() end) end
    end
end

function ESP.Update(obj, newLabel, dist)
    local f = obj and obj:FindFirstChild("_VD_ESP")
    if not f then return end
    local bb = f:FindFirstChild("BB")
    if bb then
        local txt = bb:FindFirstChildOfClass("TextLabel")
        if txt then
            local text = newLabel or ""
            if dist and CFG.ESP_Distance then
                text = text .. "\n[" .. math.floor(dist) .. "m]"
            end
            txt.Text = text
        end
    end
end

function ESP.SetVis(obj, vis)
    local f = obj and obj:FindFirstChild("_VD_ESP")
    if f then
        local hl = f:FindFirstChild("HL")
        if hl then hl.Enabled = vis end
        local bb = f:FindFirstChild("BB")
        if bb then bb.Enabled = vis end
    end
end

