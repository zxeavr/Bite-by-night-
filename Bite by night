		if d.Lbl then d.Lbl.Visible=tcfg.On and (mode=="Name" or labelOverride~=nil) end
		if d.HpL then
			if showHP and S.ESPHealth then
				local hum=obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health>0 then
					local hp=math.floor(hum.Health+0.5); local mhp=math.max(math.floor(hum.MaxHealth+0.5),1)
