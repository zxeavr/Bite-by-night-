local function TeleportAway()
    if not CFG.AUTO_TeleAway or GetRole() == "Killer" then return end
    if tick() - State.LastTeleAway < 3 then return end
    local root = GetRoot()
    if not root then return end
    local kPos = nil; local kDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and IsKiller(p) and p.Character then
            local kr = p.Character:FindFirstChild("HumanoidRootPart")
            if kr then
                local d = (kr.Position - root.Position).Magnitude
                if d < kDist then kDist = d; kPos = kr.Position end
            end
        end
    end
    if kDist > CFG.AUTO_TeleAwayDist or not kPos then return end
    State.LastTeleAway = tick()
    local bestSpot, bestD = nil, 0
    for _, g in ipairs(Cache.Gates) do
        if g.part and kPos then
            local d = (g.part.Position - kPos).Magnitude
            if d > bestD then bestD = d; bestSpot = g.part.Position end
        end
    end
    if not bestSpot or bestD < 50 then
        for _, g in ipairs(Cache.Generators) do
            if g.part and kPos then
                local d = (g.part.Position - kPos).Magnitude
                if d > bestD then bestD = d; bestSpot = g.part.Position end
            end
        end
    end
    if not bestSpot and kPos then
        local dir = (root.Position - kPos).Unit
        bestSpot = root.Position + dir * 80
    end
    if bestSpot then
        for _, p in ipairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
        root.CFrame = CFrame.new(bestSpot + Vector3.new(0, 3, 0))
        task.delay(0.3, function()
            if LP.Character then
                for _, p in ipairs(LP.Character:GetDescendants()) do
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.CanCollide = true end
                end
            end
        end)
    end
end

