local function ProcessFolder(folder,key,label,maxDist)
    if not folder then return end
    for _,obj in ipairs(folder:GetChildren()) do
        if obj.Name==LP.Name then continue end
        if obj:IsA("Model") or obj:IsA("BasePart") then ApplyESP(obj,S.T[key],label,maxDist) end
        for _,sub in ipairs(obj:GetChildren()) do
            if (sub:IsA("Model") or sub:IsA("BasePart")) and sub.Name~=LP.Name then ApplyESP(sub,S.T[key],label,maxDist) end
        end
    end
end

