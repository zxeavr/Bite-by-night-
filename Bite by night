local espCache = {}
local function clearESP(model)
    if espCache[model] then
        pcall(function() espCache[model]:Destroy() end)
        espCache[model] = nil
    end
end

local function updateESP(model, color, label, on)
    if not model or not model.Parent or not on then clearESP(model); return end
    local mode = S.ESPMode
    if mode == "Highlight" or mode == "Chams" then
        local hl = espCache[model]
        if hl and hl:IsA("Highlight") then
            hl.FillColor = color; hl.OutlineColor = color
        else
            if hl then pcall(function() hl:Destroy() end) end
            hl = Instance.new("Highlight")
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillTransparency = mode == "Highlight" and 0.55 or 0.2
            hl.OutlineTransparency = 0.3
            hl.FillColor = color; hl.OutlineColor = color
            hl.Adornee = model; hl.Parent = model
            espCache[model] = hl
        end
    elseif mode == "Name" then
        local bb = espCache[model]
        if bb and bb:IsA("BillboardGui") and bb:FindFirstChild("NameTag") then
            bb.NameTag.Text = label or model.Name
            bb.NameTag.TextColor3 = color
        else
            if bb then pcall(function() bb:Destroy() end) end
            bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,200,0,20)
            bb.StudsOffset = Vector3.new(0,2.5,0); bb.Parent = model
            local txt = Instance.new("TextLabel", bb)
            txt.Name = "NameTag"; txt.Size = UDim2.new(1,0,1,0)
            txt.BackgroundTransparency = 1; txt.Font = Enum.Font.GothamBold
            txt.TextSize = 12; txt.TextColor3 = color
            txt.TextStrokeTransparency = 0.5
            txt.Text = label or model.Name
            espCache[model] = bb
        end
    elseif mode == "Dot" then
        local dot = espCache[model]
        if dot and dot:IsA("BillboardGui") and dot:FindFirstChild("Dot") then
            dot.Dot.BackgroundColor3 = color
        else
            if dot then pcall(function() dot:Destroy() end) end
            dot = Instance.new("BillboardGui")
            dot.AlwaysOnTop = true; dot.Size = UDim2.new(0,10,0,10)
            dot.StudsOffset = Vector3.new(0,2,0); dot.Parent = model
            local frame = Instance.new("Frame", dot)
            frame.Name = "Dot"; frame.Size = UDim2.new(1,0,1,0)
            frame.BackgroundColor3 = color; frame.BorderSizePixel = 0
            Instance.new("UICorner",frame).CornerRadius = UDim.new(1,0)
            espCache[model] = dot
        end
    end
end

local function processAllESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        local char = player.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end
        local isKiller = player.Team and player.Team.Name:lower() == "killer"
        local on = isKiller and S.KillerESP or S.SurvivorESP
        local color = isKiller and S.KillerColor or S.SurvivorColor
        updateESP(char, color, player.Name, on)
    end

    pcall(function()
        local map = workspace:FindFirstChild("Map")
        if not map then return end
        for _, obj in ipairs(map:GetDescendants()) do
            local cfgOn, cfgCol, label = nil, nil, nil
            if obj.Name == "Generator" then
                cfgOn, cfgCol, label = S.GeneratorESP, S.GeneratorColor, "Gen"
            elseif obj.Name == "Gate" then
                cfgOn, cfgCol, label = S.GateESP, S.GateColor, "Gate"
            elseif obj.Name == "Palletwrong" then
                cfgOn, cfgCol, label = S.PalletESP, S.PalletColor, "Pallet"
            elseif obj.Name == "Window" then
                cfgOn, cfgCol, label = S.WindowESP, S.WindowColor, "Window"
            elseif obj.Name == "Hook" then
                if obj:FindFirstChild("Model") then
                    for _, part in ipairs(obj.Model:GetDescendants()) do
                        if part:IsA("BasePart") then
                            updateESP(part, S.HookColor, "Hook", S.HookESP)
                        end
                    end
                end
                if obj:FindFirstChild("Cartoony Blood Puddle") then
                    updateESP(obj["Cartoony Blood Puddle"], S.HookColor, "Hook", S.HookESP)
                end
                continue
            end
            if cfgOn then updateESP(obj, cfgCol, label, cfgOn) end
        end
    end)
end

