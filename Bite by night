    -- CAM LOCK TAB
    do
        local R=uiRefs
        TbKiller:Paragraph({Title="Cam Lock System",Desc="Locks camera on nearest target when killer animation plays. Smooth continuous tracking."})
        TbKiller:Divider()
        R.CamLockRotten    =TbKiller:Toggle({Title="Cam Lock - Rotten Axe Charge",   Value=S.CamLockRotten,    Callback=function(v) S.CamLockRotten=v end})
        TbKiller:Divider()
        R.CamLockDoppelPull=TbKiller:Toggle({Title="Cam Lock - Doppelganger Pull",   Value=S.CamLockDoppelPull,Callback=function(v) S.CamLockDoppelPull=v end})
        R.CamLockDoppelStab=TbKiller:Toggle({Title="Cam Lock - Doppelganger Stab",   Value=S.CamLockDoppelStab,Callback=function(v) S.CamLockDoppelStab=v end})
        TbKiller:Divider()
        R.CamLockMimicGrab =TbKiller:Toggle({Title="Cam Lock - Mimic Grab",          Value=S.CamLockMimicGrab, Callback=function(v) S.CamLockMimicGrab=v end})
        R.CamLockMimicJump =TbKiller:Toggle({Title="Cam Lock - Mimic Jump",          Value=S.CamLockMimicJump, Callback=function(v) S.CamLockMimicJump=v end})
        TbKiller:Divider()
        R.CamLockM1        =TbKiller:Toggle({Title="Cam Lock - M1 All Killers",      Value=S.CamLockM1,        Callback=function(v) S.CamLockM1=v end})
        TbKiller:Divider()
        R.ShowFOV=TbKiller:Toggle({Title="Show FOV Circle",Value=S.ShowFOV,Callback=function(v) S.ShowFOV=v end})
        TbKiller:Colorpicker({Title="FOV Color",Default=S.FovColor,Callback=function(c)
            S.FovColor=c; local st=fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if st then st.Color=c end
        end})
        TbKiller:Slider({Title="FOV Radius",Step=5,Value={Min=30,Max=300,Default=120},Callback=function(v) S.CamFOV=v end})
        TbKiller:Slider({Title="FOV Transparency",Step=0.05,Value={Min=0,Max=0.95,Default=0},Callback=function(v)
            S.FovAlpha=v; local st=fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if st then st.Transparency=v end
        end})
        TbKiller:Button({Title="Lock Nearest Target",Callback=function()
            local t=FindBestTarget()
            if t then camLockTarget=t; camLockActive=true; Camera.CameraType=Enum.CameraType.Scriptable; N("Cam Lock","Locked on "..tostring(t.Parent and t.Parent.Name),3)
            else N("Cam Lock","No target in FOV",3) end
        end})
        TbKiller:Button({Title="Release Lock",Callback=function() CamLockStop(); N("Cam Lock","Released",2) end})
    end

    -- FARM
    do
        local R=uiRefs
        TbFarm:Dropdown({Title="Move Mode",Values={"TP","Tween"},Value=S.FarmMode,Multi=false,Callback=function(v) S.FarmMode=v end})
        TbFarm:Slider({Title="Move Speed",Step=5,Value={Min=10,Max=100,Default=30},Callback=function(v) S.FarmSpeed=v end})
        R.FarmUnderground=TbFarm:Toggle({Title="Underground Safe Mode (50 studs)",Value=S.FarmUnderground,Callback=function(v) S.FarmUnderground=v end})
        TbFarm:Divider()
        TbFarm:Button({Title="Complete All Generators Now",Callback=function() N("Farm","Starting...",3,"wheat"); task.spawn(CompleteAllGenerators) end})
        TbFarm:Divider()
        R.AutoFarm=TbFarm:Toggle({Title="Auto Farm (loop)",Value=S.AutoFarm,Callback=function(v) S.AutoFarm=v; SetAutoFarm(v) end})
    end

    -- CONFIG
    do
        local cfgInput=""; local selCfg=nil; local cfgDD=nil
        TbConfig:Input({Title="Config Name",Placeholder="v1",Callback=function(t) if t and t~="" then cfgInput=t end end})
        TbConfig:Button({Title="Create Config",Callback=function()
            if cfgInput=="" then return end
            if SaveCfg(cfgInput) then local l=ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end
                N("Config","Saved: "..cfgInput,3,"check") end
        end})
        local iL=ListCfgs()
        cfgDD=TbConfig:Dropdown({Title="Select Config",Values=#iL>0 and iL or {"(none)"},Value=iL[1] or nil,Multi=false,AllowNone=true,Callback=function(v) selCfg=v end})
        if #iL>0 then selCfg=iL[1] end
        TbConfig:Button({Title="Load Config",Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            local n=LoadCfg(selCfg); if not n then return end
            SyncUI(); S_Debug=S.DebugHelpers; ConnectStamina(); SetAntiAFK(S.AntiAFK)
            SetAntiTrap(S.AntiTrap); SetAutoEscape(S.AutoEscape); SetBarricade(S.AutoBarricade)
            SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
            if S.AllowJump then SetAllowJump(true) end; if S.AutoRun then SetAutoRun(true) end
            if S.DeleteDoor then SetDeleteDoor(true) end; if S.SkipCutscene then SetSkipCutscene(true) end
            if S.InstantGen then StartInstantGen() end; if S.FullBright then SetFullBright(true) end
            if S.NoBlind then SetNoBlind(true) end; if S.HideGenGui then SetHideGenGui(true) end
            if S.InstantPrompt then SetInstantPrompt(true) end; if S.AutoFarm then SetAutoFarm(true) end
            if S.AutoParry then SetAutoParry(true) end; if S.AutoShakeWire then SetAutoShakeWire(true) end
            if S.FPSBooster then SetFPSBooster(true) end; if S.FovValue~=70 then SetFOV(S.FovValue) end
