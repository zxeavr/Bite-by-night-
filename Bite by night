-- DYNAMIC PARRY
local function GetNearestKillerDistance()
    local char = LP.Character
    local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return 999 end
    local pf = workspace:FindFirstChild("PLAYERS")
    local kf = pf and pf:FindFirstChild("KILLER")
    if not kf then return 999 end
    local minDist = 999
    for _, m in ipairs(kf:GetChildren()) do
        if m:IsA("Model") then
            local kr = m:FindFirstChild("HumanoidRootPart")
            if kr then
                local d = (kr.Position - myRoot.Position).Magnitude
                if d < minDist then minDist = d end
            end
        end
    end
    return minDist
end
task.spawn(function()
    while task.wait(0.1) do
        if S.AutoParry and S.DynamicParry then
            local dist = GetNearestKillerDistance()
            local newRange = math.clamp(dist * 0.8, 5, 30)
            S.ParryRangeBasic = math.floor(newRange)
        end
    end
end)

