local function FindM1Button()
    if m1Btn and m1Btn.Parent then return m1Btn end; m1Btn=nil
    for _,gui in ipairs(LP.PlayerGui:GetChildren()) do
        if not gui:IsA("ScreenGui") then continue end
        for _,desc in ipairs(gui:GetDescendants()) do
            if desc:IsA("GuiButton") or desc:IsA("ImageButton") or desc:IsA("TextButton") then
                local n=desc.Name:lower()
                if n:find("m1") or n:find("attack") or n:find("swing") or n:find("hit") or n:find("punch") then
                    m1Btn=desc; return desc
                end
            end
        end
    end
    return nil
end
local function ExecuteSwing()
    FireInput(true,{"M1"})
    pcall(function()
        local btn=FindM1Button()
        if btn then
            if firetouch then
                firetouch(btn)
            else
                local pos=btn.AbsolutePosition+btn.AbsoluteSize*0.5
                VirtualUser:Button1Down(pos,Camera.CFrame)
                task.wait(0.05)
                VirtualUser:Button1Up(pos,Camera.CFrame)
            end
        end
    end)
end
