-- ====================== ESP ======================
local espCache = {}
local clearESP = function(o) if espCache[o] then pcall(function() espCache[o]:Destroy() end); espCache[o] = nil end end
local function ESP(obj, color, name)
    if not obj or not obj.Parent then clearESP(obj); return end
    local mode = S.ESPMode
    local fillTrans = (mode == "Highlight" and 0.5) or (mode == "Chams" and 0.2) or 1
    if mode == "Name" then
        local bb = espCache[obj]
        if bb and bb:IsA("BillboardGui") and bb:FindFirstChild("NameTag") then
            bb.NameTag.Text = name or obj.Name; bb.NameTag.TextColor3 = color
        else
            if bb then pcall(function() bb:Destroy() end) end
            bb = Instance.new("BillboardGui"); bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,120,0,30)
            bb.StudsOffset = Vector3.new(0,0,0); bb.Parent = obj
            local t = Instance.new("TextLabel", bb); t.Name = "NameTag"; t.Size = UDim2.new(1,0,1,0)
            t.BackgroundTransparency = 1; t.Text = name or obj.Name; t.TextColor3 = color
            t.Font = Enum.Font.GothamBold; t.TextSize = 10; t.TextStrokeTransparency = 0; t.TextStrokeColor3 = Color3.new(0,0,0)
            espCache[obj] = bb
        end
        return
    end
    local hl = espCache[obj]
    if hl and hl:IsA("Highlight") then
        hl.FillColor = color; hl.OutlineColor = color; hl.FillTransparency = fillTrans
    else
        if hl then pcall(function() hl:Destroy() end) end
        hl = Instance.new("Highlight"); hl.Adornee = obj; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.FillColor = color; hl.OutlineColor = color; hl.FillTransparency = fillTrans; hl.OutlineTransparency = 0.3
        hl.Parent = obj; espCache[obj] = hl
    end
end

local processAllESP = function()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP or not p.Character or not p.Team then continue end
        local on, col, nm = false, nil, p.Name
        if IsKiller(p) then on = S.KillerESP; col = S.KillerColor
        elseif IsSurvivor(p) then on = S.SurvivorESP; col = S.SurvivorColor end
        if on then ESP(p.Character, col, nm) else clearESP(p.Character) end
    end
    pcall(function()
        local map = workspace:FindFirstChild("Map"); if not map then return end
        for _, o in ipairs(map:GetDescendants()) do
            if o.Name == "Hook" then
                if o:FindFirstChild("Model") then for _, part in ipairs(o.Model:GetDescendants()) do if part:IsA("MeshPart") then if S.HookESP then ESP(part, S.HookColor, "Hook") else clearESP(part) end end end end
                if o:FindFirstChild("Cartoony Blood Puddle") then local bp = o["Cartoony Blood Puddle"]; if S.HookESP then ESP(bp, S.HookColor, "Hook") else clearESP(bp) end end
            elseif o.Name == "Generator" then if S.GeneratorESP then ESP(o, S.GeneratorColor, "Gen") else clearESP(o) end
            elseif o.Name == "Gate" then if S.GateESP then ESP(o, S.GateColor, "Gate") else clearESP(o) end
            elseif o.Name == "Palletwrong" then if S.PalletESP then ESP(o, S.PalletColor, "Pallet") else clearESP(o) end
            elseif o.Name == "Window" then if S.WindowESP then ESP(o, S.WindowColor, "Window") else clearESP(o) end
            end
        end
    end)
end
local ClearESPCache = function() for o in pairs(espCache) do clearESP(o) end end

