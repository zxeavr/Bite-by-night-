function BuildWindow()
    local ok, err = pcall(function()
        WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()
    end)
    if not ok or not WindUI then
        local msg = Instance.new("Message", LP:WaitForChild("PlayerGui"))
        msg.Text = "❌ WindUI failed. Use Delta or Wave executor."
        task.wait(5); msg:Destroy()
        return
    end

    local Window = WindUI:CreateWindow({
        Title = "Phantom Hub",
        Icon = "moon",
        Author = "7k.u | Violence District",
        Folder = "PhantomHub",
        Size = UDim2.fromOffset(650,420),
        Transparent = true,
        Theme = "Midnight",
        Resizable = false,
        Background = "rbxassetid://104829641696132",
        BackgroundImageTransparency = 0.45,
        User = {Enabled=true, Anonymous=false}
    })
    Window:Tag({Title="v8.0", Color=Color3.fromRGB(120,60,240)})

    -- ================ INFO TAB ================
    local TbInfo = Window:Tab({Title="Info", Icon="info"})
    TbInfo:Paragraph({
        Title = LP.DisplayName.." (@"..LP.Name..")",
        Desc = "Violence District | Phantom Hub",
        Image = "rbxthumb://type=AvatarHeadShot&id="..LP.UserId.."&w=150&h=150",
        ImageSize = 50
    })
    TbInfo:Paragraph({Title="Features",
        Desc="✅ ESP (Highlight/Chams/Name/Dot)\n✅ Auto Perfect Check\n✅ WalkSpeed Slider\n✅ Full Bright / No Fog / No Shadow\n✅ Config save/load"})

    -- ================ MAIN TAB ================
    local TbMain = Window:Tab({Title="Main", Icon="house"})
    TbMain:Toggle({Title="ESP Master", Value = S.ESP, Callback = function(v) S.ESP = v end})
    TbMain:Dropdown({Title="ESP Mode", Values={"Highlight","Chams","Name","Dot"}, Value=S.ESPMode, Multi=false, Callback=function(v) S.ESPMode=v end})
    TbMain:Divider()

    local types = {
        {"Killer", "KillerESP", S.KillerColor, function(c) S.KillerColor=c end},
        {"Survivor", "SurvivorESP", S.SurvivorColor, function(c) S.SurvivorColor=c end},
        {"Generator", "GeneratorESP", S.GeneratorColor, function(c) S.GeneratorColor=c end},
        {"Gate", "GateESP", S.GateColor, function(c) S.GateColor=c end},
        {"Pallet", "PalletESP", S.PalletColor, function(c) S.PalletColor=c end},
        {"Window", "WindowESP", S.WindowColor, function(c) S.WindowColor=c end},
        {"Hook", "HookESP", S.HookColor, function(c) S.HookColor=c end},
    }
    for _,t in ipairs(types) do
        TbMain:Toggle({Title=t[1].." ESP", Value=S[t[2]], Callback=function(v) S[t[2]]=v end})
        TbMain:Colorpicker({Title=t[1].." Color", Default=t[3], Callback=t[4]})
    end
    TbMain:Divider()

    TbMain:Toggle({Title="Auto Perfect Check", Value=S.PerfectCheck, Callback=function(v) S.PerfectCheck=v; SetPerfectCheck(v) end})
    TbMain:Divider()
    TbMain:Slider({Title="Walk Speed", Step=1, Value={Min=10,Max=50,Default=S.WalkSpeed}, Callback=function(v) S.WalkSpeed=v end})

    -- ================ VISUAL TAB ================
    local TbVisual = Window:Tab({Title="Visual", Icon="palette"})
    TbVisual:Toggle({Title="Full Bright", Value=S.FullBright, Callback=function(v) S.FullBright=v; SetFullBright(v) end})
    TbVisual:Toggle({Title="No Fog", Value=S.NoFog, Callback=function(v) S.NoFog=v end})
    TbVisual:Toggle({Title="No Shadow", Value=S.NoShadow, Callback=function(v) S.NoShadow=v end})
    TbVisual:Slider({Title="Field of View", Step=1, Value={Min=10,Max=100,Default=S.FovValue}, Callback=function(v) SetFOV(v) end})
    TbVisual:Divider()
    TbVisual:Slider({Title="UI Scale", Step=0.05, Value={Min=0.7,Max=1.5,Default=S.UIScale}, Callback=function(v) ApplyScale(v) end})
    TbVisual:Slider({Title="UI Transparency", Step=0.05, Value={Min=0,Max=0.9,Default=S.UIAlpha}, Callback=function(v) ApplyAlpha(v) end})

    -- ================ SETTINGS TAB ================
    local TbSet = Window:Tab({Title="Settings", Icon="sliders-horizontal"})
    TbSet:Toggle({Title="Anti-AFK", Value=S.AntiAFK, Callback=function(v) S.AntiAFK=v; SetAntiAFK(v) end})
    TbSet:Toggle({Title="FPS Booster", Value=S.FPSBooster, Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end})

    -- ================ CONFIG TAB ================
    local TbConfig = Window:Tab({Title="Config", Icon="folder"})
    local cfgInput = ""; local selCfg = nil; local cfgDD = nil
    TbConfig:Input({Title="Config Name", Placeholder="myconfig", Callback=function(t) if t and t~="" then cfgInput=t end end})
    TbConfig:Button({Title="Create Config", Callback=function()
        if cfgInput=="" then return end
        if SaveCfg(cfgInput) then
            local l = ListCfgs()
            if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end
            N("Config","Saved: "..cfgInput,3,"check")
        end
    end})
    local iL = ListCfgs()
    cfgDD = TbConfig:Dropdown({Title="Select Config", Values=#iL>0 and iL or {"(none)"}, Value=iL[1] or nil, Multi=false, AllowNone=true, Callback=function(v) selCfg=v end})
    if #iL>0 then selCfg=iL[1] end
    TbConfig:Button({Title="Load Config", Callback=function()
        if not selCfg or selCfg=="(none)" then return end
        local n = LoadCfg(selCfg)
        if not n then return end
        -- refresh UI
        N("Config","Loaded: "..n,3,"folder")
    end})
    TbConfig:Divider()
    local cA = GetAutoLoad()
    TbConfig:Toggle({Title="Auto Load on Start", Value=cA~=nil, Callback=function(v)
        if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
    end})
    TbConfig:Button({Title="Delete Selected", Callback=function()
        if not selCfg or selCfg=="(none)" then return end
        pcall(function() if delfile then delfile(CFG_FOLDER.."/VD_"..selCfg..".json") end end)
        local l = ListCfgs()
        if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end
        selCfg=nil
    end})

    -- ================ INIT ================
    SetFullBright(S.FullBright)
    SetFOV(S.FovValue)
    SetAntiAFK(S.AntiAFK)
    SetFPSBooster(S.FPSBooster)
    SetPerfectCheck(S.PerfectCheck)

    N("Phantom Hub", "Violence District ready!", 4, "moon")
end

-- ================ START ================
ShowLoadingScreen(function()
    ShowLangGUI(function()
        BuildWindow()
    end)
end)
