local RadarDots = {}
for i = 1, 50 do
    local dot = Instance.new("Frame")
    dot.Size = UDim2.fromOffset(6, 6)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    dot.BorderSizePixel = 0
    dot.Visible = false
    dot.Parent = RadarFrame
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    RadarDots[i] = dot
end

local function UpdateRadar()
    RadarGui.Enabled = CFG.RADAR_Enabled
    if not CFG.RADAR_Enabled then return end

    RadarFrame.Size = UDim2.fromOffset(CFG.RADAR_Size, CFG.RADAR_Size)
    RadarFrame.Position = UDim2.new(1, -CFG.RADAR_Size - 20, 0, 20)

    local root = GetRoot()
    if not root then
        for _, d in ipairs(RadarDots) do d.Visible = false end
        return
    end

    local myPos = root.Position
    local myLook = Camera.CFrame.LookVector
    local angle = math.atan2(-myLook.X, -myLook.Z)
    local cosA, sinA = math.cos(angle), math.sin(angle)
    local scale = (CFG.RADAR_Size / 2 - 10) / 150
    local idx = 1

    local function AddDot(pos, color)
        if idx > #RadarDots then return end
        local dx, dz = pos.X - myPos.X, pos.Z - myPos.Z
        local dist2D = math.sqrt(dx*dx + dz*dz)
        if dist2D > 150 then return end
        local rotX = dx * cosA - dz * sinA
        local rotZ = dx * sinA + dz * cosA
        local rx, ry = rotX * scale, rotZ * scale
        local maxD = CFG.RADAR_Size / 2 - 8
        local rDist = math.sqrt(rx*rx + ry*ry)
        if rDist > maxD then rx, ry = rx/rDist*maxD, ry/rDist*maxD end
        local dot = RadarDots[idx]
        dot.Position = UDim2.new(0.5, rx - 3, 0.5, ry - 3)
        dot.BackgroundColor3 = color
        dot.Visible = true
        idx = idx + 1
    end

    if CFG.RADAR_Killer then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and IsKiller(p) and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r then AddDot(r.Position, COLORS.Killer) end
            end
        end
    end
    if CFG.RADAR_Survivor then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and IsSurvivor(p) and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r then AddDot(r.Position, COLORS.Survivor) end
            end
        end
    end
    if CFG.RADAR_Generator then
        for _, g in ipairs(Cache.Generators) do
            if g.part then AddDot(g.part.Position, COLORS.Generator) end
        end
    end
    if CFG.RADAR_Pallet then
        for _, p in ipairs(Cache.Pallets) do
            if p.part then AddDot(p.part.Position, COLORS.Pallet) end
        end
    end
    for i = idx, #RadarDots do RadarDots[i].Visible = false end
end

