-- AUTO PHASE
local phaseConn=nil
local function SetAutoPhase(on)
    if phaseConn then phaseConn:Disconnect() phaseConn=nil end if not on then return end
    local canPhase=true
    phaseConn=RunService.Heartbeat:Connect(function()
        if not canPhase then return end
        pcall(function()
            local char=LP.Character if not char then return end local maskClient=char:FindFirstChild("MaskClient") if not maskClient then return end
            local checkPartsModule=maskClient:FindFirstChild("CheckParts") if not checkPartsModule then return end local checkParts=require(checkPartsModule)
            local lungeFunc=nil local activeLunge=maskClient:FindFirstChild("ActiveLunge") if activeLunge then for _,conn in next,getconnections(activeLunge.OnClientEvent) do lungeFunc=conn.Function break end end
            if not lungeFunc or not checkParts then return end
            local other=workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP") and workspace.MAPS["GAME MAP"]:FindFirstChild("Other") if not other then return end
            local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
            local nearest,nearestDist=nil,math.huge
            for _,part in next,other:GetDescendants() do if part:IsA("BasePart") then local lower=part.Name:lower() for _,v in next,checkParts do if type(v)=="string" and lower:find(v:lower(),nil,true) then local dist=(part.Position-hrp.Position).Magnitude if dist<nearestDist then nearestDist=dist nearest=part end break end end end end
            if nearest and nearestDist<=S.PhaseDistance then canPhase=false lungeFunc() task.wait(0.3) canPhase=true end
        end)
    end)
end

