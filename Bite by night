-- AUTO PERFECT SKILL CHECK (From user provided code, improved)
-- ============================================================
local SkillCheck = {
    monitoring = false,
    conn = nil,
    uiConn = nil,
}

function SkillCheck:GetElements()
    local pg = LP:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local prompt = pg:FindFirstChild("SkillCheckPromptGui")
    if not prompt then return nil end
    local frame = prompt:FindFirstChild("Check")
    if not frame then return nil end
    return {
        frame = frame,
        needle = frame:FindFirstChild("Line"),
        target = frame:FindFirstChild("Goal")
    }
end

function SkillCheck:IsInZone(needleAngle, targetAngle)
    local needle = needleAngle % 360
    local target = targetAngle % 360
    local startAngle = (target + 104) % 360
    local endAngle = (target + 114) % 360
    if startAngle > endAngle then
        return needle >= startAngle or needle <= endAngle
    end
    return needle >= startAngle and needle <= endAngle
end

function SkillCheck:Press()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
    task.wait(0.01)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
end

function SkillCheck:Stop()
    self.monitoring = false
    if self.conn then pcall(function() self.conn:Disconnect() end); self.conn = nil end
end

function SkillCheck:FrameUpdate()
    if not Config.Auto.SkillCheck then self:Stop(); return end
    local ui = self:GetElements()
    if not ui or not ui.needle or not ui.target then self:Stop(); return end
    if self:IsInZone(ui.needle.Rotation, ui.target.Rotation) then
        self:Press()
        self:Stop()
    end
end

function SkillCheck:Start()
    if self.monitoring then return end
    self.monitoring = true
    self.conn = RunService.Heartbeat:Connect(function() self:FrameUpdate() end)
end

function SkillCheck:OnVisibilityChange()
    if not Config.Auto.SkillCheck then self:Stop(); return end
    local ui = self:GetElements()
    if ui and ui.frame and ui.frame.Visible then
        self:Start()
    else
        self:Stop()
    end
end

function SkillCheck:Init()
    pcall(function()
        local ui = self:GetElements()
        if ui and ui.frame then
            self.uiConn = ui.frame:GetPropertyChangedSignal("Visible"):Connect(function()
                self:OnVisibilityChange()
            end)
        end
    end)
    -- Re-init on character respawn
    LP.CharacterAdded:Connect(function()
        task.wait(2)
        pcall(function()
            if self.uiConn then self.uiConn:Disconnect() end
            local ui = self:GetElements()
            if ui and ui.frame then
                self.uiConn = ui.frame:GetPropertyChangedSignal("Visible"):Connect(function()
                    self:OnVisibilityChange()
                end)
            end
        end)
    end)
end

-- ============================================================
-- AUTO GENERATOR (VD style, optimized)
-- ============================================================
local AutoGen = {
    running = false,
    thread = nil,
}

function AutoGen:Loop()
    while self.running and task.wait(0.15) do
        if not Config.Auto.Generator then continue end
        pcall(function()
            local remotes = RS:FindFirstChild("Remotes")
            local gen = remotes and remotes:FindFirstChild("Generator")
            local repair = gen and gen:FindFirstChild("RepairEvent")
            local skill = gen and gen:FindFirstChild("SkillCheckResultEvent")
            if not repair or not skill then return end
            
            for _, data in ipairs(PerfManager.cache.generators) do
                local genModel = data.model
                for _, pt in ipairs(genModel:GetChildren()) do
                    if pt.Name:find("GeneratorPoint") then
                        pcall(function()
                            repair:FireServer(pt, true)
                            local mode = Config.Auto.GenMode == "great"
                            skill:FireServer(mode and "success" or "neutral", mode and 1 or 0, genModel, pt)
                        end)
                    end
                end
            end
        end)
    end
end

function AutoGen:Set(state)
    Config.Auto.Generator = state
    if state and not self.running then
        self.running = true
        self.thread = task.spawn(function() self:Loop() end)
    elseif not state and self.running then
        self.running = false
    end
end

-- ============================================================
-- AUTO ATTACK (Killer)
-- ============================================================
local AutoAttack = {
    conn = nil,
}

function AutoAttack:Set(state)
    Config.Auto.Attack = state
    if self.conn then pcall(function() self.conn:Disconnect() end); self.conn = nil end
    if not state then return end
    
    self.conn = RunService.Heartbeat:Connect(function()
        if not Config.Auto.Attack or not LPChar then return end
        if not LPRoot then return end
        local myPos = LPRoot.Position
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            if not player.Character then continue end
            if not player.Team or player.Team.Name ~= "Survivors" then continue end
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if not targetRoot then continue end
            local dist = (targetRoot.Position - myPos).Magnitude
            if dist <= Config.Auto.AttackRange then
                pcall(function()
                    local remotes = RS:FindFirstChild("Remotes")
                    local attacks = remotes and remotes:FindFirstChild("Attacks")
                    local basic = attacks and attacks:FindFirstChild("BasicAttack")
                    if basic then basic:FireServer(false) end
                end)
                break
            end
        end
    end)
end

