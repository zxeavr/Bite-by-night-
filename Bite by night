workspace.DescendantAdded:Connect(function(c) if c:IsA("Highlight") and c.Parent then parryingPlayers[c.Parent]=tick() end end)
workspace.DescendantRemoving:Connect(function(c) if c:IsA("Highlight") and c.Parent then parryingPlayers[c.Parent]=nil end end)
local function IsParrying(m)
    local t=parryingPlayers[m]; if not t then return false end
    if (tick()-t)>1.5 then parryingPlayers[m]=nil; return false end; return true
