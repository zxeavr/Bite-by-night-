local TRAP_ATTRS={"Trapped","BeartrapCaught","Caught","InTrap","Tripped","Snared","TrapCaught"}
local TRAP_TAGS={"Trapped","BeartrapCaught","Bear","InBearTrap","BearTrap"}
function AntiTrapUpdate()
    if not LPChar or not LPHum then return end
    pcall(function()
        for _,a in ipairs(TRAP_ATTRS) do local v=LPChar:GetAttribute(a)
            if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
            elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
        end
        for _,t in ipairs(TRAP_TAGS) do if CollectionService:HasTag(LPChar,t) then CollectionService:RemoveTag(LPChar,t) end end
        local hrp=LPChar:FindFirstChild("HumanoidRootPart")
        if hrp then for _,o in ipairs(hrp:GetChildren()) do
            if o:IsA("BallSocketConstraint") or o:IsA("RopeConstraint") then pcall(function() o:Destroy() end) end
        end end
        if LPHum.WalkSpeed<=0 then LPHum.WalkSpeed=math.max(S.RunSpeed,16) end
    end)
end

-- دالة الباريكاد المنفصلة
function BarricadeUpdate()
    pcall(function()
        local du
        for _,v in ipairs(LP.PlayerGui:GetChildren()) do if v.Name=="Dot" and v.Enabled then du=v; break end end
        if not du then return end
        local c=du:FindFirstChild("Container"); local f=c and c:FindFirstChild("Frame")
        if not f then for _,d in ipairs(du:GetDescendants()) do if d:IsA("Frame") and d.Name~="Container" then f=d; break end end end
        if f then local vp=Camera.ViewportSize; f.Position=UDim2.fromOffset(vp.X/2,vp.Y/2) end
    end)
end

-- هروب
function EscapeMap()
    pcall(function()
        local gF=workspace:FindFirstChild("GAME"); local cE=gF and gF:FindFirstChild("CAN_ESCAPE")
        if cE and not cE.Value then return end
        local mF=workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP")
        if mF then
            local ef=mF:FindFirstChild("Escapes")
            if ef then for _,v in ipairs(ef:GetChildren()) do
                if v:GetAttribute("Enabled")~=false and LPChar then
                    local cf=v:IsA("BasePart") and v.CFrame or (v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.CFrame)
                    if cf then LPChar:PivotTo(cf+Vector3.new(0,4,0)); return end
                end
            end end
            local dF=mF:FindFirstChild("Doors")
            if dF then for _,d in ipairs(dF:GetChildren()) do
                local tp=d:FindFirstChild("TouchPart")
                if tp and not tp.CanCollide and LPChar then LPChar:PivotTo(tp.CFrame*CFrame.new(0,2,-5)); return end
            end end
        end
    end)
end

-- دائرة نطاق الباري (تُحدث بشكل منفصل)
local parryCirclePart
local function UpdateParryCircle()
    if not S.ShowParryRange then
        if parryCirclePart then parryCirclePart:Destroy(); parryCirclePart = nil end
        return
    end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        if parryCirclePart then parryCirclePart.Enabled = false end
        return
    end
    if not parryCirclePart then
        parryCirclePart = Instance.new("Part")
        parryCirclePart.Name = "PH_ParryDisc"
        parryCirclePart.Anchored = true
        parryCirclePart.CanCollide = false
        parryCirclePart.Material = Enum.Material.SmoothPlastic
        parryCirclePart.Color = Color3.fromRGB(255,0,0)
        parryCirclePart.Transparency = 0.6
        parryCirclePart.Shape = Enum.PartType.Cylinder
        parryCirclePart.Size = Vector3.new(1,0.2,1)
        parryCirclePart.Parent = workspace
    end
    local radius = S.ParryRangeBasic
    parryCirclePart.Size = Vector3.new(radius*2, 0.2, radius*2)
    parryCirclePart.CFrame = CFrame.new(hrp.Position) * CFrame.new(0, -2, 0)
    parryCirclePart.Enabled = true
end
task.spawn(function() while task.wait(0.1) do pcall(UpdateParryCircle) end end)

