            local char = LP.Character or LP.CharacterAdded:Wait()
            char.DescendantAdded:Connect(function(tool)
                if tool:IsA("Tool") and autoReach and reachValue > 0 then
                    for _, part in next, tool:GetDescendants() do
                        if part:IsA("BasePart") and part:FindFirstChild("TouchInterest") then
                            part.Transparency = 1
                            part.Massless = true
                            part.Size = Vector3.new(reachValue, reachValue, reachValue)
                        end
                    end
                end
            end)
        end
    end
    -- Get main weapon button
    ISFunctions.GetMainWeapon = function()
        local last = LP.Character.HumanoidRootPart.CFrame
        local bac = LP.Backpack
        repeat task.wait()
            local toolname = (LP.Marketplace["Main Weapon"].Equipped.Value == "Default" and "Bat" or LP.Marketplace["Main Weapon"].Equipped.Value)
            LP.Character.HumanoidRootPart.CFrame = workspace.Map.HumanBase.Vendor.BatCollection.HitBox.CFrame
            workspace.Map.HumanBase.Vendor.BatCollection.ClickDetector.MaxActivationDistance = math.huge
            fireclickdetector(workspace.Map.HumanBase.Vendor.BatCollection.ClickDetector)
        until bac:FindFirstChild(toolname)
        repeat task.wait() LP.Character.HumanoidRootPart.CFrame = last until LP.Character.HumanoidRootPart.CFrame == last
    end
    -- Get all special weapons
    ISFunctions.GetAllSpecialWeapons = function()
        for _, gun in next, workspace.Map.System:GetDescendants() do
            if gun:IsA("ClickDetector") and table.find({"FirePotionCollection", "ShotgunCollection", "KnifeCollection", "HatchetCollection", "RustyShovelCollection", "WaterJugCollection", "HandgunCollection", "ShovelCollection"}, gun.Parent.Name) and not gun.Parent:FindFirstAncestor("Locker") then
                local name = table.concat(string.split(string.gsub(gun.Parent.Name, "Collection", ""), "%l"), " ")
                local pos = LP.Character.HumanoidRootPart.CFrame
                local past = tick()
                repeat task.wait()
                    LP.Character.HumanoidRootPart.CFrame = gun.Parent:FindFirstChildWhichIsA("BasePart").CFrame
                    fireclickdetector(gun)
                until LP.Backpack:FindFirstChild(name) or tick() - past >= 0.75
                LP.Character.HumanoidRootPart.CFrame = pos
            end
        end
    end
    -- Delete tool
    ISFunctions.DeleteTool = function()
        local tool = LP.Character:FindFirstChildOfClass("Tool")
        if tool then tool:Destroy() end
    end
    -- Anti inventory block
    local antiInventory = false
    ISFunctions.SetAntiInventory = function(val)
        antiInventory = val
        task.spawn(function()
            while antiInventory do
                task.wait()
                pcall(function() game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true) end)
            end
        end)
    end
    -- Anti infection
    ISFunctions.SetAntiInfection = function(val)
        for _, part in next, workspace.Map:GetDescendants() do
            if part:IsA("BasePart") and string.find(part.Parent.Name, "Infector") then
                part.Transparency = val and 0.25 or 0
                part.CanTouch = not val
            end
        end
    end
    -- Anti infected players
    local antiInfectedPlayers = false
    ISFunctions.SetAntiInfectedPlayers = function(val)
        antiInfectedPlayers = val
        task.spawn(function()
            while antiInfectedPlayers do
                task.wait()
                if LP.Character and LP.Character.Humanoid:GetStateEnabled(Enum.HumanoidStateType.Jumping) == false and LP.Team:lower() ~= "smilling" then
                    LP.Character.HumanoidRootPart.Velocity = LP.Character.HumanoidRootPart.Velocity * 10000 + Vector3.new(0, 10000, 0)
                    task.wait()
                    LP.Character.HumanoidRootPart.Velocity = LP.Character.HumanoidRootPart.Velocity
                end
            end
        end)
    end
    -- AntiCheat destroy
    ISFunctions.AntiCheatDestroy = function()
        pcall(function() workspace.Map.AntiHack:Destroy() end)
        pcall(function() LP.Character.StayOnPart:Destroy() end)
        pcall(function() LP.Character.HumanoidInit:Destroy() end)
    end
    -- Infect yourself
    ISFunctions.Infect = function()
        firetouchinterest(LP.Character.HumanoidRootPart, workspace.Map.Infectors.Infector.Part, 0)
    end
    -- Reach hitbox input
    ISFunctions.SetReachHitbox = function(num)
        local hitbox = Instance.new("SelectionBox", LP.Character.Torso.Part)
        hitbox.Adornee = LP.Character.Torso.Part
        LP.Character.Torso.Part.Massless = true
        LP.Character.Torso.Part.Size = Vector3.new(7, 2, tonumber(num) or 0)
    end
    -- Disable anti smilers
    ISFunctions.DisableAntiSmilers = function(val)
        for _, part in next, workspace:GetDescendants() do
            if part:IsA("BasePart") and part.BrickColor.Name == "Neon orange" then
                part.CanTouch = not val
                part.CanQuery = not val
            end
        end
    end
    -- Auto grab
    local autoGrab = false
    ISFunctions.SetAutoGrab = function(val)
        autoGrab = val
        task.spawn(function()
            while autoGrab do
                task.wait()
                pcall(function() LP.Character.Infected.InfectEvent:FireServer() end)
            end
        end)
    end
    -- Kill grab
    local killGrab = false
    ISFunctions.SetKillGrab = function(val)
        killGrab = val
        task.spawn(function()
            while killGrab do
                task.wait()
                for _, player in ipairs(Players:GetPlayers()) do
                    pcall(function()
                        if player ~= LP and player.Character and player.Character.HumanoidRootPart and isnetworkowner(player.Character.HumanoidRootPart) then
                            firetouchinterest(player.Character.HumanoidRootPart, workspace.Map.Misc.Spearer.Lava, 0)
                        end
                    end)
                end
            end
        end)
    end
    -- Instant kill grab
    local instantKillGrab = false
    ISFunctions.SetInstantKillGrab = function(val)
        instantKillGrab = val
        task.spawn(function()
            while instantKillGrab do
                task.wait()
                for _, player in ipairs(Players:GetPlayers()) do
                    pcall(function()
                        if player ~= LP and player.Character and player.Character.HumanoidRootPart and isnetworkowner(player.Character.HumanoidRootPart) then
                            for _, part in next, workspace.Map:GetDescendants() do
                                if part:IsA("BasePart") and part:FindFirstChildWhichIsA("TouchTransmitter") then
                                    firetouchinterest(player.Character.HumanoidRootPart, part, 0)
                                    firetouchinterest(player.Character.HumanoidRootPart, part, 1)
                                end
                            end
                        end
                    end)
                end
            end
        end)
    end
    -- Push grab
    local pushGrab = false
    ISFunctions.SetPushGrab = function(val)
        pushGrab = val
        task.spawn(function()
            while pushGrab do
                task.wait()
                for _, player in ipairs(Players:GetPlayers()) do
                    pcall(function()
                        if player ~= LP and player.Character and player.Character.HumanoidRootPart and isnetworkowner(player.Character.HumanoidRootPart) then
                            player.Character.Humanoid:ChangeState("PlatformStanding", true)
                            player.Character.HumanoidRootPart.Velocity += LP.Character.HumanoidRootPart.CFrame.RightVector * 600
                        end
                    end)
                end
            end
        end)
    end
    -- Anti stun (IS version)
    local antiStunIS = false
    ISFunctions.SetAntiStunIS = function(val)
        antiStunIS = val
        task.spawn(function()
            while antiStunIS do
                task.wait()
                pcall(function()
                    if LP.Character.Stats.Downed.Value == true or LP.Character.Stats.Ragdoll.Value == true then
                        LP.Character.Humanoid.WalkSpeed = 20
                        LP.Character.Humanoid:SetStateEnabled("Jumping", true)
                        LP.Character.Stats.Downed.Value = false
                        LP.Character.Stats.Ragdoll.Value = false
                    end
                end)
            end
        end)
    end
    -- Instant infect
    ISFunctions.InstantInfect = function()
        if LP.Character:FindFirstChild("Infected") then
            LP.Character.Infected.Infect.Cooldown.Value = 0
        end
    end
    -- Auto collect keys
    local autoKeys = false
    ISFunctions.SetAutoKeys = function(val)
        autoKeys = val
        task.spawn(function()
            while autoKeys do
                task.wait()
                for _, key in next, workspace.Particles:GetChildren() do
                    if key:IsA("BasePart") and string.find(key.Name, "Key") then
                        firetouchinterest(workspace:WaitForChild(LP.Name, 10):WaitForChild("HumanoidRootPart", 10), key, 0)
                    end
                end
            end
        end)
    end
    -- Auto collect coins
    local autoCoins = false
    ISFunctions.SetAutoCoins = function(val)
        autoCoins = val
        task.spawn(function()
            while autoCoins do
                task.wait()
                for _, v in pairs(workspace.Map.System:GetDescendants()) do
                    if v.Name == "SmileCoin" and v:FindFirstChild("TouchInterest") then
                        pcall(function() firetouchinterest(LP.Character.HumanoidRootPart, v, 0) end)
                    end
                end
            end
        end)
    end
    -- Fullbright button
    ISFunctions.FullBrightIS = function()
        pcall(function()
            local lighting = game:GetService("Lighting")
            lighting.Ambient = Color3.fromRGB(255, 255, 255)
            lighting.Brightness = 1
            lighting.FogEnd = 1e10
            for i, v in pairs(lighting:GetDescendants()) do
                if v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect") or v:IsA("SunRaysEffect") then
                    v.Enabled = false
                end
            end
            lighting.Changed:Connect(function()
                lighting.Ambient = Color3.fromRGB(255, 255, 255)
                lighting.Brightness = 1
                lighting.FogEnd = 1e10
            end)
            spawn(function()
                local character = LP.Character
                while wait() do
                    repeat wait() until character ~= nil
                    if not character.HumanoidRootPart:FindFirstChildWhichIsA("PointLight") then
                        local headlight = Instance.new("PointLight", character.HumanoidRootPart)
                        headlight.Brightness = 1
                        headlight.Range = 60
                    end
                end
            end)
        end)
    end
    -- Remove fog
    ISFunctions.RemoveFog = function()
        game.Lighting.FogStart = math.huge
        game.Lighting.FogEnd = math.huge
        game.Lighting.FogColor = Color3.new(0, 0, 0)
    end
    -- Check seismic activity
    ISFunctions.CheckSeismic = function()
        local original = workspace.CurrentCamera.CFrame
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
        workspace.CurrentCamera.CFrame = CFrame.new(-20, 6, -10) * CFrame.Angles(0, math.rad(90), 0)
        task.wait(2)
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    end
    -- Anti black hole
    local antiBlackHole = false
    ISFunctions.SetAntiBlackHole = function(val)
        antiBlackHole = val
        task.spawn(function()
            while antiBlackHole do
                task.wait()
                for _, child in pairs(LP.Character:GetDescendants()) do
                    if child:IsA("BodyMover") then child:Destroy() end
                end
            end
        end)
    end
    -- Kill nearest NPCs
    local killNPCs = false
    ISFunctions.SetKillNPCs = function(val)
        killNPCs = val
        task.spawn(function()
            while killNPCs do
                task.wait()
                if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                    local parts = workspace:GetPartBoundsInRadius(LP.Character.HumanoidRootPart.Position, 45)
                    for _, part in next, parts do
                        if part.Anchored == false and not Players:GetPlayerFromCharacter(part.Parent) and part.Parent:FindFirstChildOfClass("Humanoid") then
                            local humanoid = part.Parent:FindFirstChildOfClass("Humanoid")
                            humanoid.Health = 0
                            humanoid:TakeDamage(math.huge)
                        end
                    end
                end
            end
        end)
    end
    -- Disable echo sounds
    ISFunctions.DisableEcho = function(val)
        if val then
            game:GetService("SoundService"):ResetPropertyToDefault("AmbientReverb")
        else
            game:GetService("SoundService").AmbientReverb = Enum.ReverbType.Cave
        end
    end
    -- Loadstring buttons (external scripts)
    ISFunctions.RunScript = function(url)
        loadstring(game:HttpGet(url, true))()
    end
end

