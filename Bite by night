local TRAP_ATTRS={"Trapped","BeartrapCaught","Caught","InTrap","Tripped","Snared","TrapCaught"}
local TRAP_TAGS={"Trapped","BeartrapCaught","Bear","InBearTrap","BearTrap"}
local antiTrapConn=nil
local function SetAntiTrap(on)
    if antiTrapConn then antiTrapConn:Disconnect(); antiTrapConn=nil end; if not on then return end
    antiTrapConn=RunService.Heartbeat:Connect(function()
        if not S.AntiTrap or not LPChar or not LPHum then return end
        pcall(function()
            for _,a in ipairs(TRAP_ATTRS) do local v=LPChar:GetAttribute(a)
                if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
                elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
            end
            for _,t in ipairs(TRAP_TAGS) do if CollectionService:HasTag(LPChar,t) then CollectionService:RemoveTag(LPChar,t) end end
            local hrp=LPChar:FindFirstChild("HumanoidRootPart")
            if hrp then for _,o in ipairs(hrp:GetChildren()) do
                if o:IsA("BallSocketConstraint") or o:IsA("RopeConstraint") then pcall(function() o:Destroy() end) end
            end end
            if LPHum.WalkSpeed<=0 then LPHum.WalkSpeed=math.max(S.RunSpeed,16) end
            if not hrp then return end
            local ig=workspace:FindFirstChild("IGNORE"); if not ig then return end
            local trapF=ig:FindFirstChild("Trap"); if not trapF then return end
            for _,trap in ipairs(trapF:GetChildren()) do
                if not trap:IsA("Model") then continue end
                local pp=trap.PrimaryPart or trap:FindFirstChildOfClass("BasePart"); if not pp then continue end
                if (hrp.Position-pp.Position).Magnitude<=10 then pcall(function() trap:SetAttribute("HP",0) end) end
            end
        end)
    end)
end

