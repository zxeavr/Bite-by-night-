local function UpdateHitboxes()
    if GetRole() ~= "Killer" or not CFG.HITBOX_Enabled then
        for p, sz in pairs(OriginalHitboxes) do
            SafeCall(function()
                if p and p.Character then
                    local r = p.Character:FindFirstChild("HumanoidRootPart")
                    if r then r.Size = sz; r.Transparency = 1; r.CanCollide = true end
                end
            end)
        end
        OriginalHitboxes = {}
        return
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and IsSurvivor(p) then
            local c = p.Character
            if c then
                local r = c:FindFirstChild("HumanoidRootPart")
                local h = c:FindFirstChildOfClass("Humanoid")
                if r and h and h.Health > 0 then
                    if not OriginalHitboxes[p] then OriginalHitboxes[p] = r.Size end
                    local sz = CFG.HITBOX_Size
                    r.Size = Vector3.new(sz, sz, sz)
                    r.CanCollide = false
                    r.Transparency = 0.7
                end
            end
        end
    end
end

local function AutoAttack()
    if not CFG.AUTO_Attack or GetRole() ~= "Killer" then return end
    local root = GetRoot()
    if not root then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local tr = p.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                local d = (tr.Position - root.Position).Magnitude
                if d <= CFG.AUTO_AttackRange then
                    SafeCall(function()
                        local rem = ReplicatedStorage:FindFirstChild("Remotes")
                        local att = rem and rem:FindFirstChild("Attacks")
                        local ba = att and att:FindFirstChild("BasicAttack")
                        if ba then ba:FireServer(false) end
                    end)
                    break
                end
            end
        end
    end
end

local function DoubleTap()
    if not CFG.KILLER_DoubleTap or GetRole() ~= "Killer" then return end
    if tick() - State.LastDoubleTap < 0.5 then return end
    SafeCall(function()
        local rem = ReplicatedStorage:FindFirstChild("Remotes")
        local att = rem and rem:FindFirstChild("Attacks")
        local ba = att and att:FindFirstChild("BasicAttack")
        if ba then ba:FireServer(false); task.wait(0.05); ba:FireServer(false); State.LastDoubleTap = tick() end
    end)
end

local function InfiniteLunge()
    if not CFG.KILLER_InfiniteLunge or GetRole() ~= "Killer" then return end
    local c = LP.Character
