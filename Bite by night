local antiTrapConn; local trapSigConns = {}; local trapActive = false; local savedTrapCF = nil
local function GetLobbyPosition()
	local pf = workspace:FindFirstChild("PLAYERS"); if not pf then return nil end
	local lb = pf:FindFirstChild("LOBBY"); if not lb then return nil end
	local tp = lb:FindFirstChildOfClass("BasePart")
	if not tp then for _, v in ipairs(lb:GetDescendants()) do if v:IsA("BasePart") then tp = v; break end end end
	return tp and tp.CFrame
end
local function ClearTrapState()
	if not LPChar then return end
	for _, t in ipairs(TRAP_TAGS) do pcall(function() if CollectionService:HasTag(LPChar,t) then CollectionService:RemoveTag(LPChar,t) end end) end
	for _, a in ipairs(TRAP_ATTRS) do pcall(function()
		local v = LPChar:GetAttribute(a)
		if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
		elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
	end) end
	for _, obj in ipairs(LPChar:GetDescendants()) do
		if obj:IsA("BallSocketConstraint") or obj:IsA("RopeConstraint") or obj:IsA("WeldConstraint") then pcall(function() obj:Destroy() end) end
	end
end
local function TrapEscape()
	if trapActive then return end; if not LPChar then return end
	trapActive = true
	local hrp = LPChar:FindFirstChild("HumanoidRootPart")
	if hrp then savedTrapCF = hrp.CFrame end
	ClearTrapState()
	local lPos = GetLobbyPosition()
	if lPos and hrp then
		hrp.CFrame = CFrame.new(lPos.Position+Vector3.new(0,5,0))
	else
		if hrp then hrp.CFrame = CFrame.new(hrp.CFrame.Position-Vector3.new(0,50,0)) end
	end
	local clearLoop = task.spawn(function() for _=1,40 do task.wait(0.2); ClearTrapState() end end)
	task.delay(8, function()
		pcall(task.cancel, clearLoop); ClearTrapState()
		if LPChar and savedTrapCF then
			local hrp2 = LPChar:FindFirstChild("HumanoidRootPart")
			if hrp2 then hrp2.CFrame = savedTrapCF+Vector3.new(0,4,0) end
		end
		trapActive = false
	end)
end
local function SetAntiTrap(on)
	if antiTrapConn then antiTrapConn:Disconnect(); antiTrapConn = nil end
	for _, c in ipairs(trapSigConns) do pcall(function() c:Disconnect() end) end; trapSigConns = {}
	if not on then return end
