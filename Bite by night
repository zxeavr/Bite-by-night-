local aimbotConn, aimbotTarget
local GetAimTargetPart = function(char)
    if not char then return nil end
    if S.AimTargetPart == "Head" then return char:FindFirstChild("Head")
    elseif S.AimTargetPart == "Torso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    else return char:FindFirstChild("HumanoidRootPart") end
end
local IsVisible = function(char)
    if not char then return false end
    local cam = Camera; if not cam then return false end
    local parts = {"Head","UpperTorso","Torso","HumanoidRootPart"}
    local params = RaycastParams.new(); params.FilterType = Enum.RaycastFilterType.Blacklist; params.FilterDescendantsInstances = {cam, LP.Character, char}
    for _, p in ipairs(parts) do
        local part = char:FindFirstChild(p); if part then
            local dir = part.Position - cam.CFrame.Position; local ray = workspace:Raycast(cam.CFrame.Position, dir, params)
            if not ray then return true end
        end
    end
    return false
end
local FindBestAimTarget = function()
    if not Camera then return nil end
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local myRole = GetRole(); local closest, bestDist = nil, S.AimFOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP or not p.Character or not p.Team then continue end
        local should = (myRole == "Survivor" and IsKiller(p)) or (myRole == "Killer" and IsSurvivor(p))
        if should then
            local tPart = GetAimTargetPart(p.Character); if tPart then
                local visOk = not S.AimVisCheck or IsVisible(p.Character)
                if visOk then
                    local sp, onScr = Camera:WorldToViewportPoint(tPart.Position)
                    if onScr then local d = (Vector2.new(sp.X, sp.Y) - screenCenter).Magnitude; if d < bestDist then bestDist = d; closest = p end end
                end
            end
        end
    end
    return closest
end
local AimAt = function(pos) if Camera and pos then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, pos), S.AimSmooth) end end
local aimHolding = false
UserInputService.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton2 then aimHolding = true end end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton2 then aimHolding = false; aimbotTarget = nil end end)
SetAimbot = function(on)
    S.Aimbot = on; if aimbotConn then aimbotConn:Disconnect(); aimbotConn = nil end
    if not on then return end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not S.Aimbot or not aimHolding then aimbotTarget = nil; return end
        local t = FindBestAimTarget(); aimbotTarget = t
        if t and t.Character then local tp = GetAimTargetPart(t.Character); if tp then local pos = tp.Position; if S.AimPredict and t.Character:FindFirstChild("HumanoidRootPart") then pos = pos + t.Character.HumanoidRootPart.Velocity * 0.1 end; AimAt(pos) end end
    end)
end

