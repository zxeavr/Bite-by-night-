local function SetAutoSwing(on)
    if swingConn then swingConn:Disconnect(); swingConn=nil end; if not on then m1Btn=nil; return end
    task.spawn(function() task.wait(0.5); FindM1Button() end)
    swingConn=RunService.Heartbeat:Connect(function()
        if not S.AutoSwing then return end
        if (tick()-lastSwing)<0.45 then return end
        local char=LP.Character; local myRoot=char and char:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
        pcall(function()
            local pf=workspace:FindFirstChild("PLAYERS"); local af=pf and pf:FindFirstChild("ALIVE"); if not af then return end
            local bd=S.SwingRange+1; local bt=nil
            for _,m in ipairs(af:GetChildren()) do
                if m.Name==LP.Name or IsParrying(m) then continue end
                local h=m:FindFirstChild("HumanoidRootPart"); if not h then continue end
                local d=(myRoot.Position-h.Position).Magnitude
