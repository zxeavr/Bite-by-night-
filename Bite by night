local function ListCfgs()
    if not listfiles then return {} end
    local r = {}; local ok, fs = pcall(listfiles, CFG_FOLDER); if not ok then return r end
    for _, f in ipairs(fs) do local n = f:match("([^/\\]+)%.json$"); if n and n ~= "_autoload" then table.insert(r, n) end end
    return r
end
local function SaveCfg(name)
    if not writefile then return false end
    local function sc(c) return {c.R, c.G, c.B} end
    local data = {LANG = LANG, Game = CURRENT_GAME}
    -- save all current S
    for k, v in pairs(S) do
        if type(v) == "table" and v.R then data[k] = sc(v)
        elseif type(v) == "table" and v.On ~= nil then
            data[k] = {On = v.On, Color = sc(v.Color)}
        else data[k] = v
        end
    end
    local json = HttpService:JSONEncode(data)
    return pcall(writefile, CFG_FOLDER .. "/" .. name .. ".json", json)
end
local function LoadCfg(name)
    if not readfile or not isfile then return nil end
    local path = CFG_FOLDER .. "/" .. name .. ".json"
    if not isfile(path) then return nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not ok or not data then return nil end
    for k, v in pairs(data) do
        if S[k] ~= nil then
            if type(v) == "table" and v.R then S[k] = Color3.new(v[1], v[2], v[3])
            elseif type(v) == "table" and v.On ~= nil then
                S[k].On = v.On
                if v.Color then S[k].Color = Color3.new(v.Color[1], v.Color[2], v.Color[3]) end
            else S[k] = v
            end
        end
    end
    S_Debug = S.DebugHelpers
    return true
end
local function GetAutoLoad()
    if not isfile or not readfile or not isfile(AUTO_FILE) then return nil end
    local ok, v = pcall(readfile, AUTO_FILE); return (ok and v and v ~= "") and v or nil
end
local function SetAutoLoad(n) pcall(writefile, AUTO_FILE, n or "") end

