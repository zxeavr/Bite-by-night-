local camLockActive = false
local camLockTarget = nil

local function AnyCamLockOn()
    return S.CamLockRotten or S.CamLockM1 or S.CamLockTaser or S.CamLockDoppelPull
        or S.CamLockDoppelStab or S.CamLockMimicGrab or S.CamLockMimicJump
end

local function CamLockStop()
    camLockActive = false
    camLockTarget = nil
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
end

local function FindBestTarget()
    local vp = Camera.ViewportSize
    local center = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
    local best, bestD = nil, math.huge
    local pf = workspace:FindFirstChild("PLAYERS")
    if not pf then return nil end
    local af = pf:FindFirstChild("ALIVE")
    if not af then return nil end
    
    for _, m in ipairs(af:GetChildren()) do
        if m.Name == LP.Name then continue end
        local hrp = m:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local sp, vis = Camera:WorldToViewportPoint(hrp.Position)
        if not vis or sp.Z < 0 then continue end
        local sd = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if sd > S.CamFOV then continue end
        local mc = LP.Character
        local mr = mc and mc:FindFirstChild("HumanoidRootPart")
        local wd = mr and (hrp.Position - mr.Position).Magnitude or sd
        if wd < bestD then
            bestD = wd
            best = hrp
        end
    end
    return best
end

local function CamLockStart(track)
    local target = FindBestTarget()
    if not target then return end
    camLockTarget = target
    camLockActive = true
    Camera.CameraType = Enum.CameraType.Scriptable
    local conn
    conn = track.Stopped:Connect(function()
        conn:Disconnect()
        if camLockTarget == target then CamLockStop() end
    end)
end

RunService.RenderStepped:Connect(function()
    if not camLockActive then return end
    if not AnyCamLockOn() then
        CamLockStop()
        return
    end
    if not camLockTarget or not camLockTarget.Parent then
        CamLockStop()
        return
    end
    
    Camera.CameraType = Enum.CameraType.Scriptable
    local goal = CFrame.new(Camera.CFrame.Position, camLockTarget.Position + Vector3.new(0, 2, 0))
    Camera.CFrame = Camera.CFrame:Lerp(goal, 0.2)
end)

local hookedKillers = {}
local function HookKiller(km)
    if not km or hookedKillers[km] then return end
    hookedKillers[km] = true
    local hum = km:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    hum.AnimationPlayed:Connect(function(track)
        if not track or not track.Animation then return end
        local cfg = CAM_ANIMS[track.Animation.AnimationId]
        if not cfg then return end
        if not S[cfg.key] then return end
        if cfg.stop then
            CamLockStop()
        else
            CamLockStart(track)
        end
    end)
    
    km.AncestryChanged:Connect(function()
        if not km.Parent then hookedKillers[km] = nil end
    end)
end

