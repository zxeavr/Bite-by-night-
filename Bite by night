-- DELETE DOOR (FIX: persistent loop on confirmed path workspace.MAPS["GAME MAP"].Doors)
local doorTask = nil; local doorWatchConn = nil
local function ProcessDoors(canCol)
    pcall(function()
        local maps = workspace:FindFirstChild("MAPS"); if not maps then return end
        local gm = maps:FindFirstChild("GAME MAP"); if not gm then return end
        local doorsF = gm:FindFirstChild("Doors"); if not doorsF then return end
        for _, part in ipairs(doorsF:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = canCol; part.CanTouch = canCol end
        end
    end)
