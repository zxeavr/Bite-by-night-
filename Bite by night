local function ApplyScale(v)
    S.UIScale = v
    pcall(function()
        for _, guiName in ipairs({"PhantomHub","WindUI"}) do
            for _, parent in ipairs({LP.PlayerGui, game:GetService("CoreGui")}) do
                local gui = parent:FindFirstChild(guiName)
