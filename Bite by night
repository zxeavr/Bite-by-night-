local function CamLockStop()
    camLockActive = false
    camLockTarget = nil
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
    Log("CamLock STOPPED")
end

-- Find nearest target inside FOV circle (from ALIVE folder)
local function FindBestTarget()
    local vp = Camera.ViewportSize
    local center = Vector2.new(vp.X*0.5, vp.Y*0.5)
    local best, bestDist = nil, math.huge
    local pf = workspace:FindFirstChild("PLAYERS")
    local af = pf and pf:FindFirstChild("ALIVE")
    if not af then return nil end
    for _, m in ipairs(af:GetChildren()) do
        if m.Name == LP.Name then continue end
        local hrp = m:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local sp, vis = Camera:WorldToViewportPoint(hrp.Position)
        if not vis or sp.Z < 0 then continue end
        -- Check inside FOV circle
        local screenDist = (Vector2.new(sp.X,sp.Y) - center).Magnitude
        if screenDist > S.CamFOV then continue end
        -- Also check world distance for proximity
        local myChar = LP.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local worldDist = myRoot and (hrp.Position - myRoot.Position).Magnitude or screenDist
        if worldDist < bestDist then
            bestDist = worldDist
            best = hrp
        end
    end
    return best
end

local function CamLockStart(track)
    local target = FindBestTarget()
    if not target then
        Log("CamLock: no target in FOV")
        return
    end
    camLockTarget = target
    camLockActive = true
    Camera.CameraType = Enum.CameraType.Scriptable
    Log("CamLock STARTED on " .. tostring(target.Parent and target.Parent.Name))
    -- Auto-stop when animation finishes
    local conn; conn = track.Stopped:Connect(function()
        conn:Disconnect()
        if camLockTarget == target then CamLockStop() end
    end)
end

-- Smooth cam lock tracking - runs every frame
RunService.RenderStepped:Connect(function()
    if not camLockActive then return end
    if not AnyCamLockOn() then CamLockStop(); return end
    if not camLockTarget or not camLockTarget.Parent then CamLockStop(); return end
    -- Smooth follow: Lerp toward target
    Camera.CameraType = Enum.CameraType.Scriptable
    local goal = CFrame.new(Camera.CFrame.Position, camLockTarget.Position + Vector3.new(0, 2, 0))
    Camera.CFrame = Camera.CFrame:Lerp(goal, 0.2)
end)

-- Hook killer animations
local hookedKillers = {}
local function HookKiller(km)
    if not km or hookedKillers[km] then return end
    hookedKillers[km] = true
    local hum = km:FindFirstChildOfClass("Humanoid"); if not hum then return end
    hum.AnimationPlayed:Connect(function(track)
        if not track or not track.Animation then return end
        local cfg = CAM_ANIMS[track.Animation.AnimationId]
        if not cfg then return end
        if not S[cfg.key] then return end
        if cfg.stop then CamLockStop() else CamLockStart(track) end
    end)
    km.AncestryChanged:Connect(function()
        if not km.Parent then hookedKillers[km] = nil end
    end)
end
