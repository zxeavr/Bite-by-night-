		R.ParryDynamic = TbMain:Toggle({Title="Dynamic Size",         Value=S.ParryDynamic, Callback=function(v) S.ParryDynamic=v end})
		R.ParryRainbow = TbMain:Toggle({Title="Rainbow",              Value=S.ParryRainbow, Callback=function(v) S.ParryRainbow=v end})
		TbMain:Colorpicker({Title="Visualizer Color",Default=S.ParryColor,Callback=function(c) S.ParryColor=c end})
		TbMain:Slider({Title="Transparency",Step=0.05,Value={Min=0,Max=0.95,Default=0.5},Callback=function(v) S.ParryAlpha=v end})
		TbMain:Divider()
		R.AutoShakeWire = TbMain:Toggle({Title="Auto Shake Wire Eye", Value=S.AutoShakeWire, Callback=function(v) S.AutoShakeWire=v; SetAutoShakeWire(v) end})
		TbMain:Slider({Title="Shake Cooldown",Step=0.1,Value={Min=0.1,Max=3,Default=0.5},Callback=function(v) S.ShakeSpeed=v end})
	end

	-- IS Main
	if currentPlace == PLACE_IS then
		local R = uiRefs
		R.HitboxExpander = TbMain:Toggle({Title="Hitbox Expander", Value=S.HitboxExpander, Callback=function(v) S.HitboxExpander=v end})
		TbMain:Slider({Title="Hitbox Scale",Step=0.1,Value={Min=1,Max=5,Default=1.5},Callback=function(v) S.HitboxScale=v end})
		TbMain:Dropdown({Title="Shape",Values={"Box","Sphere","Triangle"},Value=S.HitboxShape,Multi=false,Callback=function(v) S.HitboxShape=v end})
		TbMain:Colorpicker({Title="Color",Default=S.HitboxColor,Callback=function(c) S.HitboxColor=c end})
		TbMain:Slider({Title="Transparency",Step=0.05,Value={Min=0,Max=1,Default=0.5},Callback=function(v) S.HitboxTransparency=v end})
		R.HitboxRainbow = TbMain:Toggle({Title="Rainbow", Value=S.HitboxRainbow, Callback=function(v) S.HitboxRainbow=v end})
		TbMain:Divider()
		R.WalkSpeedEnabled = TbMain:Toggle({Title="Custom Walk Speed", Value=S.WalkSpeedEnabled, Callback=function(v) S.WalkSpeedEnabled=v end})
		TbMain:Slider({Title="Walk Speed",Step=1,Value={Min=0,Max=50,Default=16},Callback=function(v) S.WalkSpeedValue=v end})
		TbMain:Divider()
		R.AutoGetWeapon = TbMain:Toggle({Title="Auto Get Weapon (Teleport&Return)", Value=S.AutoGetWeapon, Callback=function(v) S.AutoGetWeapon=v end})
		TbMain:Divider()
		R.NoCooldown = TbMain:Toggle({Title="No Cooldown (all weapons)", Value=S.NoCooldown, Callback=function(v) S.NoCooldown=v end})
		TbMain:Divider()
		R.AutoInfectious = TbMain:Toggle({Title="Auto Infectious (nearest)", Value=S.AutoInfectious, Callback=function(v) S.AutoInfectious=v end})
		TbMain:Divider()
		R.DeleteDoorSmart = TbMain:Toggle({Title="Smart Delete Doors (with prompt)", Value=S.DeleteDoorSmart, Callback=function(v) S.DeleteDoorSmart=v end})
		TbMain:Divider()
		R.AntiStun = TbMain:Toggle({Title="Anti Stun", Value=S.AntiStun, Callback=function(v) S.AntiStun=v end})
	end

	-- Visual tab (common)
	do
		TbVisual:Slider({Title="Field of View",Step=1,Value={Min=10,Max=100,Default=70},Callback=function(v) SetFOV(v) end})
		TbVisual:Toggle({Title="Full Bright", Value=S.FullBright, Callback=function(v) S.FullBright=v; SetFullBright(v) end})
		TbVisual:Toggle({Title="No Fog",      Value=S.NoFog,      Callback=function(v) S.NoFog=v; Lighting.FogEnd = v and 1e9 or 100000; Lighting.FogStart = v and 1e9 or 0 end})
		TbVisual:Toggle({Title="No Shadow",   Value=S.NoShadow,   Callback=function(v) S.NoShadow=v; Lighting.GlobalShadows = not v end})
		if currentPlace == PLACE_BBN then
			TbVisual:Divider()
			TbVisual:Dropdown({Title="ESP Type",Values={"Highlight","Chams","Name","Dot"},Value=S.ESPMode,Multi=false,Callback=function(v) S.ESPMode=v end})
			uiRefs.ESPHealth = TbVisual:Toggle({Title="Health ESP", Value=S.ESPHealth, Callback=function(v) S.ESPHealth=v end})
			uiRefs.ShowGenProgress = TbVisual:Toggle({Title="Show Gen Progress %", Value=S.ShowGenProgress, Callback=function(v) S.ShowGenProgress=v end})
			for _,row in ipairs({{"Killer","Killer"},{"Survivor","Survivor"},{"Generator","Generator"},{"Battery","Battery"},{"Fuse","Fuse"},{"Trap","Trap"},{"WireEye","Wire Eye"}}) do
				local key,label = row[1], row[2]
				uiRefs["T."..key..".On"] = TbVisual:Toggle({Title="ESP "..label, Value=S.T[key].On, Callback=function(v) S.T[key].On=v end})
				TbVisual:Colorpicker({Title=label.." Color",Default=S.T[key].Color,Callback=function(c) S.T[key].Color=c end})
			end
		end
	end

	-- BBN Cam Lock & Farm
	if currentPlace == PLACE_BBN then
		-- Cam Lock
		local R = uiRefs
		R.CamLockRotten = TbKiller:Toggle({Title="Rotten Axe Charge", Value=S.CamLockRotten, Callback=function(v) S.CamLockRotten=v end})
		TbKiller:Divider()
		R.CamLockDoppelPull = TbKiller:Toggle({Title="Doppelganger Pull", Value=S.CamLockDoppelPull, Callback=function(v) S.CamLockDoppelPull=v end})
		R.CamLockDoppelStab = TbKiller:Toggle({Title="Doppelganger Stab", Value=S.CamLockDoppelStab, Callback=function(v) S.CamLockDoppelStab=v end})
		TbKiller:Divider()
		R.CamLockMimicGrab  = TbKiller:Toggle({Title="Mimic Grab", Value=S.CamLockMimicGrab, Callback=function(v) S.CamLockMimicGrab=v end})
		R.CamLockMimicJump  = TbKiller:Toggle({Title="Mimic Jump", Value=S.CamLockMimicJump, Callback=function(v) S.CamLockMimicJump=v end})
		TbKiller:Divider()
		R.CamLockM1 = TbKiller:Toggle({Title="M1 All Killers", Value=S.CamLockM1, Callback=function(v) S.CamLockM1=v end})
		TbKiller:Divider()
		R.ShowFOV = TbKiller:Toggle({Title="Show FOV Circle", Value=S.ShowFOV, Callback=function(v) S.ShowFOV=v end})
		TbKiller:Colorpicker({Title="FOV Color",Default=S.FovColor,Callback=function(c)
			S.FovColor=c; local st = fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if st then st.Color=c end
		end})
		TbKiller:Slider({Title="FOV Radius",Step=5,Value={Min=30,Max=300,Default=120},Callback=function(v) S.CamFOV=v end})
		TbKiller:Slider({Title="FOV Transparency",Step=0.05,Value={Min=0,Max=0.95,Default=0},Callback=function(v)
			S.FovAlpha=v; local st = fovFrame and fovFrame:FindFirstChildOfClass("UIStroke"); if st then st.Transparency=v end
		end})
		TbKiller:Button({Title="Lock Nearest", Callback=function()
			local t = FindBestTarget()
			if t then camLockTarget=t; camLockActive=true; Camera.CameraType=Enum.CameraType.Scriptable; N("Cam Lock","Locked",2)
			else N("Cam Lock","No target",2) end
		end})
		TbKiller:Button({Title="Release Lock", Callback=function() CamLockStop(); N("Cam Lock","Released",2) end})

		-- Farm
		uiRefs.FarmMode = TbFarm:Dropdown({Title="Move Mode",Values={"TP","Tween"},Value=S.FarmMode,Callback=function(v) S.FarmMode=v end})
		TbFarm:Slider({Title="Move Speed",Step=5,Value={Min=10,Max=100,Default=30},Callback=function(v) S.FarmSpeed=v end})
		uiRefs.FarmUnderground = TbFarm:Toggle({Title="Underground Safe Mode",Value=S.FarmUnderground,Callback=function(v) S.FarmUnderground=v end})
		TbFarm:Button({Title="Complete Generators Now", Callback=function() task.spawn(CompleteAllGenerators) end})
		uiRefs.AutoFarm = TbFarm:Toggle({Title="Auto Farm (loop)", Value=S.AutoFarm, Callback=function(v) S.AutoFarm=v; SetAutoFarm(v) end})
	end

	-- Config & Settings (common)
	do
		local cfgInput = ""; local selCfg = nil
		local cfgDD = TbConfig:Dropdown({Title="Select Config",Values={"(none)"},Value=nil,Multi=false,Callback=function(v) selCfg=v end})
		local function RefreshDD() local l=ListCfgs(); if #l>0 then cfgDD:Refresh(l); selCfg=l[1] else cfgDD:Refresh({"(none)"}) end end
		TbConfig:Input({Title="Config Name",Placeholder="v1",Callback=function(t) cfgInput = t end})
		TbConfig:Button({Title="Create Config", Callback=function()
			if cfgInput=="" then return end
			SaveCfg(cfgInput); RefreshDD(); N("Config","Saved: "..cfgInput,2,"check")
		end})
		TbConfig:Button({Title="Load Config", Callback=function()
			if not selCfg or selCfg=="(none)" then return end
			LoadCfg(selCfg); N("Config","Loaded: "..selCfg,2,"folder")
		end})
		local autoLoad = GetAutoLoad()
		TbConfig:Toggle({Title="Auto Load on Start",Value=autoLoad~=nil,Callback=function(v)
			if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
		end})
	end
	do
		TbSettings:Slider({Title="UI Scale",Step=0.05,Value={Min=0.7,Max=1.5,Default=1.0},Callback=function(v) ApplyScale(v) end})
		TbSettings:Slider({Title="UI Transparency",Step=0.05,Value={Min=0,Max=0.9,Default=0},Callback=function(v) ApplyAlpha(v) end})
		TbSettings:Toggle({Title="Anti-AFK",Value=S.AntiAFK,Callback=function(v) S.AntiAFK=v; SetAntiAFK(v) end})
		TbSettings:Toggle({Title="FPS Booster",Value=S.FPSBooster,Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end})
		TbSettings:Keybind({Title="Toggle UI",Value="RightControl",Callback=function(k) pcall(function() Window:SetToggleKey(Enum.KeyCode[k]) end) end})
		TbSettings:Button({Title="Switch Language (EN/AR)",Callback=function() LANG = LANG=="en" and "ar" or "en"; N("Language",LANG,2,"globe") end})
	end

	-- Apply scale after a delay
	task.delay(0.9, function() ApplyScale(S.UIScale) end)

	-- Character respawn
	LP.CharacterAdded:Connect(function()
		task.wait(1); RefreshChar()
		if currentPlace == PLACE_BBN then
			ConnectStamina(); ConnectAntiDie()
			if S.NoClip then SetNoClip(true) end
			if S.AllowJump then SetAllowJump(true) end
			if S.AutoRun then SetAutoRun(true) end
			if S.AutoParry then SetAutoParry(true) end
			if S.AntiTrap then SetAntiTrap(true) end
			SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
		end
	end)

	N("Phantom Hub v8.0","Loaded "..(currentPlace==PLACE_BBN and "Bite By Night" or "Infectious Smile"),5,"moon")
end

-- Boot sequence
ShowLoadingScreen(function() ShowLangGUI(function() BuildWindow() end) end)
