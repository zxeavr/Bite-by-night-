-- ============================================================
-- PERFORMANCE MANAGER
-- ============================================================
local PerfManager = {
    connections = {},
    lastCache   = 0,
    cacheRate   = 2.5,
    cache       = {
        generators = {},
        gates      = {},
        hooks      = {},
        pallets    = {},
        windows    = {},
        pumpkins   = {},
    }
}

function PerfManager:Connect(name, conn)
    self.connections[name] = conn
end

function PerfManager:Disconnect(name)
    if self.connections[name] then
        pcall(function() self.connections[name]:Disconnect() end)
        self.connections[name] = nil
    end
end

function PerfManager:CacheMap()
    local now = tick()
    if now - self.lastCache < self.cacheRate then return end
    self.lastCache = now
    
    local map = Workspace:FindFirstChild("Map")
    if not map then return end
    
    local newCache = {generators={}, gates={}, hooks={}, pallets={}, windows={}, pumpkins={}}
    
    for _, obj in ipairs(map:GetDescendants()) do
        if obj:IsA("Model") then
            local part = obj:FindFirstChildWhichIsA("BasePart")
            if part then
                if obj.Name == "Generator" then
                    table.insert(newCache.generators, {model=obj, part=part})
                elseif obj.Name == "Gate" then
                    table.insert(newCache.gates, {model=obj, part=part})
                elseif obj.Name == "Hook" then
                    table.insert(newCache.hooks, {model=obj, part=part})
                elseif obj.Name == "Palletwrong" or obj.Name:lower():find("pallet") then
                    table.insert(newCache.pallets, {model=obj, part=part})
                elseif obj.Name == "Window" then
                    table.insert(newCache.windows, {model=obj, part=part})
                end
            end
        end
    end
    
    local pumpkins = map:FindFirstChild("Pumpkins")
    if pumpkins then
        for _, obj in ipairs(pumpkins:GetDescendants()) do
            if obj:IsA("Model") and obj.Name:find("Pumpkin") then
                local part = obj:FindFirstChildWhichIsA("BasePart")
                if part then table.insert(newCache.pumpkins, {model=obj, part=part}) end
            end
        end
    end
    
    self.cache = newCache
end

-- Apply performance settings
local function ApplyPerfSettings()
    if Config.Perf.DisableParticles then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
                pcall(function() obj.Enabled = false end)
            end
        end
    end
    if Config.Perf.LowerGraphics then
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    end
    if Config.Perf.DisableShadows then
        pcall(function() Lighting.GlobalShadows = false end)
    end
    if Config.Perf.ReduceRenderDist then
        pcall(function()
            Workspace.StreamingEnabled = true
            Workspace.StreamingMinRadius = 32
            Workspace.StreamingTargetRadius = 64
        end)
    end
end

-- ============================================================
-- SAFE TELEPORT (BBN-style lerp)
-- ============================================================
local function SafeTeleport(targetCF, offset)
    offset = offset or Vector3.new(0, Config.TP.Offset, 0)
    if not LPChar then return false end
    local hrp = LPRoot; if not hrp then return false end
    
    if Config.TP.Safe then
        for _, part in ipairs(LPChar:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    
    hrp.CFrame = targetCF + offset
    
    if Config.TP.Safe then
        task.delay(0.3, function()
            if LPChar then
                for _, part in ipairs(LPChar:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = true
                    end
                end
            end
        end)
    end
    return true
end

-- ============================================================
-- ESP ENGINE (Optimized Hybrid: BBN + VD)
-- ============================================================
local ESP = {
    objects = {},      -- [instance] = {highlight, billboard, ...}
    playerCache = {},
    objectCount = 0,
    lastUpdate = 0,
}

local function CreateESPObject(target, color, label)
    if not target or not target.Parent then return nil end
    if ESP.objects[target] then return ESP.objects[target] end
    if ESP.objectCount >= Config.Perf.MaxESPObjects then return nil end
    
    local data = {target = target, valid = true}
    
    -- Highlight (BBN style)
    if Config.ESP.UseHighlight then
        local hl = Instance.new("Highlight")
        hl.Name = "PH_ESP"
        hl.Adornee = target
        hl.FillColor = color
        hl.OutlineColor = color
        hl.FillTransparency = 0.55
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = target
        data.highlight = hl
    end
    
    -- Billboard
    local root = target:IsA("Model") and (target:FindFirstChild("HumanoidRootPart") or target:FindFirstChildWhichIsA("BasePart")) or target
    if root then
        local bb = Instance.new("BillboardGui")
        bb.Name = "PH_ESP_Label"
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.AlwaysOnTop = true
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.Adornee = root
        bb.MaxDistance = Config.ESP.MaxDistance
        bb.Parent = target
        
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = color
        lbl.TextStrokeColor3 = Color3.new(0, 0, 0)
        lbl.TextStrokeTransparency = 0
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 14
        lbl.Text = label
        lbl.Parent = bb
        
        data.billboard = bb
        data.label = lbl
        data.root = root
    end
    
    -- Cleanup connection
    data.conn = target.AncestryChanged:Connect(function()
        if target.Parent then return end
        ESP:Remove(target)
    end)
    
    ESP.objects[target] = data
    ESP.objectCount = ESP.objectCount + 1
    return data
end

function ESP:Remove(target)
    local data = self.objects[target]
    if not data then return end
    data.valid = false
    pcall(function() if data.highlight then data.highlight:Destroy() end end)
    pcall(function() if data.billboard then data.billboard:Destroy() end end)
    pcall(function() if data.conn then data.conn:Disconnect() end end)
    self.objects[target] = nil
    self.objectCount = self.objectCount - 1
end

function ESP:Clear()
    for target, _ in pairs(self.objects) do self:Remove(target) end
end

function ESP:UpdatePlayer(player, color, label)
    if not Config.Types[label] and label ~= "Killer" and label ~= "Survivor" then return end
    if not player.Character then return end
    if player == LP then return end
    
    local char = player.Character
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Distance culling
    if Config.Perf.UseDistanceCulling and LPRoot then
        local dist = (root.Position - LPRoot.Position).Magnitude
        if dist > Config.ESP.MaxDistance then
            if self.objects[char] then self:Remove(char) end
            return
        end
    end
    
    local data = self.objects[char]
    if not data then
        data = CreateESPObject(char, color, player.Name)
        if not data then return end
    end
    
    -- Update label
    if data.label then
        local text = player.Name
        if label == "Killer" then text = text .. " [KILLER]" else text = text .. " [SURVIVOR]" end
        if Config.ESP.ShowHealth and hum then
            text = text .. "\n" .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
        end
        if Config.ESP.ShowDistance and LPRoot then
            text = text .. "\n" .. math.floor((root.Position - LPRoot.Position).Magnitude) .. "m"
        end
        data.label.Text = text
        data.label.TextColor3 = color
    end
    
    if data.highlight then
        data.highlight.FillColor = color
        data.highlight.OutlineColor = color
    end
end

function ESP:UpdateObject(objData, color, label)
    if not Config.Types[label] then return end
    local obj = objData.model
    local part = objData.part
    if not part or not part.Parent then return end
    
    if Config.Perf.UseDistanceCulling and LPRoot then
        local dist = (part.Position - LPRoot.Position).Magnitude
        if dist > Config.ESP.MaxDistance then
            if self.objects[obj] then self:Remove(obj) end
            return
        end
    end
    
    local data = self.objects[obj]
    if not data then
        data = CreateESPObject(obj, color, label)
        if not data then return end
    end
    
    if data.label then
        local text = label
        if Config.ESP.ShowDistance and LPRoot then
            text = text .. "\n" .. math.floor((part.Position - LPRoot.Position).Magnitude) .. "m"
        end
        data.label.Text = text
        data.label.TextColor3 = color
    end
    if data.highlight then
        data.highlight.FillColor = color
        data.highlight.OutlineColor = color
    end
end

function ESP:Step()
    local now = tick()
    if now - self.lastUpdate < Config.ESP.UpdateRate then return end
    self.lastUpdate = now
    
    -- Cache map objects
    PerfManager:CacheMap()
    
    -- Players
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LP then continue end
        if player.Team then
            local team = player.Team.Name
            if team == "Killer" and Config.Types.Killer then
                self:UpdatePlayer(player, Config.Colors.Killer, "Killer")
            elseif team == "Survivors" and Config.Types.Survivor then
                self:UpdatePlayer(player, Config.Colors.Survivor, "Survivor")
            end
        end
    end
    
    -- Objects
    for _, data in ipairs(PerfManager.cache.generators) do
        self:UpdateObject(data, Config.Colors.Generator, "Generator")
    end
    for _, data in ipairs(PerfManager.cache.gates) do
        self:UpdateObject(data, Config.Colors.Gate, "Gate")
    end
    for _, data in ipairs(PerfManager.cache.hooks) do
        self:UpdateObject(data, Config.Colors.Hook, "Hook")
    end
    for _, data in ipairs(PerfManager.cache.pallets) do
        self:UpdateObject(data, Config.Colors.Pallet, "Pallet")
    end
    for _, data in ipairs(PerfManager.cache.windows) do
        self:UpdateObject(data, Config.Colors.Window, "Window")
    end
    for _, data in ipairs(PerfManager.cache.pumpkins) do
        self:UpdateObject(data, Config.Colors.Pumpkin, "Pumpkin")
    end
    
    -- Cleanup invalid
    for target, data in pairs(self.objects) do
        if not data.valid or not target.Parent then
            self:Remove(target)
        end
    end
end

