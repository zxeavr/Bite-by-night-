-- IS: AUTO INFECTIOUS (teleport to nearest Infector)
local IS_infectThread
local function IS_FindNearestInfector()
    local hrp=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return nil,nil end
    local infectors=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Infectors")
    if not infectors then return nil,nil end
    local best,bestPart,bestD=nil,nil,math.huge
    for _,inf in ipairs(infectors:GetChildren()) do
        local part=inf:FindFirstChild("Part") or inf:FindFirstChildOfClass("BasePart")
        if part then
            local d=(part.Position-hrp.Position).Magnitude
            if d<bestD then bestD=d; best=inf; bestPart=part end
        end
    end
    return best,bestPart
end
