local function FullGenBreak()
    if not CFG.KILLER_FullGenBreak or GetRole() ~= "Killer" then return end
    if tick() - State.LastGenBreak < 0.3 then return end
    local root = GetRoot()
    if not root then return end
    SafeCall(function()
        local rem = ReplicatedStorage:FindFirstChild("Remotes")
        local gen = rem and rem:FindFirstChild("Generator")
        local ev = gen and gen:FindFirstChild("BreakGenEvent")
        if ev then
            local map = workspace:FindFirstChild("Map")
            if map then
                for _, obj in ipairs(map:GetDescendants()) do
                    if obj.Name:lower():find("generator") then
                        local gp = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                        if gp and (gp.Position - root.Position).Magnitude <= 15 then
                            ev:FireServer(obj); State.LastGenBreak = tick()
                        end
                    end
                end
            end
        end
    end)
end

