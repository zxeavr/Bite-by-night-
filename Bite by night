    end

    -- CONFIG TAB (same for both games)
    local cfgTabRef = Window:Tab({Title="Config",Icon="folder"})
    do
        local cfgInput=""; local selCfg=nil; local cfgDD=nil
        cfgTabRef:Input({Title="Config Name",Placeholder="v1",Callback=function(t) if t and t~="" then cfgInput=t end end})
        cfgTabRef:Button({Title="Save Config",Callback=function()
            if cfgInput=="" then return end
            if SaveCfg(cfgInput) then local l=ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end; N("Config","Saved: "..cfgInput,3,"check") end
        end})
        local iL=ListCfgs()
        cfgDD=cfgTabRef:Dropdown({Title="Select Config",Values=#iL>0 and iL or {"(none)"},Value=iL[1] or nil,Multi=false,AllowNone=true,Callback=function(v) selCfg=v end})
        if #iL>0 then selCfg=iL[1] end
        cfgTabRef:Button({Title="Load Config",Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            local n=LoadCfg(selCfg); if not n then return end
            S_Debug=S.DebugHelpers; ConnectStamina()
            if GAME_BBN then SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap); SetAutoEscape(S.AutoEscape); SetBarricade(S.AutoBarricade)
                SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
                if S.AllowJump then SetAllowJump(true) end; if S.AutoRun then SetAutoRun(true) end
                if S.DeleteDoor then SetDeleteDoor(true) end; if S.SkipCutscene then SetSkipCutscene(true) end
                if S.AutoPhase then SetAutoPhase(true) end; if S.InstantGen then StartInstantGen() end
                if S.FullBright then SetFullBright(true) end; if S.NoBlind then SetNoBlind(true) end
                if S.HideGenGui then SetHideGenGui(true) end; if S.InstantPrompt then SetInstantPrompt(true) end
                if S.AutoFarm then SetAutoFarm(true) end; if S.AutoParry then SetAutoParry(true) end
                if S.AutoShakeWire then SetWireShake(true) end
            else
                IS_SetAntiStun(S.IS_AntiStun); IS_SetNoCooldown(S.IS_NoCooldown)
                IS_SetAutoGetWeapon(S.IS_AutoGetWeapon); IS_SetAutoInfect(S.IS_AutoInfect)
                IS_SetAntiInfect(S.IS_AntiInfect); IS_SetDisableKillbricks(S.IS_DisableKillbricks)
                IS_SetHitbox(S.IS_HitboxOn); if S.IS_WalkSpeed~=16 then IS_SetWalkSpeed(S.IS_WalkSpeed) end
                if S.FullBright then SetFullBright(true) end
            end
            SetFPSBooster(S.FPSBooster); SetAntiAFK(S.AntiAFK)
            if S.FovValue~=70 then SetFOV(S.FovValue) end
            ConnectAntiDie(); N("Config","Loaded: "..tostring(n),3,"folder")
        end})
        cfgTabRef:Divider()
        local cA=GetAutoLoad()
        cfgTabRef:Toggle({Title="Auto Load on Start",Value=cA~=nil,Callback=function(v)
            if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
        end})
        cfgTabRef:Button({Title="Delete Selected",Callback=function()
            if not selCfg or selCfg=="(none)" then return end
            pcall(function() if delfile then delfile(CFG_FOLDER.."/"..selCfg..".json") end end)
            local l=ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end; selCfg=nil
        end})
    end

    -- SETTINGS TAB
    local TbSetFinal=Window:Tab({Title="Settings",Icon="sliders-horizontal"})
    do
        TbSetFinal:Slider({Title="UI Scale",Step=0.05,Value={Min=0.7,Max=1.5,Default=1.0},Callback=function(v) ApplyScale(v) end})
        TbSetFinal:Slider({Title="UI Transparency",Step=0.05,Value={Min=0,Max=0.9,Default=0},Callback=function(v) ApplyAlpha(v) end})
        TbSetFinal:Divider()
        uiRefs.AntiAFK=TbSetFinal:Toggle({Title="Anti-AFK",  Value=S.AntiAFK,    Callback=function(v) S.AntiAFK=v; SetAntiAFK(v) end})
        uiRefs.FPSBooster=TbSetFinal:Toggle({Title="FPS Booster",Value=S.FPSBooster,Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end})
        TbSetFinal:Keybind({Title="Toggle UI",Value="RightControl",Callback=function(k) pcall(function() Window:SetToggleKey(Enum.KeyCode[k]) end) end})
        TbSetFinal:Divider()
        uiRefs.DebugHelpers=TbSetFinal:Toggle({Title="Debug Helpers (open Delta console)",Value=S.DebugHelpers,Callback=function(v)
            S.DebugHelpers=v; S_Debug=v
            if v then
                print("[PH Helper] Debug ON - open Delta console")
                if GAME_BBN then
                    print("[PH Helper] Anti Trap: walk into trap → '[TRAP] Tag added: Trapped'")
                    print("[PH Helper] Auto Farm: enable → gen info appears here")
                    print("[PH Helper] Anti Stun: get stunned → cleared tags appear here")
                else
                    print("[PH Helper] IS: enable features and actions appear here")
                end
            else print("[PH Helper] Debug OFF") end
        end})
        TbSetFinal:Divider()
        TbSetFinal:Button({Title="Switch Language (EN/AR) [re-exec]",Callback=function() N("Language","Switch → re-execute for full effect",4,"globe") end})
    end

    -- INITIALIZE
    if GAME_BBN then
        ConnectStamina(); SetAntiAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap); SetAntiStun(S.AntiStun)
        SetAntiRagdoll(S.AntiRagdoll)
        if S.AllowJump      then SetAllowJump(true)    end
        -- FIX: ONLY start AutoRun if explicitly ON
        if S.AutoRun        then SetAutoRun(true)       end
        -- NEVER call SetAutoRun(false) on start - it does nothing now
        if S.DeleteDoor     then SetDeleteDoor(true)    end
        if S.SkipCutscene   then SetSkipCutscene(true)  end
        if S.AutoPhase      then SetAutoPhase(true)     end
        if S.InstantGen     then StartInstantGen()      end
        if S.FullBright     then SetFullBright(true)    end
        if S.NoBlind        then SetNoBlind(true)       end
        if S.HideGenGui     then SetHideGenGui(true)    end
        if S.InstantPrompt  then SetInstantPrompt(true) end
        if S.AutoBarricade  then SetBarricade(true)     end
        if S.AutoEscape     then SetAutoEscape(true)    end
        if S.AutoFarm       then SetAutoFarm(true)      end
        if S.AutoParry      then SetAutoParry(true)     end
        if S.AutoShakeWire  then SetWireShake(true)     end
        LP.CharacterAdded:Connect(function()
            task.wait(1); RefreshChar(); ConnectStamina(); ConnectAntiDie()
            if S.NoClip    then SetNoClip(true)    end
            if S.AllowJump then SetAllowJump(true) end
            if S.AutoRun   then SetAutoRun(true)   end
            if S.AutoParry then SetAutoParry(true) end
            if S.AntiTrap  then SetAntiTrap(true)  end
            SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
            if S.AutoPhase then SetAutoPhase(true) end
            task.wait(1); pcall(function()
                local kf=workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("KILLER")
                if kf then for _,m in ipairs(kf:GetChildren()) do
                    local hookedK={}; local function HookK2(km) if not km or hookedK[km] then return end; hookedK[km]=true
                        local hum=km:FindFirstChildOfClass("Humanoid"); if not hum then return end
                        hum.AnimationPlayed:Connect(function(track) if not track or not track.Animation then return end
                            local cfg=CAM_ANIMS[track.Animation.AnimationId]; if not cfg then return end
                            if not S[cfg.key] then return end; if cfg.stop then CamStop() else CamStart(track) end
                        end)
                    end; HookK2(m)
                end end
            end)
        end); ConnectAntiDie()
    else
        -- IS INIT
        IS_SetAntiStun(S.IS_AntiStun); IS_SetNoCooldown(S.IS_NoCooldown)
        IS_SetAutoGetWeapon(S.IS_AutoGetWeapon); IS_SetAutoInfect(S.IS_AutoInfect)
        IS_SetAntiInfect(S.IS_AntiInfect); IS_SetDisableKillbricks(S.IS_DisableKillbricks)
        IS_SetHitbox(S.IS_HitboxOn)
        if S.IS_WalkSpeed~=16 then IS_SetWalkSpeed(S.IS_WalkSpeed) end
        if S.FullBright then SetFullBright(true) end
        LP.CharacterAdded:Connect(function()
            task.wait(1); RefreshChar()
            IS_SetAntiStun(S.IS_AntiStun); IS_SetNoCooldown(S.IS_NoCooldown)
            IS_SetAutoGetWeapon(S.IS_AutoGetWeapon); IS_SetAutoInfect(S.IS_AutoInfect)
            if S.IS_WalkSpeed~=16 then IS_SetWalkSpeed(S.IS_WalkSpeed) end
        end)
    end
    SetFPSBooster(S.FPSBooster); SetAntiAFK(S.AntiAFK)
    if S.FovValue~=70 then SetFOV(S.FovValue) end
    task.delay(0.9,function() ApplyScale(S.UIScale); ApplyAlpha(S.UIAlpha) end)
    task.wait(1.5); N("Phantom Hub  v7.6 R5","By 7k.u  —  "..(GAME_BBN and "BBN" or "IS").."  Ready",5,"moon")
end

ShowLoadingScreen(function() ShowLangGUI(function() BuildWindow() end) end)
