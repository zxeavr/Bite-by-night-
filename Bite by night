local function SetDeleteDoor(on)
    if doorTask then pcall(task.cancel, doorTask); doorTask = nil end
    if doorWatchConn then doorWatchConn:Disconnect(); doorWatchConn = nil end
    if on then
        ProcessDoors(false)
        doorTask = task.spawn(function()
            while S.DeleteDoor do task.wait(0.5); ProcessDoors(false) end
        end)
        doorWatchConn = workspace.DescendantAdded:Connect(function(d)
            if not S.DeleteDoor or not d:IsA("BasePart") then return end
            pcall(function()
                local maps = workspace:FindFirstChild("MAPS"); if not maps then return end
                local gm = maps:FindFirstChild("GAME MAP"); if not gm then return end
                local doorsF = gm:FindFirstChild("Doors")
                if doorsF and d:IsDescendantOf(doorsF) then d.CanCollide = false; d.CanTouch = false end
            end)
        end)
    else
        ProcessDoors(true)
    end
end

