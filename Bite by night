    local function ProcessFolder(folder, key, label, maxDist)
        if not folder then return end
        for _, obj in ipairs(folder:GetChildren()) do
            if obj.Name == LP.Name then continue end
            if obj:IsA("Model") or obj:IsA("BasePart") then ApplyESP(obj, S.T[key], label, maxDist, false) end
        end
    end
    task.spawn(function()
        while task.wait(0.08) do
            local anyOn = S.ESPHealth or S.ShowGenProgress
