function VisualMods:SetNoFog(state)
    Config.Visual.NoFog = state
    if self.fogConn then pcall(function() self.fogConn:Disconnect() end); self.fogConn = nil end
    if not state then
        pcall(function()
            Lighting.FogEnd = self.orig.fogEnd
            Lighting.FogStart = self.orig.fogStart
        end)
        return
    end
    self.fogConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            Lighting.FogEnd = 1e9
            Lighting.FogStart = 1e9
        end)
    end)
end

function VisualMods:SetFOV(val)
    Config.Visual.FOV = val
    if self.fovConn then pcall(function() self.fovConn:Disconnect() end); self.fovConn = nil end
    self.fovConn = RunService.Heartbeat:Connect(function()
        pcall(function() Camera.FieldOfView = Config.Visual.FOV end)
    end)
end

function VisualMods:SetNoShadow(state)
    Config.Visual.NoShadow = state
    pcall(function() Lighting.GlobalShadows = not state end)
end

