    -- ============================================
    -- INVISIBLE KILLER (Mimic/Ennard)
    -- ============================================
    local invisTrack=nil; local invisStepped=nil; local invisCamera=nil
    local function ApplyInvisibility(enabled)
        local char = LP.Character or LP.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")
        local root = char:WaitForChild("HumanoidRootPart")
        local camera = workspace.CurrentCamera
        if not enabled then
            if invisTrack then invisTrack:Stop(); invisTrack=nil end
            if invisStepped then invisStepped:Disconnect(); invisStepped=nil end
            if invisCamera then invisCamera:Disconnect(); invisCamera=nil end
            camera.CameraSubject = hum
            -- Restore door collisions
            local map = GetMap()
            if map and map:FindFirstChild("Doors") then
                for _, base in ipairs(map.Doors:GetDescendants()) do
                    if base:IsA("BasePart") and base:GetAttribute("OriginalCollision") then
                        base.CanCollide = base:GetAttribute("OriginalCollision")
                    end
                end
            end
            return
        end
        if char:GetAttribute("Team") ~= "Killer" then return end
        local charName = char:GetAttribute("Character")
        if charName ~= "Mimic" and charName ~= "Ennard" then return end
        -- Make body noclip except root
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.CanCollide = false
            end
        end
        root.CanCollide = true
        camera.CameraSubject = root
        invisCamera = camera:GetPropertyChangedSignal("CameraSubject"):Connect(function()
            if camera.CameraSubject ~= root then camera.CameraSubject = root end
        end)
        -- Doors noclip
        local map = GetMap()
        if map and map:FindFirstChild("Doors") then
            for _, base in ipairs(map.Doors:GetDescendants()) do
                if base:IsA("BasePart") then
                    if not base:GetAttribute("OriginalCollision") then
                        base:SetAttribute("OriginalCollision", base.CanCollide)
                    end
                    base.CanCollide = false
                end
            end
        end
        -- Animation
        local anim = Instance.new("Animation")
        local animId = nil
        if charName == "Mimic" then animId = "rbxassetid://95483601477510"
        elseif charName == "Ennard" then animId = "rbxassetid://111261793531584"
        else return end
        anim.AnimationId = animId
        local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        invisTrack = animator:LoadAnimation(anim)
        invisTrack.Priority = Enum.AnimationPriority.Action4
        invisTrack.Looped = false
        invisTrack:Play()
        task.wait(0.1)
        if invisTrack.Length > 0 then
            invisTrack.TimePosition = invisTrack.Length - 0.01
            invisTrack:AdjustSpeed(0)
        end
        invisStepped = RunService.RenderStepped:Connect(function()
            if camera.CameraSubject ~= root then camera.CameraSubject = root end
        end)
    end
    local function SetInvisibleKiller(on)
        S.InvisibleKiller = on
        pcall(function() ApplyInvisibility(on) end)
    end
