local function GetAimPart(char)
    if not char then return nil end
    if CFG.AIM_TargetPart == "Head" then return char:FindFirstChild("Head")
    elseif CFG.AIM_TargetPart == "Torso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    else return char:FindFirstChild("HumanoidRootPart") end
end

local function GetAimTarget()
    local role = GetRole()
    local best, bestD = nil, CFG.AIM_FOV
    local center = Camera.ViewportSize / 2
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Team then
            local ok = false
            if role == "Survivor" and IsKiller(p) then ok = true
            elseif role == "Killer" and IsSurvivor(p) then ok = true end
            if ok then
                local part = GetAimPart(p.Character)
                if part then
                    if CFG.AIM_VisCheck and not Cache.Visibility[p] then continue end
                    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen and sp.Z > 0 then
                        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                        if d < bestD then bestD = d; best = p end
                    end
                end
            end
        end
    end
    return best
end

local function AimbotUpdate()
    if not CFG.AIM_Enabled then State.AimTarget = nil; return end
    if CFG.AIM_UseRMB and not State.AimHolding then State.AimTarget = nil; return end
    local t = GetAimTarget()
    State.AimTarget = t
    if t and t.Character then
        local part = GetAimPart(t.Character)
        if part then
            local pos = part.Position
            if CFG.AIM_Predict then
                local r = t.Character:FindFirstChild("HumanoidRootPart")
                if r then pos = pos + r.Velocity * 0.1 end
            end
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, pos), CFG.AIM_Smooth)
        end
    end
end

