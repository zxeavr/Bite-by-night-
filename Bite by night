UserInputService.InputBegan:Connect(function(inp, gp)
    if State.Unloaded then return end
    if inp.KeyCode == CFG.KEY_Panic then
        State.Unloaded = true
        ESP.Clear()
        if FOVCircle then FOVCircle:Remove() end
        if NoclipConn then NoclipConn:Disconnect() end
        if InfJumpConn then InfJumpConn:Disconnect() end
        if SCConn then SCConn:Disconnect() end
        SG:Destroy()
        RadarGui:Destroy()
        return
    end
    if inp.KeyCode == CFG.KEY_Menu and not gp then
        CFG.MENU_Open = not CFG.MENU_Open
        Main.Visible = CFG.MENU_Open
    end
    if inp.UserInputType == Enum.UserInputType.MouseButton2 and CFG.AIM_Enabled and CFG.AIM_UseRMB then
        State.AimHolding = true
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 and CFG.AIM_UseRMB then
        State.AimHolding = false; State.AimTarget = nil
    end
end)

