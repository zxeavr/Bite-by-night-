if CURRENT_GAME.Type == "BBN" then
    local STUN_ATTRS = {"Stun", "Stunned", "IsStunned", "Blinded", "IsBlinded", "Slowed", "Slowness", "bypass_slow"}
    local STUN_TAGS = {"SlowStop", "Stun", "Stunned", "Blinded", "Slowed", "bypass_slow"}
    local antiStunConn

    local function SetAntiStun(on)
        if antiStunConn then antiStunConn:Disconnect() end
        if not on then
            pcall(function()
                if not LPChar then return end
                for _, t in ipairs(STUN_TAGS) do
                    if CollectionService:HasTag(LPChar, t) then
                        CollectionService:RemoveTag(LPChar, t)
                    end
                end
            end)
            return
        end

        antiStunConn = RunService.Heartbeat:Connect(function()
            if not S.AntiStun or not LPChar then return end
            pcall(function()
                for _, t in ipairs(STUN_TAGS) do
                    if CollectionService:HasTag(LPChar, t) then
                        CollectionService:RemoveTag(LPChar, t)
                    end
                end
                for _, a in ipairs(STUN_ATTRS) do
                    local v = LPChar:GetAttribute(a)
                    if type(v) == "boolean" and v then
                        LPChar:SetAttribute(a, false)
                    elseif type(v) == "number" and v > 0 then
                        LPChar:SetAttribute(a, 0)
                    end
                end
            end)
        end)
    end

    _G.SetAntiStun = SetAntiStun
end

