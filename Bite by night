--// MODIFIED: Safe teleport helper for AutoFarm
local function tpChar(targetCF)
    pcall(function()
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local dist = (root.Position - targetCF.Position).Magnitude
        if dist < 12 then
            root.CFrame = targetCF
            return
        end
        -- Safe teleport: move under map then to target to avoid anti-cheat
        root.CFrame = CFrame.new(targetCF.Position.X, targetCF.Position.Y - 250, targetCF.Position.Z)
        task.wait(0.06)
        root.CFrame = targetCF
    end)
end

--// MODIFIED: Improved AutoFarm using Nullix open source + Battery/Fuse/Escape
local farmThread=nil
local function SetAutoFarm(on)
    if farmThread then pcall(task.cancel,farmThread); farmThread=nil end
    if not on then return end
    farmThread = task.spawn(function()
        while S.AutoFarm do
            task.wait(0.6)
            pcall(function()
                local char = LP.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                if char:GetAttribute("Team") ~= "Survivor" then return end
                
                -- 1. Collect Battery if missing
                if not char:FindFirstChild("Battery") then
                    local ig = workspace:FindFirstChild("IGNORE")
                    if ig then
                        for _,b in ipairs(ig:GetChildren()) do
                            if b.Name == "Battery" and b:IsA("BasePart") then
                                tpChar(b.CFrame + Vector3.new(0, 1, 0))
                                task.wait(0.25)
                                local attach = b:FindFirstChild("Attachment")
                                local prompt = attach and attach:FindFirstChildOfClass("ProximityPrompt")
                                if prompt and fireproximityprompt then
                                    pcall(function() fireproximityprompt(prompt) end)
                                end
                                task.wait(0.6)
                                break
                            end
                        end
                    end
                end
                
                -- 2. Insert Battery into Fuse Boxes
                local map = GetMap()
                if map and char:FindFirstChild("Battery") then
                    local fuseFolder = map:FindFirstChild("FuseBoxes")
                    if fuseFolder then
                        for _,fuse in ipairs(fuseFolder:GetChildren()) do
                            if fuse:IsA("Model") and not fuse:GetAttribute("Inserted") then
                                local root = fuse.PrimaryPart or fuse:FindFirstChild("RootPart") or fuse:FindFirstChild("HumanoidRootPart")
                                if root then
                                    tpChar(root.CFrame + Vector3.new(0, 2, 0))
                                    task.wait(0.3)
                                    for _,d in ipairs(fuse:GetDescendants()) do
                                        if d:IsA("ProximityPrompt") and d.Enabled then
                                            pcall(function() fireproximityprompt(d) end)
                                            break
                                        end
                                    end
                                    task.wait(1)
                                    break
                                end
                            end
                        end
                    end
                end
                
                -- 3. Complete Generators (Nullix open source style)
                if map then
                    local gens = map:FindFirstChild("Generators")
                    if gens then
                        for _,gen in ipairs(gens:GetChildren()) do
                            if gen:IsA("Model") and gen:GetAttribute("Progress") < 100 then
                                local primary = gen.PrimaryPart or gen:FindFirstChild("RootPart")
                                if primary then
                                    tpChar(CFrame.new(primary.Position + Vector3.new(0, 2, 0)))
                                    task.wait(0.5)
                                    local rootPart = gen:FindFirstChild("RootPart")
                                    if rootPart then
                                        local prompts = {}
                                        for _,ptName in ipairs({"Point1","Point2","Point3"}) do
                                            local pt = rootPart:FindFirstChild(ptName)
                                            if pt then
                                                local pp = pt:FindFirstChildOfClass("ProximityPrompt")
                                                if pp then table.insert(prompts, pp) end
                                            end
                                        end
                                        local startTime = tick()
                                        while gen.Parent and gen:GetAttribute("Progress") < 100 and (tick()-startTime) < 25 do
                                            local fired = false
                                            for _,pp in ipairs(prompts) do
                                                if pp and pp.Enabled then
                                                    pcall(function() fireproximityprompt(pp) end)
                                                    fired = true
                                                    break
                                                end
                                            end
                                            if not fired then break end
                                            task.wait(0.6)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                
                -- 4. Escape
                EscapeMap()
            end)
        end
    end)
end

