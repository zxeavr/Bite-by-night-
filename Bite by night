            local key,label=row[1],row[2]; local cfg=S.T[key]; if not cfg then continue end
            R["T."..key..".On"]=TbVisual:Toggle({Title="ESP "..label,Value=cfg.On,Callback=function(v) cfg.On=v end})
            TbVisual:Colorpicker({Title=label.." Color",Default=cfg.Color,Callback=function(c) cfg.Color=c end})
        end
        TbVisual:Divider()
        R.FullBright=TbVisual:Toggle({Title="Full Bright",Value=S.FullBright,Callback=function(v) S.FullBright=v; SetFullBright(v) end})
        R.NoBlind   =TbVisual:Toggle({Title="No Blindness",Value=S.NoBlind,  Callback=function(v) S.NoBlind=v; SetNoBlind(v) end})
        R.NoFog     =TbVisual:Toggle({Title="No Fog",      Value=S.NoFog,    Callback=function(v) S.NoFog=v end})
        R.NoShadow  =TbVisual:Toggle({Title="No Shadow",   Value=S.NoShadow, Callback=function(v) S.NoShadow=v end})
        TbVisual:Slider({Title="Field of View",Step=1,Value={Min=10,Max=100,Default=70},Callback=function(v) SetFOV(v) end})
        TbVisual:Divider()
        R.HideGenGui=TbVisual:Toggle({Title="Hide Generator GUI",Value=S.HideGenGui,Callback=function(v) S.HideGenGui=v; SetHideGenGui(v) end})
