local function ListCfgs()
    if not listfiles then return {} end
    local r = {}; local ok,fs = pcall(listfiles,CFG_FOLDER); if not ok then return r end
    for _,f in ipairs(fs) do
        local n = f:match("([^/\\]+)%.json$")
        if n and n:sub(1,3) == "VD_" then table.insert(r, n:sub(4)) end
    end
    return r
end

local function SaveCfg(name)
    if not writefile then return false end
    local data = {
        ESP=S.ESP, ESPMode=S.ESPMode,
        KillerESP=S.KillerESP, KillerColor={S.KillerColor.R,S.KillerColor.G,S.KillerColor.B},
        SurvivorESP=S.SurvivorESP, SurvivorColor={S.SurvivorColor.R,S.SurvivorColor.G,S.SurvivorColor.B},
        GeneratorESP=S.GeneratorESP, GeneratorColor={S.GeneratorColor.R,S.GeneratorColor.G,S.GeneratorColor.B},
        GateESP=S.GateESP, GateColor={S.GateColor.R,S.GateColor.G,S.GateColor.B},
        PalletESP=S.PalletESP, PalletColor={S.PalletColor.R,S.PalletColor.G,S.PalletColor.B},
        WindowESP=S.WindowESP, WindowColor={S.WindowColor.R,S.WindowColor.G,S.WindowColor.B},
        HookESP=S.HookESP, HookColor={S.HookColor.R,S.HookColor.G,S.HookColor.B},
        PerfectCheck=S.PerfectCheck, WalkSpeed=S.WalkSpeed,
        FullBright=S.FullBright, NoFog=S.NoFog, NoShadow=S.NoShadow,
        FovValue=S.FovValue, AntiAFK=S.AntiAFK, FPSBooster=S.FPSBooster,
        UIScale=S.UIScale, UIAlpha=S.UIAlpha
    }
    return pcall(writefile, CFG_FOLDER.."/VD_"..name..".json", HttpService:JSONEncode(data))
end

local function LoadCfg(name)
    if not readfile or not isfile then return nil end
    local path = CFG_FOLDER.."/VD_"..name..".json"
    if not isfile(path) then return nil end
    local ok,d = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not ok or not d then return nil end
    for k,v in pairs(d) do
        if k:find("Color") then
            S[k] = Color3.new(v[1] or 1, v[2] or 1, v[3] or 1)
        else
            S[k] = v
        end
    end
    return name
end

local function GetAutoLoad()
    if not isfile or not readfile or not isfile(AUTO_FILE) then return nil end
    local ok,v = pcall(readfile,AUTO_FILE)
    return (ok and v and v~="") and v or nil
end
local function SetAutoLoad(n) pcall(writefile,AUTO_FILE,n or "") end

local autoName = GetAutoLoad()
if autoName then pcall(function() LoadCfg(autoName) end) end

