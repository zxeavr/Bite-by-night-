local function SetupAntiBlind()
    pcall(function()
        local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
        local items = remotes and remotes:FindFirstChild("Items")
        local flashlight = items and items:FindFirstChild("Flashlight")
        local gotBlinded = flashlight and flashlight:FindFirstChild("GotBlinded")
        if gotBlinded and gotBlinded:IsA("RemoteEvent") then
            local oldFire = gotBlinded.FireServer
            gotBlinded.FireServer = function(self, ...)
                if S.AntiBlind and GetRole() == "Killer" then return nil end
                return oldFire(self, ...)
            end
        end
    end)
end

local function SetupNoPalletStun()
    pcall(function()
        local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
        local pallet = remotes and remotes:FindFirstChild("Pallet")
        local jason = pallet and pallet:FindFirstChild("Jason")
        if jason then
            for _, eventName in ipairs({"Stun", "StunDrop"}) do
                local event = jason:FindFirstChild(eventName)
                if event and event:IsA("RemoteEvent") then
                    local mt = getrawmetatable(game)
                    if mt and setreadonly then
                        setreadonly(mt, false)
                        local oldIndex = mt.__namecall
                        mt.__namecall = newcclosure(function(self, ...)
                            if S.NoPalletStun and GetRole() == "Killer" then
                                if self == event then return nil end
                            end
                            return oldIndex(self, ...)
                        end)
                        setreadonly(mt, true)
                    end
                end
            end
        end
    end)
end

