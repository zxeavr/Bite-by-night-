-- CORE LOOP – يجمع كل التحديثات المهمة
local coreConn = nil
local function StopCoreLoop()
    if coreConn then coreConn:Disconnect(); coreConn = nil end
end
local function StartCoreLoop()
    StopCoreLoop()
    coreConn = RunService.Heartbeat:Connect(function()
        local char = LP.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        -- ستامينا + مضاد ذهول + مضاد سقوط
        if S.InfStamina and char then
            pcall(function() char:SetAttribute("Stamina", char:GetAttribute("MaxStamina") or 100) end)
        end
        if S.AntiStun and char then
            for _,a in ipairs({"Stun","Stunned","IsStunned","Blinded","IsBlinded","Slowed","Slowness"}) do
                local v = char:GetAttribute(a)
                if type(v)=="boolean" and v then char:SetAttribute(a,false)
                elseif type(v)=="number" and v>0 then char:SetAttribute(a,0) end
            end
            for _,t in ipairs({"Stun","Stunned","Blinded"}) do
                if CollectionService:HasTag(char,t) then CollectionService:RemoveTag(char,t) end
            end
        end
        if S.AntiRagdoll and hum and hum:GetState()==Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end

        -- جري تلقائي: عند الإغلاق يزيل RunSpeed ويوقف الركض تماماً
        if S.AutoRun and char then
            local rs = char:GetAttribute("RunSpeed")
            char:SetAttribute("WalkSpeed", (rs and rs~=0) and rs or 24)
        else
            if char then
                char:SetAttribute("WalkSpeed", 16)
                char:SetAttribute("RunSpeed", nil)
            end
        end

        -- تجاوز البطء
        if S.BypassSlow and char and hum then
            local spd = S.RunSpeed
            hum.WalkSpeed = spd
            char:SetAttribute("CustomSpeed", spd)
            char:SetAttribute("ModifiedMovementSpeed", spd)
        end

        -- الصد التلقائي (هايلايت)
        if S.AutoParry then
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v.ClassName == "Highlight" and v.Name == "Highlight" and v.Enabled and v.Adornee and v.Adornee:IsA("Model") then
                        local km = v.Adornee
                        local kf = workspace:FindFirstChild("PLAYERS") and workspace.PLAYERS:FindFirstChild("KILLER")
                        if kf and km.Parent == kf then
                            local kr = km:FindFirstChild("HumanoidRootPart")
                            if kr and (root.Position - kr.Position).Magnitude <= S.ParryRangeBasic then
                                if (tick() - (lastParryFiredAt or 0)) >= 0.15 then
                                    lastParryFiredAt = tick()
                                    pcall(function()
                                        local rel = RS:WaitForChild("Modules"):WaitForChild("Warp"):WaitForChild("Index"):WaitForChild("Event"):WaitForChild("Reliable")
                                        rel:FireServer(buffer.fromstring("\a"), buffer.fromstring("\254\001\000\254\002\000\006\aAbility\001\002"))
                                    end)
                                end
                                break
                            end
                        end
                    end
                end
            end
        end

        -- هجوم تلقائي
        if S.AutoSwing and char then
            local myRoot = char:FindFirstChild("HumanoidRootPart")
            if myRoot and (tick() - lastSwing >= 0.45) then
                local pf = workspace:FindFirstChild("PLAYERS")
                local af = pf and pf:FindFirstChild("ALIVE")
                if af then
                    local closest, bestDist = nil, S.SwingRange+1
                    for _, m in ipairs(af:GetChildren()) do
                        if m.Name ~= LP.Name and not IsParrying(m) then
                            local hrp = m:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local d = (myRoot.Position - hrp.Position).Magnitude
                                if d < bestDist then bestDist = d; closest = m end
                            end
                        end
                    end
                    if closest then
                        lastSwing = tick()
                        SimulateM1Click()
                    end
                end
            end
        end

        -- هروب تلقائي
        if S.AutoEscape and char and char:GetAttribute("Team") == "Survivor" then
            EscapeMap()
        end

        -- مضاد الفخاخ
        if S.AntiTrap and char and hum then
            AntiTrapUpdate()
        end

        -- باريكاد
        if S.AutoBarricade then
            BarricadeUpdate()
        end

        -- قفل كاميرا Any Killer
        if S.CamAny and not camActive then
            local myRoot = char and char:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local pf = workspace:FindFirstChild("PLAYERS")
                local kf = pf and pf:FindFirstChild("KILLER")
                if kf then
                    for _, m in ipairs(kf:GetChildren()) do
                        if m:IsA("Model") then
                            local kr = m:FindFirstChild("HumanoidRootPart")
                            if kr and (kr.Position - myRoot.Position).Magnitude <= S.CamAnyRange then
                                if kr.CFrame.LookVector:Dot((myRoot.Position - kr.Position).Unit) > 0.3 then
                                    camActive = true
                                    S.CamTarget = kr
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end
StartCoreLoop()

