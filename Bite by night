local function BeatSurvivor()
    if not CFG.BEAT_Survivor or GetRole() ~= "Survivor" then
        State.BeatSurvivorDone = false; return
    end
    local root = GetRoot()
    if not root then return end
    local map = workspace:FindFirstChild("Map")
    if not map then return end
    local exitPos = nil
    SafeCall(function()
        local finish = map:FindFirstChild("Finishline") or map:FindFirstChild("FinishLine") or map:FindFirstChild("Fininshline")
        if finish then
            if finish:IsA("BasePart") then exitPos = finish.Position
            elseif finish:IsA("Model") then
                local pt = finish:FindFirstChildWhichIsA("BasePart")
                if pt then exitPos = pt.Position end
            end
        end
        if not exitPos then
            for _, obj in ipairs(map:GetDescendants()) do
                if obj.Name:lower():find("finish") then
                    if obj:IsA("BasePart") then exitPos = obj.Position; break
                    elseif obj:IsA("Model") then
                        local pt = obj:FindFirstChildWhichIsA("BasePart")
                        if pt then exitPos = pt.Position; break end
                    end
                end
            end
        end
    end)
    if not exitPos then return end
    if State.BeatSurvivorDone then return end
    root.CFrame = CFrame.new(exitPos + Vector3.new(0, 3, 0))
    State.BeatSurvivorDone = true
end

local function BeatKiller()
    if not CFG.BEAT_Killer or GetRole() ~= "Killer" then
        State.KillerTarget = nil; return
    end
    local root = GetRoot()
    if not root then return end
    local target = State.KillerTarget
    local needNew = true
    if target and target.Character then
        local tr = target.Character:FindFirstChild("HumanoidRootPart")
        local hum = target.Character:FindFirstChildOfClass("Humanoid")
        if tr and hum and hum.Health > 0 and hum.Health / hum.MaxHealth > 0.25 then
            needNew = false
        else
            State.KillerTarget = nil
        end
    end
    if needNew then
        local survivors = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and IsSurvivor(p) and p.Character then
                local tr = p.Character:FindFirstChild("HumanoidRootPart")
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if tr and hum and hum.Health > 0 and hum.Health / hum.MaxHealth > 0.25 then
                    table.insert(survivors, p)
                end
            end
        end
        if #survivors > 0 then
            local best, bestD = nil, math.huge
            for _, p in ipairs(survivors) do
                local tr = p.Character:FindFirstChild("HumanoidRootPart")
                if tr then
                    local d = (tr.Position - root.Position).Magnitude
                    if d < bestD then bestD = d; best = p end
                end
            end
            State.KillerTarget = best; target = best
        else
            State.KillerTarget = nil; return
        end
    end
    if not target or not target.Character then return end
    local tr = target.Character:FindFirstChild("HumanoidRootPart")
    if not tr then State.KillerTarget = nil; return end
    for _, p in ipairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
    local dir = (root.Position - tr.Position).Unit
    if dir.Magnitude ~= dir.Magnitude then dir = Vector3.new(1, 0, 0) end
    root.CFrame = CFrame.new(tr.Position + dir * 3 + Vector3.new(0, 1, 0), tr.Position)
    SafeCall(function()
        local rem = ReplicatedStorage:FindFirstChild("Remotes")
        local att = rem and rem:FindFirstChild("Attacks")
        local ba = att and att:FindFirstChild("BasicAttack")
        if ba then ba:FireServer(false) end
    end)
end

