local function ApplyESP(obj,tcfg,label,maxDist)
    if not obj or not obj.Parent then return end
    local anyOn = tcfg.On or S.ESPHealth
    local d = espReg[obj]
    if not anyOn then
        if d then
            if d.HL then d.HL.Enabled=false end
            if d.SB then d.SB.Visible=false end
            if d.BB then d.BB.Enabled=false end
        end
        return
    end
    if not d then d = BuildESP(obj,tcfg.Color,label,maxDist); if not d then return end end
    if d.HL then d.HL.FillColor=tcfg.Color; d.HL.OutlineColor=tcfg.Color end
    if d.SB then d.SB.Color3=tcfg.Color; d.SB.SurfaceColor3=tcfg.Color end
    if d.Lbl then d.Lbl.TextColor3=tcfg.Color; d.Lbl.Text=label end
    local mode = S.ESPMode
    if mode=="Highlight" then
        if d.HL then d.HL.Enabled=true end; if d.SB then d.SB.Visible=false end; if d.BB then d.BB.Enabled=false end
    elseif mode=="Chams" then
        if d.HL then d.HL.Enabled=false end; if d.SB then d.SB.Visible=true end; if d.BB then d.BB.Enabled=false end
    elseif mode=="Name" then
        if d.HL then d.HL.Enabled=false end; if d.SB then d.SB.Visible=false end; if d.BB then d.BB.Enabled=true end; if d.Lbl then d.Lbl.Visible=true end
    end
    -- Health ESP
    if d.HpL then
        if S.ESPHealth then
            local hum=obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                local hp=math.floor(hum.Health+0.5); local mhp=math.max(math.floor(hum.MaxHealth+0.5),1)
                local r=math.clamp(hum.Health/mhp,0,1)
                d.HpL.Text=hp.." / "..mhp
                d.HpL.TextColor3=Color3.fromRGB(math.floor((1-r)*255),math.floor(r*200+55),30)
                d.HpL.Visible=true
            else d.HpL.Visible=false end
        else d.HpL.Visible=false end
    end
end
local function ProcessFolder(folder,key,label,maxDist)
    if not folder then return end
    for _,obj in ipairs(folder:GetChildren()) do
        if obj.Name==LP.Name then continue end
        if obj:IsA("Model") or obj:IsA("BasePart") then ApplyESP(obj,S.T[key],label,maxDist) end
    end
end
