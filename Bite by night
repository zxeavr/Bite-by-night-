-- Simple Cam Lock (nearest player)
local camLockTarget = nil
local camLockActive = false

local function findClosestPlayer()
	local closest = nil
	local closestDist = math.huge
	local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LP and plr.Character then
			local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
					if dist < closestDist then
						closestDist = dist
						closest = hrp
					end
				end
			end
		end
	end
	return closest
end

RunService.RenderStepped:Connect(function()
	if camLockActive then
		if not camLockTarget or not camLockTarget.Parent then
			camLockTarget = findClosestPlayer()
		end
		if camLockTarget and camLockTarget.Parent then
			Camera.CameraType = Enum.CameraType.Scriptable
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, camLockTarget.Position)
		end
	else
		if Camera.CameraType == Enum.CameraType.Scriptable then
			pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
		end
		camLockTarget = nil
	end
end)

local function SetCamLockSimple(on)
	camLockActive = on
	if not on then camLockTarget = nil end
end

