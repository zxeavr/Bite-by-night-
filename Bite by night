		-- ==================== IS TABS ====================
		Tabs.Human:Dropdown({
			Title = "Fast Weapon",
			Values = {"Bat", "Bottle", "Katana", "Branch", "Spare", "Chain"},
			Value = S.IS_FastWeaponOption or "Katana",
			Multi = false,
			Callback = function(selected)
				S.IS_FastWeaponOption = selected
				applyFastWeapon(selected)
				N("Fast Weapon", selected.." cooldown -> 0", 2, "zap")
			end
		})
		Tabs.Human:Toggle({Title="Auto Fast Weapons", Value=S.IS_AutoFastWeapons, Callback=function(v) S.IS_AutoFastWeapons=v; setAutoFastWeapons(v) end})
		Tabs.Human:Toggle({Title="Disable Killbricks", Value=S.IS_DisableKillbricks, Callback=function(v) S.IS_DisableKillbricks=v; setDisableKillbricks(v) end})
		Tabs.Human:Divider()
		Tabs.Human:Toggle({Title="Reach All Weapons", Value=S.IS_ReachAllWeapons, Callback=function(v) S.IS_ReachAllWeapons=v; if v then setReachAllWeapons(v) end end})
		Tabs.Human:Slider({Title="Reach Size", Step=0.5, Min=3, Max=15, Default=5, Callback=function(v) S.IS_ReachSize=v; if S.IS_ReachAllWeapons then applyReachAll(v) end end})
		Tabs.Human:Toggle({Title="Auto Reach (new weapons)", Value=S.IS_AutoReach, Callback=function(v) S.IS_AutoReach=v; setAutoReach(v) end})
		Tabs.Human:Divider()
		Tabs.Human:Button({Title="Get Main Weapon", Callback=getMainWeapon})
		Tabs.Human:Button({Title="Get All Special Weapons", Callback=getAllSpecialWeapons})
		Tabs.Human:Button({Title="Delete Tool", Callback=deleteTool})
		Tabs.Human:Divider()
		Tabs.Human:Toggle({Title="Anti Inventory Block", Value=S.IS_AntiInventoryBlock, Callback=function(v) S.IS_AntiInventoryBlock=v; setAntiInventoryBlock(v) end})
		Tabs.Human:Toggle({Title="Anti Infection", Value=S.IS_AntiInfection, Callback=function(v) S.IS_AntiInfection=v; setAntiInfection(v) end})
		Tabs.Human:Toggle({Title="Anti Infected Players", Value=S.IS_AntiInfectedPlayers, Callback=function(v) S.IS_AntiInfectedPlayers=v; setAntiInfectedPlayers(v) end})
		Tabs.Human:Button({Title="AntiCheat Destroy", Callback=antiCheatDestroy})

		-- Smile Tab
		Tabs.Smile:Button({Title="Infect (self)", Callback=infectSelf})
		Tabs.Smile:Slider({Title="Reach Hitbox (torso Z)", Step=1, Min=5, Max=30, Default=10, Callback=function(v) S.IS_ReachHitboxVal=v; if S.IS_ReachHitbox then setReachHitbox(v) end end})
		Tabs.Smile:Toggle({Title="Enable Reach Hitbox", Value=S.IS_ReachHitbox, Callback=function(v) S.IS_ReachHitbox=v; if v then setReachHitbox(S.IS_ReachHitboxVal) end end})
		Tabs.Smile:Divider()
		Tabs.Smile:Toggle({Title="Disable Anti Smilers", Value=S.IS_DisableAntiSmilers, Callback=function(v) S.IS_DisableAntiSmilers=v; setDisableAntiSmilers(v) end})
		Tabs.Smile:Toggle({Title="Auto Grab", Value=S.IS_AutoGrab, Callback=function(v) S.IS_AutoGrab=v; setAutoGrab(v) end})
		Tabs.Smile:Toggle({Title="Kill Grab", Value=S.IS_KillGrab, Callback=function(v) S.IS_KillGrab=v; setKillGrab(v) end})
		Tabs.Smile:Toggle({Title="Instant Kill Grab", Value=S.IS_InstantKillGrab, Callback=function(v) S.IS_InstantKillGrab=v; setInstantKillGrab(v) end})
		Tabs.Smile:Toggle({Title="Push Grab", Value=S.IS_PushGrab, Callback=function(v) S.IS_PushGrab=v; setPushGrab(v) end})
		Tabs.Smile:Toggle({Title="Anti Stun (Stats)", Value=S.IS_AntiStunIS, Callback=function(v) S.IS_AntiStunIS=v; setAntiStunIS(v) end})
		Tabs.Smile:Button({Title="Instant Infect (cooldown 0)", Callback=instantInfectButton})

		-- Events Tab
		Tabs.Events:Toggle({Title="Auto Collect Keys", Value=S.IS_AutoCollectKeys, Callback=function(v) S.IS_AutoCollectKeys=v; setAutoCollectKeys(v) end})
		Tabs.Events:Toggle({Title="Auto Collect Coins", Value=S.IS_AutoCollectCoins, Callback=function(v) S.IS_AutoCollectCoins=v; setAutoCollectCoins(v) end})
		Tabs.Events:Divider()
		Tabs.Events:Toggle({Title="Fullbright", Value=S.IS_FullBrightIS, Callback=function(v) S.IS_FullBrightIS=v; setFullbrightIS(v) end})
		Tabs.Events:Toggle({Title="Remove Fog", Value=S.IS_RemoveFogIS, Callback=function(v) S.IS_RemoveFogIS=v; setRemoveFogIS(v) end})
		Tabs.Events:Button({Title="Check Seismic Activity", Callback=checkSeismic})
		Tabs.Events:Divider()
		Tabs.Events:Toggle({Title="Anti Black Hole", Value=S.IS_AntiBlackHole, Callback=function(v) S.IS_AntiBlackHole=v; setAntiBlackHole(v) end})
		Tabs.Events:Toggle({Title="Kill Nearest NPCs", Value=S.IS_KillNearestNPCs, Callback=function(v) S.IS_KillNearestNPCs=v; setKillNearestNPCs(v) end})
		Tabs.Events:Toggle({Title="Disable Echo", Value=S.IS_DisableEcho, Callback=function(v) S.IS_DisableEcho=v; setDisableEcho(v) end})
		Tabs.Events:Divider()
		Tabs.Events:Label("External GUIs")
		Tabs.Events:Button({Title="Smile Hax", Callback=function() loadstring(game:HttpGet("https://pastebin.com/raw/WG1BMS72",true))() end})
		Tabs.Events:Button({Title="Multi Hub", Callback=function() loadstring(game:HttpGet("https://raw.githubusercontent.com/jj123llol/multi-hub/main/Multi",true))() end})
		Tabs.Events:Button({Title="ROChips",   Callback=function() loadstring(game:HttpGet("https://pastebin.com/raw/5NvnvrrS",true))() end})
		Tabs.Events:Button({Title="GUI 1",     Callback=function() loadstring(game:HttpGet("https://raw.githubusercontent.com/MariyaFurmanova/Library/main/InfectiousSmile", true))() end})
		Tabs.Events:Button({Title="GUI 2",     Callback=function() loadstring(game:HttpGet("https://pastebin.com/raw/X8hLEwcz"))() end})
		Tabs.Events:Button({Title="GUI 3",     Callback=function() loadstring(game:HttpGet("https://raw.githubusercontent.com/Nicuse/RobloxScripts/main/InfectiousSmile.lua", true))() end})
	end

	-- ==================== SETTINGS TAB ====================
	local setTab = Window:Tab({Title="Settings", Icon="sliders-horizontal"})
	setTab:Slider({Title="UI Scale", Step=0.05, Min=0.7, Max=1.5, Default=1.0, Callback=function(v) ApplyScale(v) end})
	setTab:Slider({Title="UI Transparency", Step=0.05, Min=0, Max=0.9, Default=0, Callback=function(v) ApplyAlpha(v) end})
	setTab:Toggle({Title="Anti-AFK", Value=S.AntiAFK, Callback=function(v) S.AntiAFK=v; SetAFK(v) end})
	setTab:Toggle({Title="FPS Booster", Value=S.FPSBooster, Callback=function(v) S.FPSBooster=v; SetFPSBooster(v) end})
	setTab:Keybind({Title="Toggle UI", Value="RightControl", Callback=function(k) pcall(function() Window:SetToggleKey(Enum.KeyCode[k]) end) end})
	setTab:Toggle({Title="Debug Helpers", Value=S.DebugHelpers, Callback=function(v) S.DebugHelpers=v; S_Debug=v end})

	-- ==================== CONFIG TAB ====================
	local cfgTab = Window:Tab({Title="Config", Icon="folder"})
	local cfgInput = ""; local selCfg = nil; local cfgDD = nil
	cfgTab:Input({Title="Config Name", Placeholder="v1", Callback=function(t) if t and t~="" then cfgInput=t end end})
	cfgTab:Button({Title="Save Config", Callback=function()
		if cfgInput=="" then return end
		if SaveCfg(cfgInput) then
			local l = ListCfgs(); if cfgDD then cfgDD:Refresh(#l>0 and l or {"(none)"}) end
			N("Config","Saved: "..cfgInput,3,"check")
		end
	end})
	local l = ListCfgs()
	cfgDD = cfgTab:Dropdown({Title="Select Config", Values=#l>0 and l or {"(none)"}, Value=l[1] or "(none)", Multi=false, AllowNone=true, Callback=function(v) selCfg=v end})
	if #l>0 then selCfg = l[1] end
	cfgTab:Button({Title="Load Config", Callback=function()
		if not selCfg or selCfg=="(none)" then return end
		if LoadCfg(selCfg) then
			N("Config","Loaded: "..selCfg,3,"folder")
			-- reapply features from state S
		end
	end})
	cfgTab:Divider()
	local autoLoad = GetAutoLoad() ~= nil
	cfgTab:Toggle({Title="Auto Load on Start", Value=autoLoad, Callback=function(v)
		if v then if selCfg and selCfg~="(none)" then SetAutoLoad(selCfg) end else SetAutoLoad("") end
	end})
	cfgTab:Button({Title="Delete Selected", Callback=function()
		if not selCfg or selCfg=="(none)" then return end
		pcall(function() if delfile then delfile(CFG_FOLDER.."/"..selCfg..".json") end end)
		local l2 = ListCfgs(); if cfgDD then cfgDD:Refresh(#l2>0 and l2 or {"(none)"}) end; selCfg=nil
	end})

	-- ==================== Initialise Features ====================
	if IS_BBN then
		ConnectStamina(); SetAFK(S.AntiAFK); SetAntiTrap(S.AntiTrap); SetAntiStun(S.AntiStun)
		SetAntiRagdoll(S.AntiRagdoll)
		if S.AllowJump   then SetAllowJump(true) end
		if S.AutoRun     then SetAutoRun(true) end
		if S.DeleteDoor  then SetDeleteDoor(true) end
		if S.SkipCutscene then SetSkipCutscene(true) end
		if S.AutoPhase   then SetAutoPhase(true) end
		if S.InstantGen  then StartInstantGen() end
		if S.FullBright  then SetFullBright(true) end
		if S.NoBlind     then SetNoBlind(true) end
		if S.HideGenGui  then SetHideGenGui(true) end
		if S.InstantPrompt then SetInstantPrompt(true) end
		if S.AutoBarricade then SetBarricade(true) end
		if S.AutoEscape  then SetAutoEscape(true) end
		if S.AutoFarm    then SetAutoFarm(true) end
		if S.AutoParry   then SetAutoParry(true) end
		if S.AutoShakeWire then SetWireShake(true) end
		SetCamLockSimple(S.CamLockSimple)

		LP.CharacterAdded:Connect(function()
			task.wait(1); RefreshChar()
			ConnectStamina(); ConnectAntiDie()
			if S.NoClip    then SetNoClip(true) end
			if S.AllowJump then SetAllowJump(true) end
			if S.AutoRun   then SetAutoRun(true) end
			if S.AutoParry then SetAutoParry(true) end
			if S.AntiTrap  then SetAntiTrap(true) end
			SetAntiStun(S.AntiStun); SetAntiRagdoll(S.AntiRagdoll)
			if S.AutoPhase then SetAutoPhase(true) end
			SetCamLockSimple(S.CamLockSimple)
		end)
		ConnectAntiDie()
	else
		if S.IS_AutoFastWeapons then setAutoFastWeapons(true) end
		if S.IS_DisableKillbricks then setDisableKillbricks(true) end
		if S.IS_ReachAllWeapons then setReachAllWeapons(true) end
		if S.IS_AutoReach then setAutoReach(true) end
		if S.IS_AntiInventoryBlock then setAntiInventoryBlock(true) end
		if S.IS_AntiInfection then setAntiInfection(true) end
		if S.IS_AntiInfectedPlayers then setAntiInfectedPlayers(true) end
		if S.IS_ReachHitbox then setReachHitbox(S.IS_ReachHitboxVal) end
		if S.IS_DisableAntiSmilers then setDisableAntiSmilers(true) end
		if S.IS_AutoGrab then setAutoGrab(true) end
		if S.IS_KillGrab then setKillGrab(true) end
		if S.IS_InstantKillGrab then setInstantKillGrab(true) end
		if S.IS_PushGrab then setPushGrab(true) end
		if S.IS_AntiStunIS then setAntiStunIS(true) end
		if S.IS_AutoCollectKeys then setAutoCollectKeys(true) end
		if S.IS_AutoCollectCoins then setAutoCollectCoins(true) end
		if S.IS_FullBrightIS then setFullbrightIS(true) end
		if S.IS_RemoveFogIS then setRemoveFogIS(true) end
		if S.IS_AntiBlackHole then setAntiBlackHole(true) end
		if S.IS_KillNearestNPCs then setKillNearestNPCs(true) end
		if S.IS_DisableEcho then setDisableEcho(true) end

		LP.CharacterAdded:Connect(function()
			task.wait(1); RefreshChar()
			if S.IS_ReachAllWeapons then applyReachAll(S.IS_ReachSize) end
			if S.IS_ReachHitbox then setReachHitbox(S.IS_ReachHitboxVal) end
			if S.IS_AntiStunIS then setAntiStunIS(true) end
		end)
	end

	SetFPSBooster(S.FPSBooster)
	if S.FovValue ~= 70 then SetFOV(S.FovValue) end
	task.delay(0.9, function() ApplyScale(S.UIScale); ApplyAlpha(S.UIAlpha) end)
	task.wait(1.5)
	N("Phantom Hub v8.0", (IS_BBN and "BBN" or "IS").." ready", 5, "moon")
end

