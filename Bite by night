local function GetAnchor(obj)
    if obj:IsA("BasePart") then return obj end
    return obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
        or (obj:IsA("Model") and obj.PrimaryPart) or obj:FindFirstChildOfClass("BasePart",true)
end
local function BuildESP(obj,color,label,maxDist)
    if not obj or not obj.Parent then return nil end
    local d={valid=true}
    local hl=Instance.new("Highlight"); hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillTransparency=0.55; hl.OutlineTransparency=0; hl.FillColor=color; hl.OutlineColor=color
    hl.Adornee=obj; hl.Enabled=false; hl.Parent=obj; d.HL=hl
    local sb=Instance.new("SelectionBox"); sb.LineThickness=0.05; sb.SurfaceTransparency=0.88
    sb.Color3=color; sb.SurfaceColor3=color; sb.Adornee=obj; sb.Visible=false; sb.Parent=workspace; d.SB=sb
    local anc=GetAnchor(obj)
    if anc then
        local bb=Instance.new("BillboardGui"); bb.Size=UDim2.fromOffset(200,58); bb.StudsOffset=Vector3.new(0,4,0)
        bb.AlwaysOnTop=true; bb.Enabled=false; bb.ResetOnSpawn=false; bb.LightInfluence=0
        bb.MaxDistance=maxDist or 9999; bb.Adornee=anc; bb.Parent=anc
        local hpL=Instance.new("TextLabel",bb); hpL.Name="HP"; hpL.Size=UDim2.new(1,0,0.42,0)
        hpL.BackgroundTransparency=1; hpL.Font=Enum.Font.GothamBold; hpL.TextSize=14
        hpL.TextColor3=Color3.fromRGB(100,255,100); hpL.TextStrokeTransparency=0.2
        hpL.TextStrokeColor3=Color3.new(0,0,0); hpL.Visible=false
        local nmL=Instance.new("TextLabel",bb); nmL.Name="L"; nmL.Size=UDim2.new(1,0,0.58,0)
        nmL.Position=UDim2.fromScale(0,0.42); nmL.BackgroundTransparency=1; nmL.Text=label
        nmL.TextColor3=color; nmL.Font=Enum.Font.GothamBold; nmL.TextSize=16
        nmL.TextStrokeTransparency=0.2; nmL.TextStrokeColor3=Color3.new(0,0,0); nmL.Visible=false
        d.BB=bb; d.HpL=hpL; d.Lbl=nmL
    end
    local conn; conn=obj.AncestryChanged:Connect(function()
        if obj.Parent then return end; conn:Disconnect(); d.valid=false
        pcall(function() if d.HL then d.HL:Destroy() end; if d.SB then d.SB:Destroy() end; if d.BB then d.BB:Destroy() end end)
        espReg[obj]=nil
    end)
    espReg[obj]=d; return d
end
local function ApplyESP(obj,tcfg,label,maxDist)
    if not obj or not obj.Parent then return end
    local anyOn = tcfg.On or S.ESPHealth
    local d = espReg[obj]
    if not anyOn then
        if d then
            if d.HL then d.HL.Enabled=false end
            if d.SB then d.SB.Visible=false end
            if d.BB then d.BB.Enabled=false end
        end
        return
    end
    if not d then d = BuildESP(obj,tcfg.Color,label,maxDist); if not d then return end end
    if d.HL then d.HL.FillColor=tcfg.Color; d.HL.OutlineColor=tcfg.Color end
    if d.SB then d.SB.Color3=tcfg.Color; d.SB.SurfaceColor3=tcfg.Color end
    if d.Lbl then d.Lbl.TextColor3=tcfg.Color; d.Lbl.Text=label end
    local mode = S.ESPMode
    if mode=="Highlight" then
        if d.HL then d.HL.Enabled=true end; if d.SB then d.SB.Visible=false end; if d.BB then d.BB.Enabled=false end
    elseif mode=="Chams" then
        if d.HL then d.HL.Enabled=false end; if d.SB then d.SB.Visible=true end; if d.BB then d.BB.Enabled=false end
    elseif mode=="Name" then
        if d.HL then d.HL.Enabled=false end; if d.SB then d.SB.Visible=false end; if d.BB then d.BB.Enabled=true end; if d.Lbl then d.Lbl.Visible=true end
    end
    if d.HpL then
        if S.ESPHealth then
            local hum=obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                local hp=math.floor(hum.Health+0.5); local mhp=math.max(math.floor(hum.MaxHealth+0.5),1)
                local r=math.clamp(hum.Health/mhp,0,1)
                d.HpL.Text=hp.." / "..mhp
                d.HpL.TextColor3=Color3.fromRGB(math.floor((1-r)*255),math.floor(r*200+55),30)
                d.HpL.Visible=true
            else d.HpL.Visible=false end
        else d.HpL.Visible=false end
    end
end
local function ProcessFolder(folder,key,label,maxDist)
    if not folder then return end
    for _,obj in ipairs(folder:GetChildren()) do
        if obj.Name==LP.Name then continue end
        if obj:IsA("Model") or obj:IsA("BasePart") then ApplyESP(obj,S.T[key],label,maxDist) end
    end
end
