local TRAP_ATTRS={"Trapped","BeartrapCaught","Caught","InTrap","Tripped","Snared","TrapCaught"}
local TRAP_TAGS={"Trapped","BeartrapCaught","Bear","InBearTrap","BearTrap"}
local antiTrapConn=nil
local lastTrapLog=0
--// MODIFIED: AntiTrap now includes Helper debug logger
local function SetAntiTrap(on)
    if antiTrapConn then antiTrapConn:Disconnect(); antiTrapConn=nil end
    if not on then return end
    antiTrapConn=RunService.Heartbeat:Connect(function()
        if not LPChar or not LPHum then return end
        pcall(function()
            --// Trap Helper: logs to console when caught (for screenshots/diagnosis)
            local char = LPChar
            local found = false
            local info = {}
            for _,a in ipairs(TRAP_ATTRS) do
                local v = char:GetAttribute(a)
                if v ~= nil and v ~= false and v ~= 0 then
                    found = true
                    table.insert(info, a.."="..tostring(v))
                end
            end
            for _,t in ipairs(TRAP_TAGS) do
                if CollectionService:HasTag(char, t) then
                    found = true
                    table.insert(info, "Tag:"..t)
                end
            end
            if found and (tick()-lastTrapLog) > 2 then
                lastTrapLog = tick()
                warn("========== [PH ANTI-TRAP HELPER] ==========")
                warn("TRAP DETECTED ON PLAYER!")
                warn("Details: "..table.concat(info, " | "))
                warn("Position: "..tostring(char:GetPivot().Position))
                warn("Time: "..tostring(math.floor(tick())))
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local cons = {}
                    for _,c in ipairs(hrp:GetChildren()) do
                        if c:IsA("Constraint") or c:IsA("BodyVelocity") or c:IsA("BodyGyro") or c:IsA("Weld") then
                            table.insert(cons, c.Name.."("..c.ClassName..")")
                        end
                    end
                    if #cons > 0 then warn("HRP Constraints: "..table.concat(cons, ", ")) end
                end
                warn("===========================================")
            end
            
            --// Anti Trap Logic
            if not S.AntiTrap then return end
            for _,a in ipairs(TRAP_ATTRS) do local v=LPChar:GetAttribute(a)
                if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
                elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
            end
            for _,t in ipairs(TRAP_TAGS) do if CollectionService:HasTag(LPChar,t) then CollectionService:RemoveTag(LPChar,t) end end
            local hrp=LPChar:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _,o in ipairs(hrp:GetChildren()) do
                    if o:IsA("BallSocketConstraint") or o:IsA("RopeConstraint") or o:IsA("WeldConstraint") then
                        pcall(function() o:Destroy() end)
                    end
                end
            end
            if LPHum.WalkSpeed<=0 then LPHum.WalkSpeed=math.max(S.RunSpeed,16) end
        end)
    end)
end

