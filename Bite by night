-- ============================================================
-- ANTI STUN (FIX: clears bypass_slow + SlowStop on disable)
-- ============================================================
local STUN_ATTRS = {"Stun","Stunned","IsStunned","Blinded","IsBlinded","Slowed","Slowness","bypass_slow"}
local STUN_TAGS  = {"SlowStop","Stun","Stunned","Blinded","Slowed","bypass_slow"}
local antiStunConn

local function ClearStunState()
    -- Fully clear all stun state from character
    pcall(function()
        if not LPChar then return end
        for _, t in ipairs(STUN_TAGS) do
            if CollectionService:HasTag(LPChar,t) then
                CollectionService:RemoveTag(LPChar,t)
                Log("Removed tag: "..t)
            end
        end
        for _, a in ipairs(STUN_ATTRS) do
            LPChar:SetAttribute(a, nil)
        end
        -- Restore walk speed to expected value
        local ws = S.AutoRun and S.RunSpeed or 16
        if LPHum then LPHum.WalkSpeed = ws end
    end)
end

local function SetAntiStun(on)
    if antiStunConn then antiStunConn:Disconnect(); antiStunConn=nil end
    if not on then
        ClearStunState()
        Log("AntiStun OFF - cleared all stun state")
        return
    end
    Log("AntiStun ON")
    antiStunConn = RunService.Heartbeat:Connect(function()
        if not S.AntiStun or not LPChar or not LPHum then return end
        pcall(function()
            -- Remove stun tags
            for _, t in ipairs(STUN_TAGS) do
                if CollectionService:HasTag(LPChar,t) then
                    CollectionService:RemoveTag(LPChar,t)
                    Log("Stun tag cleared: "..t)
                end
            end
            -- Clear stun attributes
            for _, a in ipairs(STUN_ATTRS) do
                local v = LPChar:GetAttribute(a)
                if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
                elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
            end
            -- Restore WalkSpeed if it was stunned to low value
            local expectedWS = S.AutoRun and S.RunSpeed or 16
            if LPHum.WalkSpeed < expectedWS*0.5 then
                LPHum.WalkSpeed = expectedWS
                Log("WalkSpeed restored to "..expectedWS)
            end
        end)
    end)
end

