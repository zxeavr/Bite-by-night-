-- AUTO PERFECT CHECK (الكود الأصلي)
-- ============================================================
local perfConn, perfCheckConn = nil, nil
local function SetupPerfectCheck()
    if perfConn then return end
    local PG = LP:WaitForChild("PlayerGui")
    local CheckGui = PG:WaitForChild("SkillCheckPromptGui")
    local Check = CheckGui:WaitForChild("Check")
    local Line = Check:WaitForChild("Line")
    local Goal = Check:WaitForChild("Goal")

    local function PressSpace()
        VirtualInputMgr:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
        task.wait(0.01)
        VirtualInputMgr:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
    end

    local function LineInGoal()
        local lr = Line.Rotation % 360
        local gr = Goal.Rotation % 360
        local gs = (gr + 104) % 360
        local ge = (gr + 114) % 360
        if gs > ge then return lr >= gs or lr <= ge
        else return lr >= gs and lr <= ge end
    end

    local function HeartbeatCheck()
        if not S.PerfectCheck then
            if perfCheckConn then perfCheckConn:Disconnect(); perfCheckConn = nil end
            return
        end
        if LP.Team and LP.Team.Name == "Survivors" then
            if LineInGoal() then
                PressSpace()
                if perfCheckConn then perfCheckConn:Disconnect(); perfCheckConn = nil end
            end
        elseif perfCheckConn then
            perfCheckConn:Disconnect()
            perfCheckConn = nil
        end
    end

    Check:GetPropertyChangedSignal("Visible"):Connect(function()
        if not S.PerfectCheck then return end
        if LP.Team and LP.Team.Name == "Survivors" then
            if Check.Visible then
                if perfCheckConn then perfCheckConn:Disconnect() end
                perfCheckConn = RunService.Heartbeat:Connect(HeartbeatCheck)
            elseif perfCheckConn then
                perfCheckConn:Disconnect()
                perfCheckConn = nil
            end
        elseif perfCheckConn then
            perfCheckConn:Disconnect()
            perfCheckConn = nil
        end
    end)
    perfConn = true
end

local function SetPerfectCheck(on)
    S.PerfectCheck = on
    if on then
        SetupPerfectCheck()
    else
        if perfCheckConn then perfCheckConn:Disconnect(); perfCheckConn = nil end
    end
end

