-- AUTO PARRY – يعتمد على Highlight القاتل الذي أرسلته
local function IsPlayerInsideKillerHighlight()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    -- البحث عن جميع Highlights اللي اسمها "Highlight" وكائنها Killer
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.ClassName == "Highlight" and v.Name == "Highlight" and v.Enabled then
            if v.Adornee and v.Adornee:IsA("Model") then
                local killerModel = v.Adornee
                -- تحقق أن هذا الكائن تابع للقاتل (موجود في PLAYERS.KILLER)
                local pf = workspace:FindFirstChild("PLAYERS")
                local kf = pf and pf:FindFirstChild("KILLER")
                if kf and killerModel.Parent == kf then
                    -- الآن تحقق من المسافة بين اللاعب و Part القاتل
                    local kr = killerModel:FindFirstChild("HumanoidRootPart")
                    if kr then
                        local dist = (root.Position - kr.Position).Magnitude
                        if dist <= S.ParryRangeBasic then
                            -- اللاعب داخل نطاق الـHighlight، نصد
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

