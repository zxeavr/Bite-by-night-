local function FindNearestSurvivor()
    local vp=Camera.ViewportSize; local center=Vector2.new(vp.X*0.5,vp.Y*0.5)
    local best=nil; local bestD=S.CamFOV
    local pf=workspace:FindFirstChild("PLAYERS")
    local af=pf and pf:FindFirstChild("ALIVE"); if not af then return nil end
    for _,m in ipairs(af:GetChildren()) do
        if m.Name==LP.Name then continue end
        local h=m:FindFirstChild("HumanoidRootPart"); if not h then continue end
        local sp,vis=Camera:WorldToViewportPoint(h.Position); if not vis then continue end
        local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude
        if d<bestD then bestD=d; best=h end
    end
    return best
end

local function StartCamLockOnTrack(track)
    local target=FindNearestSurvivor(); if not target then return end
    S.CamTarget=target; camActive=true
    -- Stop when animation ends
    local conn; conn=track.Stopped:Connect(function()
        conn:Disconnect()
        if S.CamTarget==target then
            camActive=false; S.CamTarget=nil
        end
    end)
end

local hookedKillers={}
local function HookKillerAnim(km)
    if not km or hookedKillers[km] then return end; hookedKillers[km]=true
    local hum=km:FindFirstChildOfClass("Humanoid"); if not hum then return end
    hum.AnimationPlayed:Connect(function(track)
        if not track or not track.Animation then return end
        local animId=track.Animation.AnimationId
        local cfg=CAM_ANIM_CONFIG[animId]
        if not cfg then return end
        if not S[cfg.feature] then return end
        if cfg.isStop then
            -- Stop lock for this feature
            camActive=false; S.CamTarget=nil
        else
            -- Start lock instantly
            StartCamLockOnTrack(track)
        end
    end)
    km.AncestryChanged:Connect(function() if not km.Parent then hookedKillers[km]=nil end end)
end

