    if self.fbConn then pcall(function() self.fbConn:Disconnect() end); self.fbConn = nil end
    if not state then
        pcall(function()
            Lighting.Ambient = self.orig.ambient
            Lighting.Brightness = self.orig.brightness
            for _, e in ipairs(Lighting:GetChildren()) do
                if e:IsA("PostEffect") then e.Enabled = true end
            end
        end)
        return
    end
    self.fbConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            Lighting.Ambient = Color3.new(1, 1, 1)
            Lighting.Brightness = 2
            for _, e in ipairs(Lighting:GetChildren()) do
                if e:IsA("PostEffect") then e.Enabled = false end
            end
        end)
