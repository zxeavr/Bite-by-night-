            if not anyOn then
                for _, d in pairs(espReg) do pcall(function()
                    if d.HL then d.HL.Enabled = false end; if d.SB then d.SB.Visible = false end
                    if d.BB then d.BB.Enabled = false end; if d.DotBB then d.DotBB.Enabled = false end
                end) end; continue
            end
            pcall(function()
                local pf = workspace:FindFirstChild("PLAYERS")
                local kf = pf and pf:FindFirstChild("KILLER")
                if kf then for _, m in ipairs(kf:GetChildren()) do if m.Name ~= LP.Name then ApplyESP(m, S.T.Killer, m.Name, nil, true) end end end
                local af = pf and pf:FindFirstChild("ALIVE")
