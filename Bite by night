local function FlingNearest()
    if not CFG.FLING_Enabled then return end
    local root = GetRoot()
    if not root then return end
    local closest, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local tr = p.Character:FindFirstChild("HumanoidRootPart")
            if tr then
                local d = (tr.Position - root.Position).Magnitude
                if d < bestD then bestD = d; closest = p end
            end
        end
    end
    if closest and closest.Character then
        local tr = closest.Character:FindFirstChild("HumanoidRootPart")
        if tr then
            local orig = root.CFrame
            for i = 1, 10 do
                root.CFrame = tr.CFrame
                root.Velocity = Vector3.new(CFG.FLING_Strength, CFG.FLING_Strength/2, CFG.FLING_Strength)
                root.RotVelocity = Vector3.new(9999, 9999, 9999)
                task.wait()
            end
            root.CFrame = orig
            root.Velocity = Vector3.zero
            root.RotVelocity = Vector3.zero
        end
    end
end

-- ═══════════════════════════════════════════════════════════════════════
--  MAIN LOOP (THROTTLED 10Hz)
-- ═══════════════════════════════════════════════════════════════════════
local LastLoop = 0
RunService.Heartbeat:Connect(function()
    if State.Unloaded then return end
    local now = tick()
    if now - LastLoop < 0.1 then return end
    LastLoop = now

    -- Cache
    if now - State.LastCache >= 2 then State.LastCache = now; ScanMap() end

    -- Visibility
    if now - State.LastVis >= 0.2 then
        State.LastVis = now
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then Cache.Visibility[p] = IsVis(p.Character) end
        end
    end

    -- ESP Players
    if CFG.ESP_Enabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local isK = IsKiller(p)
                local show = (isK and CFG.ESP_Killer) or (not isK and CFG.ESP_Survivor)
                if show then
                    local col = isK and COLORS.Killer or COLORS.Survivor
                    local r = p.Character:FindFirstChild("HumanoidRootPart")
                    local d = r and Dist(r.Position) or math.huge
                    if d <= CFG.ESP_MaxDist then
                        local lbl = p.Name
                        if CFG.ESP_Health then
                            local hum = p.Character:FindFirstChildOfClass("Humanoid")
                            if hum then lbl = lbl .. "\nHP: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) end
                        end
                        ESP.Create(p.Character, col, lbl)
                        ESP.Update(p.Character, lbl, d)
                        ESP.SetVis(p.Character, true)
                    else
                        ESP.SetVis(p.Character, false)
                    end
                else
                    ESP.SetVis(p.Character, false)
                end
            end
        end
    else
        ESP.Clear()
    end

    -- ESP Objects
    if CFG.ESP_Enabled then
        local objs = {
            {Cache.Generators, CFG.ESP_Generator, COLORS.Generator, "GEN"},
            {Cache.Gates, CFG.ESP_Gate, COLORS.Gate, "GATE"},
            {Cache.Hooks, CFG.ESP_Hook, COLORS.Hook, "HOOK"},
            {Cache.Pallets, CFG.ESP_Pallet, COLORS.Pallet, "PALLET"},
            {Cache.Windows, CFG.ESP_Window, COLORS.Window, "WINDOW"},
        }
        for _, data in ipairs(objs) do
            for _, obj in ipairs(data[1]) do
                if data[2] and obj.part and obj.part.Parent then
                    local isClose = data[4] == "HOOK" and CFG.ESP_ClosestHook and obj == Cache.ClosestHook
                    local col = isClose and COLORS.HookClose or data[3]
                    local lbl = isClose and "HOOK!" or data[4]
                    local d = Dist(obj.part.Position)
                    if d <= CFG.ESP_MaxDist then
                        local t = obj.model or obj.part
                        ESP.Create(t, col, lbl)
                        ESP.Update(t, lbl, d)
                        ESP.SetVis(t, true)
                    end
                end
            end
        end
    end

    -- Radar
    UpdateRadar()

    -- Aimbot
    AimbotUpdate()
    if FOVCircle then
        if CFG.AIM_Enabled and CFG.AIM_ShowFOV then
            FOVCircle.Position = Camera.ViewportSize / 2
            FOVCircle.Radius = CFG.AIM_FOV
            FOVCircle.Color = State.AimTarget and COLORS.UI_On or COLORS.UI_Accent
            FOVCircle.Visible = true
        else
            FOVCircle.Visible = false
        end
    end

    -- Combat & Movement
    UpdateSpeed()
    UpdateNoclip()
    UpdateFly()
    UpdateJump()
    SetupInfJump()
    UpdateHitboxes()
    AutoAttack()
    AutoParry()
    AutoWiggle()
    TeleportAway()
    NoFall()
    UpdateFog()
    UpdateFOV()
    UpdateThirdPerson()
    UpdateNoSlowdown()
    AutoHook()
    DoubleTap()
