    local function CompleteAllGenerators()
        local mF=GetMap(); if not mF then return end
        local genFolder=mF:FindFirstChild("Generators"); if not genFolder then return end
        local wasInstantGen=S.InstantGen
        S.InstantGen=true; StartInstantGen()
        for _,gen in ipairs(genFolder:GetChildren()) do
            if not S.AutoFarm then break end
            if gen:GetAttribute("Progress") and gen:GetAttribute("Progress") >= 100 then continue end
            if not gen:IsA("Model") or not gen.PrimaryPart then continue end
            SafeTeleportTo(CFrame.new(gen.PrimaryPart.Position+Vector3.new(0,2,0)))
            task.wait(0.3)
            local rootPart=gen:FindFirstChild("RootPart")
            if rootPart then
                local attempts=0
                repeat
                    attempts=attempts+1
                    local prompt=nil
                    for i=1,3 do
                        local pt=rootPart:FindFirstChild("Point"..i)
                        if pt then
                            local pp=pt:FindFirstChildOfClass("ProximityPrompt")
                            if pp and pp.Enabled then prompt=pp; break end
                        end
                    end
                    if not prompt then
                        for _,atch in ipairs(rootPart:GetChildren()) do
                            if atch:IsA("Attachment") then
                                local pp=atch:FindFirstChildOfClass("ProximityPrompt")
                                if pp and pp.Enabled then prompt=pp; break end
                            end
                        end
                    end
                    if prompt and fireproximityprompt then
                        pcall(function() fireproximityprompt(prompt) end)
                    end
                    task.wait(1)
                until (gen:GetAttribute("Progress") or 0) >= 100 or attempts > 15 or not S.AutoFarm
            end
            task.wait(0.5)
            if LPChar and LPChar:FindFirstChild("HumanoidRootPart") then
                LPChar.HumanoidRootPart.CFrame=CFrame.new(gen.PrimaryPart.Position-Vector3.new(0,300,0))
            end
            task.wait(0.3)
        end
        if not wasInstantGen then S.InstantGen=false; StopInstantGen() end
        EscapeMap()
    end
