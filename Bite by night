local function ApplyESP(obj, tcfg, label, maxDist, showHP, labelOverride)
    if not obj or not obj.Parent then return end
    local anyOn = tcfg.On or (showHP and S.ESPHealth)
    local d = espReg[obj]
    if d then
        if not d.valid then espReg[obj] = nil; d = nil
        elseif not d.HL or not d.HL.Parent then
            pcall(function() if d.SB then d.SB:Destroy() end; if d.BB then d.BB:Destroy() end; if d.DotBB then d.DotBB:Destroy() end end)
            espReg[obj] = nil; d = nil
        end
    end
    if not anyOn then
        if d then
            if d.HL then d.HL.Enabled = false end; if d.SB then d.SB.Visible = false end
            if d.BB then d.BB.Enabled = false end; if d.DotBB then d.DotBB.Enabled = false end
        end; return
    end
    if not d then d = BuildESP(obj, tcfg.Color, label, maxDist) end; if not d then return end
    if d.HL then d.HL.FillColor = tcfg.Color; d.HL.OutlineColor = tcfg.Color end
    if d.SB then d.SB.Color3 = tcfg.Color; d.SB.SurfaceColor3 = tcfg.Color end
    if d.DotFr then d.DotFr.BackgroundColor3 = tcfg.Color end
    if d.Lbl then d.Lbl.TextColor3 = tcfg.Color; d.Lbl.Text = labelOverride or label end
    local mode = S.ESPMode
    if d.HL then d.HL.Enabled = tcfg.On and (mode == "Highlight") end
    if d.SB then d.SB.Visible = tcfg.On and (mode == "Chams") end
    if d.DotBB then d.DotBB.Enabled = tcfg.On and (mode == "Dot") end
    local showBB = (tcfg.On and (mode == "Name" or labelOverride ~= nil)) or (showHP and S.ESPHealth)
    if d.BB then d.BB.Enabled = showBB end
    if d.Lbl then d.Lbl.Visible = tcfg.On and (mode == "Name" or labelOverride ~= nil) end
    if d.HpL then
        if showHP and S.ESPHealth then
            local hum = obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local hp = math.floor(hum.Health + 0.5); local mhp = math.max(math.floor(hum.MaxHealth + 0.5), 1)
                local r = math.clamp(hum.Health / mhp, 0, 1)
                d.HpL.Text = hp .. " / " .. mhp
                d.HpL.TextColor3 = Color3.fromRGB(math.floor((1-r)*255), math.floor(r*200+55), 30)
                d.HpL.Visible = true
            else d.HpL.Visible = false end
        else d.HpL.Visible = false end
    end
end
