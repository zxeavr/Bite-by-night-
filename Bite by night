-- AUTO FARM (FIX: underground = 50 studs only, not 300)
local farmThread = nil
local function FarmMoveTo(targetCF)
    if not LPChar then return end
    local hrp = LPChar:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    if S.FarmMode == "TP" then
        if S.FarmUnderground then
            hrp.CFrame = CFrame.new(targetCF.Position - Vector3.new(0, 50, 0)) -- FIX: 50 not 300
            task.wait(0.1)
            hrp.CFrame = targetCF
        else
            hrp.CFrame = targetCF
        end
    else
        -- Tween mode
        if S.FarmUnderground then
            hrp.CFrame = CFrame.new(hrp.Position - Vector3.new(0, 50, 0)); task.wait(0.05)
        end
        local dist = (hrp.Position - targetCF.Position).Magnitude
        local time = dist / math.max(S.FarmSpeed, 5)
        local tw = TweenService:Create(hrp, TweenInfo.new(time, Enum.EasingStyle.Linear), {CFrame = targetCF})
        tw:Play(); tw.Completed:Wait()
    end
end
local function CompleteAllGenerators()
    local mF = GetMap(); if not mF then return end
    local genFolder = mF:FindFirstChild("Generators"); if not genFolder then return end
    local wasInstantGen = S.InstantGen; S.InstantGen = true; StartInstantGen()
    Log("Farm: starting generators loop")
    for _, gen in ipairs(genFolder:GetChildren()) do
        if not S.AutoFarm then break end
        local prog = gen:GetAttribute("Progress") or 0
        if prog >= 100 then continue end
        if not gen:IsA("Model") or not gen.PrimaryPart then continue end
        Log("Farm: generator progress = " .. prog)
        FarmMoveTo(CFrame.new(gen.PrimaryPart.Position + Vector3.new(0, 2, 0))); task.wait(0.3)
        local rootPart = gen:FindFirstChild("RootPart")
        if rootPart then
            Log("Farm: rootPart found, looking for prompts...")
            local attempts = 0
            repeat
                attempts = attempts + 1
                local prompt = nil
                for i = 1, 3 do
                    local pt = rootPart:FindFirstChild("Point" .. i)
                    if pt then local pp = pt:FindFirstChildOfClass("ProximityPrompt"); if pp and pp.Enabled then prompt = pp; break end end
                end
                if not prompt then for _, atch in ipairs(rootPart:GetChildren()) do
                    if atch:IsA("Attachment") then local pp = atch:FindFirstChildOfClass("ProximityPrompt"); if pp and pp.Enabled then prompt = pp; break end end
                end end
                if prompt and fireproximityprompt then pcall(function() fireproximityprompt(prompt) end) end
                task.wait(1)
            until (gen:GetAttribute("Progress") or 0) >= 100 or attempts > 15 or not S.AutoFarm
        else
            Log("Farm: NO rootPart found on " .. gen.Name .. ". Children: " .. table.concat((function() local t={} for _,c in ipairs(gen:GetChildren()) do t[#t+1]=c.Name end return t end)(),", "))
        end
        task.wait(0.3)
        if S.FarmUnderground and LPChar and LPChar:FindFirstChild("HumanoidRootPart") then
            LPChar.HumanoidRootPart.CFrame = CFrame.new(gen.PrimaryPart.Position - Vector3.new(0, 50, 0)) -- FIX: 50
        end
        task.wait(0.3)
    end
    if not wasInstantGen then S.InstantGen = false; StopInstantGen() end
    -- Wait underground until CAN_ESCAPE if underground mode
    if S.FarmUnderground then
        local timeout = 0
        while timeout < 120 do
            task.wait(1); timeout = timeout + 1
            local gF = workspace:FindFirstChild("GAME"); local cE = gF and gF:FindFirstChild("CAN_ESCAPE")
            if cE and cE.Value then break end
        end
    end
    -- Auto escape
    local gF = workspace:FindFirstChild("GAME"); local cE = gF and gF:FindFirstChild("CAN_ESCAPE")
    if not cE or not cE.Value then return end
    local mapF = workspace.MAPS and workspace.MAPS:FindFirstChild("GAME MAP"); if not mapF then return end
    local ef = mapF:FindFirstChild("Escapes"); if not ef then return end
    for _, v in ipairs(ef:GetChildren()) do
        local isEnabled = v:GetAttribute("Enabled"); if isEnabled == false then continue end
        local cf = v:IsA("BasePart") and v.CFrame or (v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.CFrame)
        if not cf then continue end
        if LPChar then LPChar:PivotTo(cf + Vector3.new(0,3,0)) end; return
    end
end
