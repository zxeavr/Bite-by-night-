-- ANTI STUN (FIX: fully clears bypass slow on disable)
local STUN_ATTRS = {"Stun","Stunned","IsStunned","Blinded","IsBlinded","Slowed","Slowness"}
local STUN_TAGS  = {"SlowStop","Stun","Stunned","Blinded","Slowed"}
local antiStunConn = nil
local function SetAntiStun(on)
    if antiStunConn then antiStunConn:Disconnect(); antiStunConn = nil end
    if not on then
        -- FIX: fully restore walk speed and remove ALL stun-related state
        pcall(function()
            if LPHum then LPHum.WalkSpeed = 16 end
            if LPChar then
                -- Remove tags
                for _, t in ipairs(STUN_TAGS) do
                    if CollectionService:HasTag(LPChar, t) then CollectionService:RemoveTag(LPChar, t) end
                end
                -- Clear attributes (set to nil to let server control again)
                for _, a in ipairs(STUN_ATTRS) do LPChar:SetAttribute(a, nil) end
                -- Only clear WalkSpeed override if AutoRun is OFF
                if not S.AutoRun then LPChar:SetAttribute("WalkSpeed", nil) end
            end
        end)
        return
    end
    antiStunConn = RunService.Heartbeat:Connect(function()
        if not S.AntiStun or not LPChar or not LPHum then return end
        pcall(function()
            -- Clear stun attributes
            for _, a in ipairs(STUN_ATTRS) do local v = LPChar:GetAttribute(a)
                if type(v) == "boolean" and v then LPChar:SetAttribute(a, false)
                elseif type(v) == "number" and v > 0 then LPChar:SetAttribute(a, 0) end
            end
            -- Remove stun tags
            for _, t in ipairs(STUN_TAGS) do
                if CollectionService:HasTag(LPChar, t) then CollectionService:RemoveTag(LPChar, t) end
            end
            -- Restore walk speed if it was reduced by stun
            local expectedSpeed = S.AutoRun and S.RunSpeed or 16
            if LPHum.WalkSpeed < (expectedSpeed * 0.5) then
                LPHum.WalkSpeed = expectedSpeed
                if S.AutoRun then LPChar:SetAttribute("WalkSpeed", expectedSpeed) end
            end
        end)
    end)
end

