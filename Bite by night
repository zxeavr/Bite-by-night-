			nmL.Position=UDim2.fromScale(0,0.42); nmL.BackgroundTransparency=1; nmL.Text=label
			nmL.TextColor3=color; nmL.Font=Enum.Font.GothamBold; nmL.TextSize=16; nmL.Visible=false
			d.BB=bb; d.HpL=hpL; d.Lbl=nmL
