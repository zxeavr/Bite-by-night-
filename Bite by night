local function ApplyESP(obj,tcfg,label)
    if not obj or not obj.Parent then return end
    local anyOn=tcfg.On or (S.ESPHealth and obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid"))
    local d=espReg[obj]
    if d then
        if not d.valid then espReg[obj]=nil; d=nil
        elseif d.HL and not d.HL.Parent then
            pcall(function() if d.SB then d.SB:Destroy() end; if d.BB then d.BB:Destroy() end end)
            espReg[obj]=nil; d=nil
        end
    end
    if not anyOn then
        if d then
            if d.HL then d.HL.Enabled=false end; if d.SB then d.SB.Visible=false end; if d.BB then d.BB.Enabled=false end
        end; return
    end
    if not d then d=BuildESP(obj,tcfg.Color,label) end; if not d then return end
    if d.HL then d.HL.FillColor=tcfg.Color; d.HL.OutlineColor=tcfg.Color end
    if d.SB then d.SB.Color3=tcfg.Color; d.SB.SurfaceColor3=tcfg.Color end
    if d.Lbl then d.Lbl.TextColor3=tcfg.Color; d.Lbl.Text=label end
    if d.HL then d.HL.Enabled=tcfg.On and (S.ESPMode=="Highlight") end
    if d.SB then d.SB.Visible=tcfg.On and (S.ESPMode=="Chams") end
    local showBB=(tcfg.On and S.ESPMode=="Name") or (S.ESPHealth and obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid"))
    if d.BB then d.BB.Enabled=showBB end
    if d.Lbl then d.Lbl.Visible=tcfg.On and (S.ESPMode=="Name") end
    if d.HpL and obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
        local hum=obj:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health>0 then
            local hp=math.floor(hum.Health+0.5); local mhp=math.max(math.floor(hum.MaxHealth+0.5),1)
