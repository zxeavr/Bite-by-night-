local TRAP_ATTRS = {"Trapped","BeartrapCaught","Caught","InTrap","Tripped","Snared","TrapCaught"}
local TRAP_TAGS  = {"Trapped","BeartrapCaught","Bear","InBearTrap","BearTrap"}
local antiTrapConn; local trapSigConns={}; local trapDeb=false

local function TrapEscape()
    if not LPChar then return end
    Log("TrapEscape!")
    for _, t in ipairs(TRAP_TAGS) do
        pcall(function() if CollectionService:HasTag(LPChar,t) then
            CollectionService:RemoveTag(LPChar,t); Log("Removed trap tag: "..t)
        end end)
    end
    for _, a in ipairs(TRAP_ATTRS) do pcall(function()
        local v=LPChar:GetAttribute(a)
        if type(v)=="boolean" and v then LPChar:SetAttribute(a,false)
        elseif type(v)=="number" and v>0 then LPChar:SetAttribute(a,0) end
    end) end
    local ws = S.AutoRun and S.RunSpeed or 16
    if LPHum then LPHum.WalkSpeed=math.max(ws,16) end
    for _, obj in ipairs(LPChar:GetDescendants()) do
        if obj:IsA("BallSocketConstraint") or obj:IsA("RopeConstraint") or obj:IsA("WeldConstraint") or obj:IsA("HingeConstraint") then
            pcall(function() obj:Destroy() end)
        end
    end
    local hrp=LPChar:FindFirstChild("HumanoidRootPart")
    if hrp and not trapDeb then
        trapDeb=true; pcall(function() hrp.CFrame=hrp.CFrame*CFrame.new(0,4,0) end)
        task.delay(0.5,function() trapDeb=false end)
    end
end

local function SetAntiTrap(on)
    if antiTrapConn then antiTrapConn:Disconnect(); antiTrapConn=nil end
    for _, c in ipairs(trapSigConns) do pcall(function() c:Disconnect() end) end; trapSigConns={}
    if not on then return end
    Log("AntiTrap ON - walk into trap to see tag in console")
    for _, tagName in ipairs(TRAP_TAGS) do
        local ok, c = pcall(function()
            return CollectionService:GetInstanceAddedSignal(tagName):Connect(function(inst)
                if not S.AntiTrap then return end
                if inst==LP.Character or (LP.Character and inst:IsDescendantOf(LP.Character)) then
                    Log(">>> TRAP TAG: "..tagName.." <<<")
                    TrapEscape()
                end
            end)
        end)
        if ok then table.insert(trapSigConns,c) end
    end
    antiTrapConn = RunService.Heartbeat:Connect(function()
        if not S.AntiTrap or not LPChar or not LPHum then return end
        pcall(function()
            if LPHum.WalkSpeed==0 and LPHum.Health>0 then
                Log(">>> WalkSpeed=0 trap detected <<<")
                TrapEscape(); return
            end
            for _, t in ipairs(TRAP_TAGS) do
                if CollectionService:HasTag(LPChar,t) then
                    Log(">>> Trap tag found: "..t.." <<<")
                    CollectionService:RemoveTag(LPChar,t); TrapEscape(); return
                end
            end
            for _, a in ipairs(TRAP_ATTRS) do
                local v=LPChar:GetAttribute(a)
                if type(v)=="boolean" and v then
                    Log(">>> Trap attr: "..a.." <<<")
                    LPChar:SetAttribute(a,false); TrapEscape(); return
                end
            end
