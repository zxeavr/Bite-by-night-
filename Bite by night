        s("ShowParryViz",S.ShowParryViz); s("ParryDynamic",S.ParryDynamic); s("ParryRainbow",S.ParryRainbow)
        s("CamLockRotten",S.CamLockRotten); s("CamLockM1",S.CamLockM1)
